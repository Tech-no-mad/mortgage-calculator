---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLiveRates } from '../utils/rates';
const ratesData = await getLiveRates(Astro);
import AdSlot from '../components/AdSlot.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Extra Payment Calculator",
      "description": "See how much interest you can save and how much faster you can pay off your mortgage by making extra payments.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
    {
        "@type": "Question",
        "name": "Does making one extra payment a year really help?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. By making just one extra mortgage payment per year (often achieved by switching to bi-weekly payments), you can shave several years off a 30-year mortgage and save tens of thousands of dollars in total interest."
        }
    },
    {
        "@type": "Question",
        "name": "Should I make extra payments or invest the money instead?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "This is a debate between guaranteed return and potential return. Paying down a 6% mortgage yields a guaranteed 6% 'return' in saved interest. Investing the money in the stock market might yield a 7-10% return on average, but it carries market risk."
        }
    },
    {
        "@type": "Question",
        "name": "How do I ensure my extra payment goes toward the principal?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "When making an extra payment online or by check, you must explicitly instruct your lender to apply the funds directly to the principal balance. Otherwise, they might apply it to next month's interest or deposit it into an escrow account."
        }
    },
    {
        "@type": "Question",
        "name": "Is there a penalty for paying off my mortgage early?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most modern residential mortgages do not have prepayment penalties, but you should always review your specific loan documents to be absolutely sure before making large lump-sum extra payments."
        }
    }
]
    }
  ]
};
---

<BaseLayout
  keywords="extra mortgage payment calculator, early payoff calculator, pay off mortgage early, biweekly payment savings, mortgage principal calculator, mortgage calculator, home loan calculator, current mortgage rates, monthly mortgage payment, free mortgage calculator, mortgage payment calculator, house payment calculator, home mortgage calculator, calculate mortgage, mortgage estimator, monthly house payment, mortgage interest calculator, loan payment calculator, how much is my mortgage, mortgage calculator with taxes, mortgage calculator with PMI, mortgage calculator with insurance, PITI calculator, home buying calculator, home affordability calculator, mortgage amortization, what will my mortgage payment be, mortgage calculator 2025, best mortgage calculator, accurate mortgage calculator, simple mortgage calculator, mortgage calculator USA, home loan payment estimator, mortgage rate calculator, mortgage cost calculator"
  canonicalUrl="/extra-payment-calculator/"
  title="Extra Payment Calculator"
  description="See how much interest you can save and how much faster you can pay off your mortgage by making extra payments."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="color: var(--text-primary);">
        Extra Payment
        <span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">Calculator</span>
      </h1>
      <p class="text-base sm:text-lg max-w-xl mx-auto" style="color: var(--text-muted);">
        Discover how extra monthly payments can shave years off your mortgage and save you thousands in interest.
      </p>
    </div>

            <button type="button" id="email-cta" class="inline-flex items-center gap-1.5 px-4 py-2 bg-[var(--color-usa-blue)] text-white text-sm font-medium rounded-lg hover:bg-opacity-90 transition shadow-sm mb-6 mt-4 cursor-pointer mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              Email me this breakdown
            </button>

  </section>

  <!-- Ad Slot: Leaderboard -->
  <AdSlot type="leaderboard" />


  <!-- Ad Slot -->
  <div class="ad-slot max-w-4xl mx-auto my-6">Advertisement Space Reserved</div>


  <!-- Calculator -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="card p-6 sm:p-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10">

        <!-- INPUTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#06b6d4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Current Mortgage
          </h2>

          <!-- Loan Amount -->
          <div>
            <label class="label block mb-1.5">Original Loan Amount</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input aria-label="Loan Amount" type="text" id="loan-amount" value="300,000" inputmode="numeric" class="calc-input pl-7 font-mono" data-step="1" data-tooltip="Step 1: Original Loan Amount" />
            </div>
          </div>

          <!-- Interest Rate -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="label block mb-1.5">Interest Rate (%)</label>
              <input aria-label="Interest Rate" type="text" id="interest-rate" value="6.52" inputmode="decimal" class="calc-input font-mono" data-step="2" data-tooltip="Step 2: Interest Rate" />
            </div>
            <div>
              <label class="label block mb-1.5">Original Term</label>
              <select aria-label="Loan Term" id="loan-term" class="calc-input font-mono w-full" data-step="3" data-tooltip="Step 3: Original Loan Term">
                <option value="30">30 Years</option>
                <option value="20">20 Years</option>
                <option value="15">15 Years</option>
                <option value="10">10 Years</option>
              </select>
            </div>
          </div>

          <h2 class="text-base font-semibold flex items-center gap-2 mt-8" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#f59e0b]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Extra Strategy
          </h2>

          <!-- Extra Payment -->
          <div>
            <label class="label block mb-1.5">Extra Monthly Payment</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input aria-label="Extra Payment" type="text" id="extra-payment" value="200" inputmode="numeric" class="calc-input pl-7 font-mono" data-step="4" data-tooltip="Step 4: Extra Monthly Payment" />
            </div>
          </div>
        </div>

        <!-- RESULTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#10b981]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Your Savings
          </h2>

          <div class="text-center py-8 rounded-xl" style="background: var(--bg-surface-2); border: 1px solid var(--border-default);">
            <p class="label-faint text-sm mb-2">Total Interest Saved</p>
            <div class="text-4xl sm:text-5xl font-bold font-mono tracking-tight" id="interest-saved">
              <span class="text-[#10b981] dark:text-emerald-400">$0</span>
            </div>
          </div>

          <div>
            <div class="result-row">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[#f59e0b]"></span>
                <span class="label">Time Saved</span>
              </div>
              <span class="text-sm font-semibold font-mono text-[#f59e0b] dark:text-amber-300" id="time-saved">0 yrs 0 mos</span>
            </div>
            <div class="result-row">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[#06b6d4]"></span>
                <span class="label">New Payoff Time</span>
              </div>
              <span class="text-sm font-semibold font-mono text-[#06b6d4] dark:text-cyan-300" id="new-payoff">0 yrs 0 mos</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  
  <!-- Ad Slot -->
  <div class="ad-slot max-w-4xl mx-auto my-6">Advertisement Space Reserved</div>
</section>

  <!-- Ad Slot: Rectangle -->
  <AdSlot type="rectangle" />


  <!-- Related Links -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="card p-8">
      <h3 class="text-xl font-bold mb-6" style="color: var(--text-primary);">Related Tools & States</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div>
          <h4 class="font-semibold mb-4 text-[#06b6d4]">More Calculators</h4>
          <ul class="space-y-3">
            <li><a href="/amortization-schedule/" class="text-sm hover:text-[#10b981] transition-colors" style="color: var(--text-secondary);">→ Amortization Schedule</a></li>
            <li><a href="/recast-calculator/" class="text-sm hover:text-[#10b981] transition-colors" style="color: var(--text-secondary);">→ Mortgage Recast Calculator</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-4 text-[#10b981]">State Spotlights</h4>
          <ul class="space-y-3">
            <li><a href="/states/north-carolina/" class="text-sm hover:text-[#06b6d4] transition-colors" style="color: var(--text-secondary);">→ North Carolina Mortgage Calculator</a></li>
            <li><a href="/states/michigan/" class="text-sm hover:text-[#06b6d4] transition-colors" style="color: var(--text-secondary);">→ Michigan Mortgage Calculator</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }
  function parse(s) { return parseFloat(String(s).replace(/[^0-9.-]/g, '')) || 0; }
  function fmtNum(n) { return Math.round(n).toLocaleString('en-US'); }

  function calcExtra() {
    const loan = parse((document.getElementById('loan-amount') as HTMLInputElement).value);
    const r = parseFloat((document.getElementById('interest-rate') as HTMLInputElement).value);
    const t = parseInt((document.getElementById('loan-term') as HTMLSelectElement).value);
    const extra = parse((document.getElementById('extra-payment') as HTMLInputElement).value);

    // Format
    if (document.activeElement?.id !== 'loan-amount') (document.getElementById('loan-amount') as HTMLInputElement).value = fmtNum(loan);
    if (document.activeElement?.id !== 'extra-payment') (document.getElementById('extra-payment') as HTMLInputElement).value = fmtNum(extra);

    const mr = (r / 100) / 12;
    const n = t * 12;

    // Normal monthly payment
    let pi = 0;
    if (mr > 0) {
      pi = loan * (mr * Math.pow(1 + mr, n)) / (Math.pow(1 + mr, n) - 1);
    } else {
      pi = loan / n;
    }

    const normalTotalInterest = (pi * n) - loan;

    // With extra payment
    let newBalance = loan;
    let newMonths = 0;
    let newTotalInterest = 0;

    const actualPayment = pi + extra;

    if (extra > 0) {
      while (newBalance > 0 && newMonths < n * 2) {
        const interest = newBalance * mr;
        newTotalInterest += interest;
        const principal = actualPayment - interest;
        newBalance -= principal;
        newMonths++;
      }
    } else {
      newMonths = n;
      newTotalInterest = normalTotalInterest;
    }

    const interestSaved = Math.max(0, normalTotalInterest - newTotalInterest);
    const monthsSaved = Math.max(0, n - newMonths);

    if (interestSaved > 0) {
      document.getElementById('interest-saved')!.innerHTML = `<span class="text-[#10b981] dark:text-emerald-400">${fmt(interestSaved)}</span>`;
    } else if (interestSaved < 0) {
      document.getElementById('interest-saved')!.innerHTML = `<span class="text-[#f43f5e] dark:text-rose-400">${fmt(interestSaved)}</span>`;
    } else {
      document.getElementById('interest-saved')!.innerHTML = `<span class="text-[#f59e0b] dark:text-amber-300">${fmt(interestSaved)}</span>`;
    }
    
    const savedYrs = Math.floor(monthsSaved / 12);
    const savedMos = monthsSaved % 12;
    document.getElementById('time-saved')!.textContent = `${savedYrs} yrs ${savedMos} mos`;

    const newYrs = Math.floor(newMonths / 12);
    const newMos = newMonths % 12;
    document.getElementById('new-payoff')!.textContent = `${newYrs} yrs ${newMos} mos`;
  }

  document.addEventListener('DOMContentLoaded', async () => {
    ['loan-amount', 'interest-rate', 'loan-term', 'extra-payment'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', calcExtra);
      document.getElementById(id)?.addEventListener('change', calcExtra);
    });
    calcExtra();

    const { OnboardingTour } = await import('../scripts/onboarding.ts');
    new OnboardingTour().init();
  });

  document.getElementById('email-cta')?.addEventListener('click', () => {
    if (typeof (window as any).__openEmailModal === 'function') {
      (window as any).__openEmailModal({
        title: "Your Extra Payment Breakdown",
        fields: [
          { label: 'Interest Saved', value: document.getElementById('interest-saved')?.textContent?.trim() || '$0', highlight: true },
          { label: 'Time Saved', value: document.getElementById('time-saved')?.textContent?.trim() || '$0' },
          { label: 'New Payoff Date', value: document.getElementById('new-payoff-date')?.textContent?.trim() || '$0' }
        ]
      });
    }
  });
</script>
