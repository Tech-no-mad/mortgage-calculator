---
import BaseLayout from '../layouts/BaseLayout.astro';
import statesData from '../data/states.json';
import { getLiveRates } from '../utils/rates';
const ratesData = await getLiveRates(Astro);
import AdSlot from '../components/AdSlot.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "HELOC Calculator",
      "description": "Calculate your Home Equity Line of Credit (HELOC) payments and estimate your borrowing power.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
    {
        "@type": "Question",
        "name": "What is the difference between a HELOC and a home equity loan?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "A home equity loan provides a single lump sum of cash with a fixed interest rate. A HELOC (Home Equity Line of Credit) acts like a credit card tied to your home's equity: you can draw money as needed over a specific period, usually with a variable interest rate."
        }
    },
    {
        "@type": "Question",
        "name": "How is a HELOC interest rate determined?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "HELOC rates are typically variable and tied to a benchmark like the Prime Rate. Lenders add a margin to that benchmark based on your credit score, Loan-to-Value (LTV) ratio, and the size of the credit line."
        }
    },
    {
        "@type": "Question",
        "name": "Can I deduct HELOC interest on my taxes?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "Under current IRS rules, you can only deduct interest on a HELOC if the borrowed funds are used to 'buy, build or substantially improve' the home that secures the loan. Using a HELOC to pay off credit card debt or buy a car is generally not tax-deductible."
        }
    },
    {
        "@type": "Question",
        "name": "What happens when the HELOC draw period ends?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "During the draw period (usually 10 years), you can borrow money and often only have to make interest payments. When the draw period ends, the repayment period begins (usually 10 to 20 years). You can no longer borrow money, and you must make fully amortizing payments of principal and interest."
        }
    }
]
    }
  ]
};
---

<BaseLayout
  keywords="heloc calculator, home equity line of credit, heloc interest rates, equity loan calculator, home equity limit, mortgage calculator, home loan calculator, current mortgage rates, monthly mortgage payment, free mortgage calculator, mortgage payment calculator, house payment calculator, home mortgage calculator, calculate mortgage, mortgage estimator, monthly house payment, mortgage interest calculator, loan payment calculator, how much is my mortgage, mortgage calculator with taxes, mortgage calculator with PMI, mortgage calculator with insurance, PITI calculator, home buying calculator, home affordability calculator, mortgage amortization, what will my mortgage payment be, mortgage calculator 2025, best mortgage calculator, accurate mortgage calculator, simple mortgage calculator, mortgage calculator USA, home loan payment estimator, mortgage rate calculator, mortgage cost calculator"
  canonicalUrl="/heloc-calculator/"
  title="HELOC Calculator"
  description="Calculate your Home Equity Line of Credit (HELOC) payments and estimate your borrowing power."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="color: var(--text-primary);">
        HELOC
        <span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">Calculator</span>
      </h1>
      <p class="text-base sm:text-lg max-w-xl mx-auto" style="color: var(--text-muted);">
        Estimate your borrowing power and monthly payments for a Home Equity Line of Credit.
      </p>
    </div>
  </section>

  <!-- Ad Slot: Leaderboard -->
  <AdSlot type="leaderboard" />
<!-- Calculator -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="card p-6 sm:p-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10">

        <!-- INPUTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#06b6d4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Home Details
          </h2>

          <!-- State Selection -->
          <div>
            <label class="label block mb-1.5">State (Pre-fills Average Home Value)</label>
            <select aria-label="State Selector" id="state-selector" class="calc-input font-mono w-full mb-5" data-step="1" data-tooltip="Step 1: Enter State Selector">
              <option value="">National Average</option>
              {statesData.map(state => (
                <option value={state.abbr} data-price={state.medianPrice}>
                  {state.name}
                </option>
              ))}
            </select>
          </div>

          <!-- Home Value -->
          <div>
            <label class="label block mb-1.5">Estimated Home Value</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input aria-label="Home Value" type="text" id="home-value" value="450,000" inputmode="numeric" class="calc-input pl-7 font-mono"  data-step="2" data-tooltip="Step 2: Enter Home Value"/>
            </div>
          </div>

          <!-- Mortgage Balance -->
          <div>
            <label class="label block mb-1.5">Current Mortgage Balance</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input aria-label="Mortgage Balance" type="text" id="mortgage-balance" value="250,000" inputmode="numeric" class="calc-input pl-7 font-mono"  data-step="3" data-tooltip="Step 3: Enter Mortgage Balance"/>
            </div>
          </div>

          <h2 class="text-base font-semibold flex items-center gap-2 mt-8" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#f59e0b]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            HELOC Details
          </h2>

          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="label block mb-1.5">HELOC Amount</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
                <input aria-label="Heloc Amount" type="text" id="heloc-amount" value="50,000" inputmode="numeric" class="calc-input pl-7 font-mono"  data-step="4" data-tooltip="Step 4: Enter Heloc Amount"/>
              </div>
            </div>
            <div>
              <label class="label block mb-1.5">Interest Rate (%)</label>
              <input aria-label="Heloc Rate" type="text" id="heloc-rate" value="8.5" inputmode="decimal" class="calc-input font-mono"  data-step="5" data-tooltip="Step 5: Enter Heloc Rate"/>
            </div>
          </div>
        </div>

        <!-- RESULTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#10b981]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Draw Period Payments
          </h2>

          <div class="text-center py-8 rounded-xl" style="background: var(--bg-surface-2); border: 1px solid var(--border-default);">
            <p class="label-faint text-sm mb-2">Interest-Only Payment</p>
            <div class="text-4xl sm:text-5xl font-bold font-mono tracking-tight" id="interest-only-payment">
              <span class="text-[#06b6d4] dark:text-cyan-300">$0</span>
            </div>
            <p class="text-xs mt-3" style="color: var(--text-muted);">Typical for the first 10 years (Draw Period)</p>
          </div>
            <button type="button" id="email-cta" class="inline-flex items-center gap-1.5 px-4 py-2 bg-[var(--color-usa-blue)] text-white text-sm font-medium rounded-lg hover:bg-opacity-90 transition shadow-sm mb-6 mt-4 cursor-pointer mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              Email me this breakdown
            </button>

          <div>
            <div class="result-row">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[#10b981]"></span>
                <span class="label">Total Home Equity</span>
              </div>
              <span class="text-sm font-semibold font-mono text-[#10b981] dark:text-emerald-400" id="total-equity">$0</span>
            </div>
            <div class="result-row">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[#f59e0b]"></span>
                <span class="label">Max Borrowing Power (80% LTV)</span>
              </div>
              <span class="text-sm font-semibold font-mono text-[#f59e0b] dark:text-amber-300" id="max-borrow">$0</span>
            </div>
          </div>
          
          <div class="mt-4 p-4 rounded-lg border" style="background: var(--bg-surface-2); border-color: var(--border-default);">
            <p class="text-sm font-medium" style="color: var(--text-primary);" id="heloc-warning">
              Calculating...
            </p>
          </div>

        </div>
      </div>
    </div>
</section>

  <!-- Ad Slot: Rectangle -->
  <AdSlot type="rectangle" />

  <!-- Related Links -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="card p-8">
      <h3 class="text-xl font-bold mb-6" style="color: var(--text-primary);">Related Tools & States</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div>
          <h4 class="font-semibold mb-4 text-[#06b6d4]">More Calculators</h4>
          <ul class="space-y-3">
            <li><a href="/refinance-calculator/" class="text-sm hover:text-[#10b981] transition-colors" style="color: var(--text-secondary);">→ Refinance Calculator</a></li>
            <li><a href="/loan-payment-calculator/" class="text-sm hover:text-[#10b981] transition-colors" style="color: var(--text-secondary);">→ Loan Payment Calculator</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-4 text-[#10b981]">State Spotlights</h4>
          <ul class="space-y-3">
            <li><a href="/states/texas/" class="text-sm hover:text-[#06b6d4] transition-colors" style="color: var(--text-secondary);">→ Texas Mortgage Calculator</a></li>
            <li><a href="/states/new-york/" class="text-sm hover:text-[#06b6d4] transition-colors" style="color: var(--text-secondary);">→ New York Mortgage Calculator</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { OnboardingTour } from '../scripts/onboarding.ts';
  new OnboardingTour().init();

  function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }
  function parse(s) { return parseFloat(String(s).replace(/[^0-9.-]/g, '')) || 0; }
  function fmtNum(n) { return Math.round(n).toLocaleString('en-US'); }

  function calcHeloc() {
    const homeValue = parse((document.getElementById('home-value') as HTMLInputElement).value);
    const mortgageBalance = parse((document.getElementById('mortgage-balance') as HTMLInputElement).value);
    const helocAmount = parse((document.getElementById('heloc-amount') as HTMLInputElement).value);
    const helocRate = parseFloat((document.getElementById('heloc-rate') as HTMLInputElement).value);

    if (document.activeElement?.id !== 'home-value') (document.getElementById('home-value') as HTMLInputElement).value = fmtNum(homeValue);
    if (document.activeElement?.id !== 'mortgage-balance') (document.getElementById('mortgage-balance') as HTMLInputElement).value = fmtNum(mortgageBalance);
    if (document.activeElement?.id !== 'heloc-amount') (document.getElementById('heloc-amount') as HTMLInputElement).value = fmtNum(helocAmount);

    const totalEquity = Math.max(0, homeValue - mortgageBalance);
    const maxBorrow = Math.max(0, (homeValue * 0.8) - mortgageBalance); // 80% LTV is standard

    const monthlyInterest = helocAmount * ((helocRate / 100) / 12);

    document.getElementById('interest-only-payment')!.innerHTML = `<span class="text-[#06b6d4] dark:text-cyan-300">${fmt(monthlyInterest)}</span>`;
    document.getElementById('total-equity')!.textContent = fmt(totalEquity);
    document.getElementById('max-borrow')!.textContent = fmt(maxBorrow);

    const warningEl = document.getElementById('heloc-warning')!;
    if (helocAmount > maxBorrow) {
      warningEl.innerHTML = `<span class="text-[#f43f5e] dark:text-rose-400"><strong>Warning:</strong> The requested HELOC amount exceeds standard 80% Loan-to-Value limits. You may need to find a specialized lender.</span>`;
    } else {
      warningEl.innerHTML = `Your requested line of credit is within safe borrowing limits. During the draw period, you only pay interest on the amount you actually withdraw.`;
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('state-selector')?.addEventListener('change', (e) => {
      const select = e.target as HTMLSelectElement;
      const option = select.options[select.selectedIndex];
      if (option.value) {
        (document.getElementById('home-value') as HTMLInputElement).value = fmtNum(parseFloat(option.getAttribute('data-price') || '450000'));
      } else {
        (document.getElementById('home-value') as HTMLInputElement).value = "450,000";
      }
      calcHeloc();
    });

    ['home-value', 'mortgage-balance', 'heloc-amount', 'heloc-rate'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', calcHeloc);
      document.getElementById(id)?.addEventListener('change', calcHeloc);
    });
    calcHeloc();
  });

  document.getElementById('email-cta')?.addEventListener('click', () => {
    if (typeof (window as any).__openEmailModal === 'function') {
      (window as any).__openEmailModal({
        title: "Your HELOC Breakdown",
        fields: [
          { label: 'Interest-Only Payment', value: document.getElementById('interest-only-payment')?.textContent?.trim() || '$0', highlight: true },
          { label: 'Total Home Equity', value: document.getElementById('equity-amount')?.textContent?.trim() || '$0' },
          { label: 'Max Borrowing Limit', value: document.getElementById('borrowing-limit')?.textContent?.trim() || '$0' },
          { label: 'LTV Ratio', value: document.getElementById('ltv-ratio')?.textContent?.trim() || '$0' }
        ]
      });
    }
  });
</script>
