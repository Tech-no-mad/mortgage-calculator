---
import BaseLayout from '../layouts/BaseLayout.astro';
import statesData from '../data/states.json';
---

<BaseLayout
  title="HELOC Calculator"
  description="Calculate your Home Equity Line of Credit (HELOC) payments and estimate your borrowing power."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="color: var(--text-primary);">
        HELOC
        <span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">Calculator</span>
      </h1>
      <p class="text-base sm:text-lg max-w-xl mx-auto" style="color: var(--text-muted);">
        Estimate your borrowing power and monthly payments for a Home Equity Line of Credit.
      </p>
    </div>
  </section>

  <!-- Calculator -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="card p-6 sm:p-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10">

        <!-- INPUTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#06b6d4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
            Home Details
          </h2>

          <!-- State Selection -->
          <div>
            <label class="label block mb-1.5">State (Pre-fills Average Home Value)</label>
            <select id="state-selector" class="calc-input font-mono w-full mb-5">
              <option value="">National Average</option>
              {statesData.map(state => (
                <option value={state.abbr} data-price={state.medianPrice}>
                  {state.name}
                </option>
              ))}
            </select>
          </div>

          <!-- Home Value -->
          <div>
            <label class="label block mb-1.5">Estimated Home Value</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input type="text" id="home-value" value="450,000" inputmode="numeric" class="calc-input pl-7 font-mono" />
            </div>
          </div>

          <!-- Mortgage Balance -->
          <div>
            <label class="label block mb-1.5">Current Mortgage Balance</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input type="text" id="mortgage-balance" value="250,000" inputmode="numeric" class="calc-input pl-7 font-mono" />
            </div>
          </div>

          <h2 class="text-base font-semibold flex items-center gap-2 mt-8" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#f59e0b]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            HELOC Details
          </h2>

          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="label block mb-1.5">HELOC Amount</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
                <input type="text" id="heloc-amount" value="50,000" inputmode="numeric" class="calc-input pl-7 font-mono" />
              </div>
            </div>
            <div>
              <label class="label block mb-1.5">Interest Rate (%)</label>
              <input type="text" id="heloc-rate" value="8.5" inputmode="decimal" class="calc-input font-mono" />
            </div>
          </div>
        </div>

        <!-- RESULTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#10b981]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Draw Period Payments
          </h2>

          <div class="text-center py-8 rounded-xl" style="background: var(--bg-surface-2); border: 1px solid var(--border-default);">
            <p class="label-faint text-sm mb-2">Interest-Only Payment</p>
            <div class="text-4xl sm:text-5xl font-bold font-mono tracking-tight" id="interest-only-payment">
              <span class="text-[#06b6d4]">$0</span>
            </div>
            <p class="text-xs mt-3" style="color: var(--text-muted);">Typical for the first 10 years (Draw Period)</p>
          </div>

          <div>
            <div class="result-row">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[#10b981]"></span>
                <span class="label">Total Home Equity</span>
              </div>
              <span class="text-sm font-semibold font-mono text-[#10b981]" id="total-equity">$0</span>
            </div>
            <div class="result-row">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[#f59e0b]"></span>
                <span class="label">Max Borrowing Power (80% LTV)</span>
              </div>
              <span class="text-sm font-semibold font-mono text-[#f59e0b]" id="max-borrow">$0</span>
            </div>
          </div>
          
          <div class="mt-4 p-4 rounded-lg border" style="background: var(--bg-surface-2); border-color: var(--border-default);">
            <p class="text-sm font-medium" style="color: var(--text-primary);" id="heloc-warning">
              Calculating...
            </p>
          </div>

        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }
  function parse(s) { return parseFloat(String(s).replace(/[^0-9.-]/g, '')) || 0; }
  function fmtNum(n) { return Math.round(n).toLocaleString('en-US'); }

  function calcHeloc() {
    const homeValue = parse((document.getElementById('home-value') as HTMLInputElement).value);
    const mortgageBalance = parse((document.getElementById('mortgage-balance') as HTMLInputElement).value);
    const helocAmount = parse((document.getElementById('heloc-amount') as HTMLInputElement).value);
    const helocRate = parseFloat((document.getElementById('heloc-rate') as HTMLInputElement).value);

    if (document.activeElement?.id !== 'home-value') (document.getElementById('home-value') as HTMLInputElement).value = fmtNum(homeValue);
    if (document.activeElement?.id !== 'mortgage-balance') (document.getElementById('mortgage-balance') as HTMLInputElement).value = fmtNum(mortgageBalance);
    if (document.activeElement?.id !== 'heloc-amount') (document.getElementById('heloc-amount') as HTMLInputElement).value = fmtNum(helocAmount);

    const totalEquity = Math.max(0, homeValue - mortgageBalance);
    const maxBorrow = Math.max(0, (homeValue * 0.8) - mortgageBalance); // 80% LTV is standard

    const monthlyInterest = helocAmount * ((helocRate / 100) / 12);

    document.getElementById('interest-only-payment')!.innerHTML = `<span class="text-[#06b6d4]">${fmt(monthlyInterest)}</span>`;
    document.getElementById('total-equity')!.textContent = fmt(totalEquity);
    document.getElementById('max-borrow')!.textContent = fmt(maxBorrow);

    const warningEl = document.getElementById('heloc-warning')!;
    if (helocAmount > maxBorrow) {
      warningEl.innerHTML = `<span class="text-[#f43f5e]"><strong>Warning:</strong> The requested HELOC amount exceeds standard 80% Loan-to-Value limits. You may need to find a specialized lender.</span>`;
    } else {
      warningEl.innerHTML = `Your requested line of credit is within safe borrowing limits. During the draw period, you only pay interest on the amount you actually withdraw.`;
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('state-selector')?.addEventListener('change', (e) => {
      const select = e.target as HTMLSelectElement;
      const option = select.options[select.selectedIndex];
      if (option.value) {
        (document.getElementById('home-value') as HTMLInputElement).value = fmtNum(parseFloat(option.getAttribute('data-price') || '450000'));
      } else {
        (document.getElementById('home-value') as HTMLInputElement).value = "450,000";
      }
      calcHeloc();
    });

    ['home-value', 'mortgage-balance', 'heloc-amount', 'heloc-rate'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', calcHeloc);
      document.getElementById(id)?.addEventListener('change', calcHeloc);
    });
    calcHeloc();
  });
</script>
