---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLiveRates } from '../utils/rates';
const ratesData = await getLiveRates(Astro);
---

<BaseLayout title="Page Not Found" description="The page you are looking for does not exist.">
  <section class="min-h-[65vh] flex items-center justify-center px-4">
    <div class="card p-10 sm:p-16 text-center max-w-lg">
      <div class="text-8xl sm:text-9xl font-bold font-mono tracking-tighter mb-4">
        <span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">404</span>
      </div>
      <h1 class="text-2xl font-bold mb-3" style="color: var(--text-primary);">Page Not Found</h1>
      <p class="mb-8" style="color: var(--text-muted);">The page you're looking for doesn't exist or has been moved.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="px-6 py-3 rounded-lg bg-[#06b6d4] hover:bg-[#0891b2] text-white font-medium transition-colors">Go Home</a>
        <a href="/faq" class="px-6 py-3 rounded-lg border font-medium transition-colors" style="border-color: var(--border-default); color: var(--text-muted);">Browse Tools</a>
      </div>
    </div>
  </section>
</BaseLayout>
