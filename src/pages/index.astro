---
import BaseLayout from '../layouts/BaseLayout.astro';
import statesData from '../data/states.json';
import { getLiveRates } from '../utils/rates';
const ratesData = await getLiveRates(Astro);
import AdSlot from '../components/AdSlot.astro';
import InteractiveUSMap from '../components/InteractiveUSMap.astro';
import countiesData from '../data/counties.json';

const lastUpdatedDate = new Date(ratesData.lastUpdated).toLocaleDateString('en-US', { month: 'long', year: 'numeric', day: 'numeric' });
---

<BaseLayout
  keywords="mortgage calculator, home loan calculator, current mortgage rates, monthly mortgage payment, free mortgage calculator, mortgage payment calculator, house payment calculator, home mortgage calculator, calculate mortgage, mortgage estimator, monthly house payment, mortgage interest calculator, loan payment calculator, how much is my mortgage, mortgage calculator with taxes, mortgage calculator with PMI, mortgage calculator with insurance, PITI calculator, home buying calculator, home affordability calculator, mortgage amortization, what will my mortgage payment be, mortgage calculator 2025, best mortgage calculator, accurate mortgage calculator, simple mortgage calculator, mortgage calculator USA, home loan payment estimator, mortgage rate calculator, mortgage cost calculator"
  canonicalUrl="/"
  title="Free Mortgage Calculator"
  description="Calculate your monthly mortgage payment, see amortization schedules, and compare rates across all 50 US states. Free, fast, and accurate."
>
  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <div class="text-center mb-10">
      <div class="inline-block bg-[var(--color-usa-blue)]/10 text-[var(--color-usa-blue)] dark:text-blue-400 px-4 py-1.5 rounded-full text-sm font-semibold mb-6 shadow-sm border border-[var(--color-usa-blue)]/20">
        🏆 Only calculator that auto-fills live property tax and interest rates
      </div>
      <br/>
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium mb-6" style="background: rgba(10, 49, 97, 0.1); color: var(--color-usa-blue); border: 1px solid rgba(10, 49, 97, 0.2);">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-usa-red)] animate-pulse"></span>
        Updated {lastUpdatedDate} · Rates at {ratesData.MORTGAGE30US}%
      </div>
      <h1 id="calc-title" class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="color: var(--text-primary);">
        Mortgage Payment
        <span class="bg-gradient-to-r from-[var(--color-usa-blue)] to-[var(--color-usa-red)] bg-clip-text text-transparent">Calculator</span>
      </h1>
      <p class="text-base sm:text-lg max-w-xl mx-auto" style="color: var(--text-muted);">
        Uses real county tax data from all 50 states + official Federal Reserve rates — updated weekly.
      </p>
    </div>

    <!-- Ad Slot 1: Leaderboard above calculator -->
    <AdSlot type="leaderboard" />
  </section>

  <!-- Calculator -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="card p-6 sm:p-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10">

        <!-- INPUTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[var(--color-usa-blue)] dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Loan Details
          </h2>

          <!-- Home Price -->
          <div>
            <label class="label block mb-1.5">Home Price</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input aria-label="Home Price Input" type="text" id="home-price-input" value="350,000" inputmode="numeric" class="calc-input pl-7 font-mono" data-step="1" data-tooltip="Step 1: Enter Home Price" />
            </div>
            <input type="range" id="home-price" min="50000" max="2000000" step="5000" value="350000" />
            <div class="flex justify-between label-faint text-xs"><span>$50K</span><span>$2M</span></div>
          </div>

          <!-- Down Payment -->
          <div id="down-payment-wrapper">
            <label class="label block mb-1.5">Down Payment</label>
            <div class="flex gap-2">
              <div class="relative flex-1">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
                <input aria-label="Down Payment Dollar Input" type="text" id="down-payment-dollar-input" value="70,000" inputmode="numeric" class="calc-input pl-7 font-mono" data-step="2" data-tooltip="Step 2: Enter Down Payment" />
              </div>
              <div class="relative w-20">
                <input aria-label="Down Payment Input" type="text" id="down-payment-input" value="20" inputmode="decimal" class="calc-input text-center font-mono" />
                <span class="absolute right-3 top-1/2 -translate-y-1/2 label-faint">%</span>
              </div>
            </div>
            <input type="range" id="down-payment" min="0" max="50" step="0.1" value="20" />
            <div class="flex justify-between label-faint text-xs"><span>0%</span><span>50%</span></div>
          </div>

          <!-- Interest Rate -->
          <div>
            <label class="label block mb-1.5">Interest Rate</label>
            <div class="relative w-28">
              <input aria-label="Interest Rate Input" type="text" id="interest-rate-input" value={ratesData.MORTGAGE30US} inputmode="decimal" class="calc-input text-center font-mono" data-step="3" data-tooltip="Step 3: Enter Interest Rate" />
              <span class="absolute right-3 top-1/2 -translate-y-1/2 label-faint">%</span>
            </div>
            <input type="range" id="interest-rate" min="1" max="15" step="0.01" value={ratesData.MORTGAGE30US} />
            <div class="flex justify-between label-faint text-xs"><span>1%</span><span>15%</span></div>
          </div>

          <!-- Loan Term -->
          <div data-step="4" data-tooltip="Step 4: Select Loan Term">
            <label class="label block mb-1.5">Loan Term</label>
            <div class="grid grid-cols-4 gap-2">
              <button data-term="15" class="term-btn py-3 rounded-lg text-sm font-medium border transition-all" style="border-color: var(--border-default); color: var(--text-muted);">15 yr</button>
              <button data-term="20" class="term-btn py-3 rounded-lg text-sm font-medium border transition-all" style="border-color: var(--border-default); color: var(--text-muted);">20 yr</button>
              <button data-term="30" class="term-btn active py-3 rounded-lg text-sm font-medium border border-[var(--color-usa-blue)] text-[var(--color-usa-blue)] dark:text-blue-400 bg-[var(--color-usa-blue)]/10 transition-all">30 yr</button>
              <button data-term="50" class="term-btn py-3 rounded-lg text-sm font-medium border transition-all" style="border-color: var(--border-default); color: var(--text-muted);">50 yr</button>
            </div>
          </div>

          <!-- State Selection for Taxes -->
          <div>
            <label class="label block mb-1.5">State (For Accurate Taxes & Insurance)</label>
            <select aria-label="State Selector" id="state-selector" class="calc-input font-mono w-full" data-step="5" data-tooltip="Step 5: Select your state for local data">
              <option value="">National Average</option>
              {statesData.map(state => (
                <option value={state.abbr} data-tax={state.taxRate} data-ins={state.insurance}>
                  {state.name}
                </option>
              ))}
            </select>
          </div>

          <!-- Tax & Insurance -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="label block mb-1.5">Tax Rate (%/yr)</label>
              <input aria-label="Property Tax" type="text" id="property-tax" value="1.1" inputmode="decimal" class="calc-input font-mono" />
            </div>
            <div>
              <label class="label block mb-1.5">Insurance ($/yr)</label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
                <input aria-label="Home Insurance" type="text" id="home-insurance" value="1,200" inputmode="numeric" class="calc-input pl-7 font-mono" />
              </div>
            </div>
          </div>
        </div>

        <!-- RESULTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[var(--color-usa-red)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Monthly Payment
          </h2>

          <!-- Big number & Donut Chart -->
          <div class="card text-center py-6 flex flex-col items-center justify-center relative" style="border-radius: 1rem;">
            <div class="text-4xl sm:text-5xl font-bold font-mono tracking-tight mb-2" id="monthly-payment">
              <span class="bg-gradient-to-r from-[var(--color-usa-blue)] to-[var(--color-usa-red)] dark:from-blue-300 dark:to-red-400 bg-clip-text text-transparent" id="monthly-payment-amount">$1,837</span>
            </div>
            <p class="label-faint text-sm mb-6">per month</p>
            
            <div class="flex flex-col sm:flex-row gap-2 mb-6 w-full px-4 justify-center">
              <button type="button" id="email-cta" class="inline-flex items-center justify-center gap-1.5 px-4 py-2 bg-[var(--color-usa-blue)] text-white text-xs font-semibold rounded-lg hover:bg-opacity-90 transition shadow-sm cursor-pointer flex-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                Email Breakdown
              </button>
              <button type="button" id="share-cta" class="inline-flex items-center justify-center gap-1.5 px-4 py-2 bg-[var(--bg-surface-2)] border border-[var(--border-default)] text-[var(--text-primary)] text-xs font-semibold rounded-lg hover:bg-[var(--border-default)] transition shadow-sm cursor-pointer flex-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l-2.777 1.388M8.684 10.742l3.417-1.708m0 0a2.997 2.997 0 104.243-4.243A2.997 2.997 0 0012.1 9.034zm0 0l-3.417 1.708m3.417-1.708a2.997 2.997 0 011.83 2.545m-6.077 0l2.777-1.388m0 0a2.996 2.996 0 002.545-1.83m-6.077 3.218a3 3 0 11-4.243-4.242 3 3 0 014.243 4.242z" /></svg>
                <span id="share-cta-text">Share Results</span>
              </button>
            </div>

            <div class="relative w-40 h-40">
              <svg width="100%" height="100%" viewBox="0 0 42 42" class="transform -rotate-90">
                <!-- Background ring -->
                <circle cx="21" cy="21" r="15.915" fill="transparent" stroke="var(--bg-surface-3)" stroke-width="4"></circle>
                
                <!-- Segments (will be updated via JS) -->
                <circle id="donut-pi" cx="21" cy="21" r="15.915" fill="transparent" stroke="var(--donut-pi)" stroke-width="4" stroke-dasharray="0 100" stroke-dashoffset="0" class="donut-segment"></circle>
                <circle id="donut-tax" cx="21" cy="21" r="15.915" fill="transparent" stroke="var(--donut-tax)" stroke-width="4" stroke-dasharray="0 100" stroke-dashoffset="0" class="donut-segment"></circle>
                <circle id="donut-ins" cx="21" cy="21" r="15.915" fill="transparent" stroke="var(--donut-ins)" stroke-width="4" stroke-dasharray="0 100" stroke-dashoffset="0" class="donut-segment"></circle>
                <circle id="donut-pmi" cx="21" cy="21" r="15.915" fill="transparent" stroke="var(--donut-pmi)" stroke-width="4" stroke-dasharray="0 100" stroke-dashoffset="0" class="donut-segment"></circle>
              </svg>
            </div>
          </div>

          <!-- Breakdown -->
          <div>
            <div class="result-row">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-usa-blue)]"></span>
                <span class="label">Principal & Interest</span>
              </div>
              <span class="text-sm font-semibold font-mono text-[var(--color-usa-blue)] dark:text-blue-400 dark:text-blue-300" id="pi-amount">$1,572</span>
            </div>
            <div class="result-row">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[#f59e0b]"></span>
                <span class="label">Property Tax</span>
              </div>
              <span class="text-sm font-semibold font-mono text-[#f59e0b] dark:text-amber-300" id="tax-amount">$321</span>
            </div>
            <div class="result-row">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-usa-red)]"></span>
                <span class="label">Home Insurance</span>
              </div>
              <span class="text-sm font-semibold font-mono text-[var(--color-usa-red)] dark:text-red-400" id="insurance-amount">$100</span>
            </div>
            <div class="result-row" id="pmi-row" style="display:none;">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[#f43f5e]"></span>
                <span class="label">PMI</span>
              </div>
              <span class="text-sm font-semibold font-mono text-[#f43f5e] dark:text-rose-400" id="pmi-amount">$0</span>
            </div>
          </div>

          <!-- Totals -->
          <div class="grid grid-cols-2 gap-3">
            <div class="stat-card">
              <p class="label-faint text-xs mb-1">Total Interest</p>
              <p class="text-lg font-bold font-mono text-[#10b981] dark:text-emerald-400" id="total-interest">$285,862</p>
            </div>
            <div class="stat-card">
              <p class="label-faint text-xs mb-1">Total Cost</p>
              <p class="text-lg font-bold font-mono text-[#10b981] dark:text-emerald-400" id="total-cost">$661,562</p>
            </div>
          </div>
        </div>
      </div>
  </section>

  <!-- Ad Slot 2: Rectangle between results and tools -->
  <AdSlot type="rectangle" />

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-3xl font-bold text-center mb-8" style="color: var(--text-primary);">Explore Mortgage Rates by State</h2>
    <InteractiveUSMap states={statesData} counties={countiesData} />
  </section>

  <!-- (removed duplicate ad section — now handled by AdSlot components) -->

  <!-- Quick Links -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-xl font-bold text-center mb-8" style="color: var(--text-primary);">More Tools</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="tools-grid">
      {[
        { title: 'Affordability', desc: 'How much house can you afford?', href: '/how-much-can-i-afford', icon: '💰' },
        { title: 'Extra Payments', desc: 'Save thousands on interest', href: '/extra-payment-calculator', icon: '📊' },
        { title: 'Refinance', desc: 'Should you refinance?', href: '/refinance-calculator', icon: '🔄' },
        { title: 'Amortization', desc: 'View full payment schedule', href: '/amortization-schedule', icon: '📅' },
        { title: 'ARM Calculator', desc: 'Adjustable rate projections', href: '/arm-calculator', icon: '📈' },
        { title: 'Auto Loan', desc: 'Car payment calculator', href: '/auto-loan-calculator', icon: '🚗' },
        { title: 'Reverse Mortgage', desc: 'Convert equity to cash', href: '/reverse-mortgage-calculator', icon: '🏠', hidden: true },
        { title: 'Investment Property', desc: 'Calculate ROI & Cash Flow', href: '/investment-property-calculator', icon: '🏢', hidden: true },
        { title: 'Commercial Mortgage', desc: 'Business property loans', href: '/commercial-mortgage-calculator', icon: '🏬', hidden: true },
        { title: 'Loan Payment', desc: 'Generic loan calculator', href: '/loan-payment-calculator', icon: '💳', hidden: true },
        { title: '50 State Rates', desc: 'Tax rates for every state', href: '/states', icon: '🗺️', hidden: true },
        { title: 'Top 10 Brokers', desc: 'Compare the best lenders', href: '/brokers', icon: '🏛️', hidden: true },
      ].map((tool) => (
        <a href={tool.href} class={`card p-5 group hover:border-[var(--color-usa-blue)] transition-all ${tool.hidden ? 'hidden extra-tool' : ''}`}>
          <span class="text-2xl mb-3 block">{tool.icon}</span>
          <h3 class="font-semibold mb-1 group-hover:text-[var(--color-usa-blue)] dark:text-blue-400 transition-colors" style="color: var(--text-primary);">{tool.title}</h3>
          <p class="text-sm" style="color: var(--text-muted);">{tool.desc}</p>
        </a>
      ))}
    </div>
    <div class="text-center mt-8">
      <button id="show-all-tools" class="px-6 py-2 border border-[var(--border-default)] rounded-lg text-sm font-semibold hover:bg-[var(--bg-hover)] transition-colors">
        See all 12 tools ↓
      </button>
    </div>
  </section>

  <!-- Ad Slot 3: Rectangle-lg between tools and SEO content -->
  <AdSlot type="rectangle-lg" />

  <script>
    document.getElementById('show-all-tools')?.addEventListener('click', (e) => {
      document.querySelectorAll('.extra-tool').forEach(el => el.classList.remove('hidden'));
      (e.target as HTMLElement).style.display = 'none';
    });
  </script>

  <!-- SEO Content -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="space-y-6">
      <h2 class="text-xl font-bold" style="color: var(--text-primary);">Why Use a State-Specific Mortgage Calculator?</h2>
      <ul class="list-disc pl-5 space-y-2" style="color: var(--text-secondary);">
        <li><strong>Accurate Local Taxes:</strong> Property taxes vary wildly by state (0.27% in Hawaii vs 2.2% in New Jersey). We auto-fill the real county tax rates so your payment isn't artificially low.</li>
        <li><strong>Live Interest Rates:</strong> We pull official Federal Reserve data weekly, giving you an exact baseline for today's market conditions.</li>
        <li><strong>True Affordability:</strong> By factoring in localized taxes and insurance upfront, you avoid surprises when applying for pre-approval.</li>
      </ul>
      
      <h3 class="text-lg font-semibold mt-4" style="color: var(--text-primary);">Understanding Your PITI Payment</h3>
      <p style="color: var(--text-secondary);">Your monthly payment includes <strong>Principal</strong> (paying down the loan), <strong>Interest</strong> (cost of borrowing), <strong>Taxes</strong> (local property taxes), and <strong>Insurance</strong> (homeowner's protection). If your down payment is below 20%, you'll also pay PMI — typically 0.3% to 1.5% of the loan annually.</p>

      <h3 class="text-lg font-semibold mt-4" style="color: var(--text-primary);">Current Mortgage Rates</h3>
      <p style="color: var(--text-secondary);">As of {lastUpdatedDate}, the 30-year fixed rate averages {ratesData.MORTGAGE30US}% and the 15-year fixed averages {ratesData.MORTGAGE15US}%. Rates depend on your credit score, down payment, loan type (conventional, FHA, VA), and state.</p>

      <h3 class="text-lg font-semibold mt-4" style="color: var(--text-primary);">15-Year vs 30-Year</h3>
      <p style="color: var(--text-secondary);">On a $280K loan: a 30-year at {ratesData.MORTGAGE30US}% costs more in total interest but keeps monthly payments lower. A 15-year at {ratesData.MORTGAGE15US}% raises your monthly bill but saves you tens of thousands in interest over the life of the loan.</p>

      <h3 class="text-lg font-semibold mt-4" style="color: var(--text-primary);">Checklist: Get the Best Rate</h3>
      <ul class="space-y-3" style="color: var(--text-secondary);">
        <li class="flex items-start gap-2">
          <span class="text-[var(--color-usa-blue)] dark:text-blue-400 font-bold">✓</span>
          <span><strong>Boost Your Credit Score:</strong> A score above 740 gets you the top tier. (Saves ~$25,000+)</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[var(--color-usa-blue)] dark:text-blue-400 font-bold">✓</span>
          <span><strong>Save 20% Down:</strong> Avoid PMI entirely. (Saves ~$150/mo)</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[var(--color-usa-blue)] dark:text-blue-400 font-bold">✓</span>
          <span><strong>Compare 3-5 Lenders:</strong> Don't just accept the first offer. (Saves ~$1,500/yr)</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[var(--color-usa-blue)] dark:text-blue-400 font-bold">✓</span>
          <span><strong>Consider Points:</strong> Pay upfront to permanently lower your rate if you plan to stay long-term.</span>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>

<script>
  import { animateValue } from '../scripts/utils.ts';

  function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }
  function parse(s) { return parseFloat(String(s).replace(/[^0-9.-]/g, '')) || 0; }
  function fmtNum(n) { return Math.round(n).toLocaleString('en-US'); }

  function updateDonut(pi, tax, ins, pmi, total) {
    if (total <= 0) return;
    const piPct = (pi / total) * 100;
    const taxPct = (tax / total) * 100;
    const insPct = (ins / total) * 100;
    const pmiPct = (pmi / total) * 100;

    const c = 100; // circumference
    let offset = 0;

    const piEl = document.getElementById('donut-pi');
    if (piEl) {
      piEl.style.strokeDasharray = `${piPct} ${c}`;
      piEl.style.strokeDashoffset = offset;
      offset -= piPct;
    }

    const taxEl = document.getElementById('donut-tax');
    if (taxEl) {
      taxEl.style.strokeDasharray = `${taxPct} ${c}`;
      taxEl.style.strokeDashoffset = offset;
      offset -= taxPct;
    }

    const insEl = document.getElementById('donut-ins');
    if (insEl) {
      insEl.style.strokeDasharray = `${insPct} ${c}`;
      insEl.style.strokeDashoffset = offset;
      offset -= insPct;
    }

    const pmiEl = document.getElementById('donut-pmi');
    if (pmiEl) {
      pmiEl.style.strokeDasharray = `${pmiPct} ${c}`;
      pmiEl.style.strokeDashoffset = offset;
    }
  }

  // To track last values for smooth animation
  const lastVals = {
    total: 0, pi: 0, mTax: 0, mIns: 0, pmi: 0, totalInterest: 0, totalCost: 0
  };

  function calc() {
    const hp = parseFloat((document.getElementById('home-price') as HTMLInputElement).value);
    const dp = parseFloat((document.getElementById('down-payment') as HTMLInputElement).value);
    const r = parseFloat((document.getElementById('interest-rate') as HTMLInputElement).value);
    const tax = parse((document.getElementById('property-tax') as HTMLInputElement).value);
    const ins = parse((document.getElementById('home-insurance') as HTMLInputElement).value);
    const t = parseInt(document.querySelector('.term-btn.active')?.getAttribute('data-term') || '30');

    const down = hp * (dp / 100);
    const loan = hp - down;
    const mr = (r / 100) / 12;
    const n = t * 12;

    let pi = mr === 0 ? loan / n : loan * (mr * Math.pow(1 + mr, n)) / (Math.pow(1 + mr, n) - 1);
    const mTax = (hp * (tax / 100)) / 12;
    const mIns = ins / 12;
    let pmi = dp < 20 ? (loan * 0.007) / 12 : 0;
    const total = pi + mTax + mIns + pmi;
    const totalInterest = (pi * n) - loan;
    const totalCost = total * n;

    (document.getElementById('home-price-input') as HTMLInputElement).value = fmtNum(hp);
    (document.getElementById('down-payment-input') as HTMLInputElement).value = dp.toString();
    (document.getElementById('down-payment-dollar-input') as HTMLInputElement).value = fmtNum(down);
    (document.getElementById('interest-rate-input') as HTMLInputElement).value = r.toFixed(2);
    
    // Animate Values
    animateValue(document.getElementById('monthly-payment'), lastVals.total, total, 400);
    animateValue(document.getElementById('pi-amount'), lastVals.pi, pi, 400);
    animateValue(document.getElementById('tax-amount'), lastVals.mTax, mTax, 400);
    animateValue(document.getElementById('insurance-amount'), lastVals.mIns, mIns, 400);
    animateValue(document.getElementById('pmi-amount'), lastVals.pmi, pmi, 400);
    animateValue(document.getElementById('total-interest'), lastVals.totalInterest, totalInterest, 400);
    animateValue(document.getElementById('total-cost'), lastVals.totalCost, totalCost, 400);

    // Update Donut
    updateDonut(pi, mTax, mIns, pmi, total);

    // Save for next calc
    lastVals.total = total;
    lastVals.pi = pi;
    lastVals.mTax = mTax;
    lastVals.mIns = mIns;
    lastVals.pmi = pmi;
    lastVals.totalInterest = totalInterest;
    lastVals.totalCost = totalCost;

    const pmiRow = document.getElementById('pmi-row');
    if (pmiRow) pmiRow.style.display = pmi > 0 ? 'flex' : 'none';

    // Update mobile sticky payment bar
    const stickyAmount = document.getElementById('sticky-payment-amount');
    if (stickyAmount) stickyAmount.textContent = fmt(total);

    // Update email modal summary fields
    const setModal = (id: string, val: string) => { const el = document.getElementById(id); if (el) el.textContent = val; };
    setModal('modal-monthly', fmt(total));
    setModal('modal-pi', fmt(pi));
    setModal('modal-tax', fmt(mTax));
    setModal('modal-ins', fmt(mIns));
    setModal('modal-total-interest', fmt(totalInterest));
    setModal('modal-total-cost', fmt(totalCost));
  }

  document.addEventListener('DOMContentLoaded', async () => {
    const $ = (id) => document.getElementById(id);
    
    // Parse URL params for specific loan types or shared configurations
    const params = new URLSearchParams(window.location.search);
    const type = params.get('type');
    const sharePrice = params.get('price');
    const shareDown = params.get('down');
    const shareRate = params.get('rate');
    const shareState = params.get('state');
    
    if (sharePrice) {
      $('home-price').value = sharePrice;
      $('home-price-input').value = parseInt(sharePrice).toLocaleString();
    }
    if (shareDown) {
      $('down-payment').value = shareDown;
      $('down-payment-input').value = shareDown;
      const hp = parseFloat(sharePrice || $('home-price').value);
      if ($('down-payment-dollar-input')) {
        $('down-payment-dollar-input').value = Math.round(hp * (parseFloat(shareDown) / 100)).toLocaleString();
      }
    }
    if (shareRate) {
      $('interest-rate').value = shareRate;
      $('interest-rate-input').value = shareRate;
    }
    if (shareState) {
      $('state-selector').value = shareState;
      const option = $('state-selector').querySelector(`option[value="${shareState}"]`);
      if (option) {
        $('property-tax').value = option.getAttribute('data-tax') || '1.1';
        $('home-insurance').value = option.getAttribute('data-ins') || '1200';
      }
    }

    if (type === 'fha') {
      $('calc-title').innerHTML = `FHA Mortgage <span class="bg-gradient-to-r from-[var(--color-usa-blue)] to-[var(--color-usa-red)] bg-clip-text text-transparent">Calculator</span>`;
      $('down-payment').value = "3.5";
      $('down-payment-input').value = "3.5";
      document.title = "FHA Mortgage Calculator | MortgageDash";
      $('down-payment-dollar-input')?.removeAttribute('data-step'); // Fixed value, skip onboarding step
    } else if (type === 'va') {
      $('calc-title').innerHTML = `VA Mortgage <span class="bg-gradient-to-r from-[var(--color-usa-blue)] to-[var(--color-usa-red)] bg-clip-text text-transparent">Calculator</span>`;
      $('down-payment').value = "0";
      $('down-payment-input').value = "0";
      document.title = "VA Mortgage Calculator | MortgageDash";
      $('down-payment-dollar-input')?.removeAttribute('data-step'); // Fixed value, skip onboarding step
    } else if (type === 'jumbo') {
      $('calc-title').innerHTML = `Jumbo Mortgage <span class="bg-gradient-to-r from-[var(--color-usa-blue)] to-[var(--color-usa-red)] bg-clip-text text-transparent">Calculator</span>`;
      if (!sharePrice) {
        $('home-price').value = "850000";
        $('home-price-input').value = "850,000";
      }
      document.title = "Jumbo Mortgage Calculator | MortgageDash";
    }

    $('state-selector')?.addEventListener('change', (e) => {
      const select = e.target as HTMLSelectElement;
      const option = select.options[select.selectedIndex];
      if (option.value) {
        ($('property-tax') as HTMLInputElement).value = option.getAttribute('data-tax') || '1.1';
        ($('home-insurance') as HTMLInputElement).value = option.getAttribute('data-ins') || '1200';
      } else {
        ($('property-tax') as HTMLInputElement).value = '1.1';
        ($('home-insurance') as HTMLInputElement).value = '1200';
      }
      calc();
    });

    ['home-price', 'down-payment', 'interest-rate'].forEach(id => $(id)?.addEventListener('input', calc));

    $('home-price-input')?.addEventListener('change', e => { $('home-price').value = Math.min(2000000, Math.max(50000, parse(e.target.value))); calc(); });
    $('down-payment-input')?.addEventListener('change', e => { $('down-payment').value = Math.min(50, Math.max(0, parseFloat(e.target.value) || 0)); calc(); });
    $('down-payment-dollar-input')?.addEventListener('change', e => { const hp = parseFloat($('home-price').value); $('down-payment').value = Math.round(Math.min(50, Math.max(0, (parse(e.target.value) / hp) * 100))); calc(); });
    $('interest-rate-input')?.addEventListener('change', e => { $('interest-rate').value = Math.min(15, Math.max(1, parseFloat(e.target.value) || 0)); calc(); });

    ['property-tax', 'home-insurance'].forEach(id => $(id)?.addEventListener('change', calc));

    document.querySelectorAll('.term-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.term-btn').forEach(b => {
          b.classList.remove('active', 'border-[var(--color-usa-blue)]', 'text-[var(--color-usa-blue)] dark:text-blue-400', 'bg-[var(--color-usa-blue)]/10');
          b.style.borderColor = 'var(--border-default)';
          b.style.color = 'var(--text-muted)';
          b.style.background = 'transparent';
        });
        btn.classList.add('active');
        btn.style.borderColor = 'var(--color-usa-blue)';
        btn.style.color = 'var(--color-usa-blue)';
        btn.style.background = 'rgba(10, 49, 97, 0.1)';
        calc();
      });
    });

    calc();

    // Email CTA opens modal
    document.getElementById('email-cta')?.addEventListener('click', () => {
      if (typeof (window as any).__openEmailModal === 'function') {
        (window as any).__openEmailModal({
          title: "Your Mortgage Breakdown",
          fields: [
            { label: "Monthly Payment", value: document.getElementById('monthly-payment')?.textContent?.trim() || '$0', highlight: true },
            { label: "Principal & Interest", value: document.getElementById('pi-amount')?.textContent?.trim() || '$0' },
            { label: "Property Tax", value: document.getElementById('tax-amount')?.textContent?.trim() || '$0' },
            { label: "Home Insurance", value: document.getElementById('insurance-amount')?.textContent?.trim() || '$0' },
            { label: "Total Interest", value: document.getElementById('total-interest')?.textContent?.trim() || '$0' },
            { label: "Total Cost", value: document.getElementById('total-cost')?.textContent?.trim() || '$0' }
          ]
        });
      }
    });

    // Share CTA copies custom URL to clipboard
    document.getElementById('share-cta')?.addEventListener('click', () => {
      const btn = document.getElementById('share-cta');
      const txt = document.getElementById('share-cta-text');
      
      const price = $('home-price').value;
      const down = $('down-payment').value;
      const rate = $('interest-rate-input').value;
      const state = $('state-selector').value;

      const url = new URL(window.location.origin + window.location.pathname);
      url.searchParams.set('price', price);
      url.searchParams.set('down', down);
      url.searchParams.set('rate', rate);
      if (state) url.searchParams.set('state', state);

      navigator.clipboard.writeText(url.toString()).then(() => {
        if (txt && btn) {
          txt.textContent = 'Copied! ✓';
          btn.classList.add('bg-emerald-500', 'text-white', 'border-emerald-600');
          btn.classList.remove('bg-[var(--bg-surface-2)]', 'text-[var(--text-primary)]');
          setTimeout(() => {
            txt.textContent = 'Share Results';
            btn.classList.remove('bg-emerald-500', 'text-white', 'border-emerald-600');
            btn.classList.add('bg-[var(--bg-surface-2)]', 'text-[var(--text-primary)]');
          }, 2000);
        }
      });
    });

    // Mobile sticky payment bar - show when scrolled past results
    const resultsSection = document.getElementById('monthly-payment');
    const stickyBar = document.getElementById('mobile-sticky-payment');
    if (resultsSection && stickyBar) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            stickyBar.classList.add('translate-y-full');
            stickyBar.classList.remove('translate-y-0');
          } else {
            stickyBar.classList.remove('translate-y-full');
            stickyBar.classList.add('translate-y-0');
          }
        });
      }, { threshold: 0.1 });
      observer.observe(resultsSection);
    }

    const { OnboardingTour } = await import('../scripts/onboarding.ts');
    new OnboardingTour().init();
  });
</script>
