---
import BaseLayout from '../layouts/BaseLayout.astro';
import ratesData from '../data/rates.json';
import AdSlot from '../components/AdSlot.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Refinance Calculator",
      "description": "Calculate if it makes sense to refinance your mortgage. Find your break-even point and total savings.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
    {
        "@type": "Question",
        "name": "What is a break-even point in refinancing?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "The break-even point is the time it takes for your monthly savings from a lower interest rate to equal the closing costs you paid to refinance. For example, if you save $100 a month and paid $3,000 in closing costs, your break-even point is 30 months."
        }
    },
    {
        "@type": "Question",
        "name": "How do closing costs affect my refinance savings?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "Closing costs typically range from 2% to 5% of the loan amount. If these upfront costs are too high, it may take many years to actually 'save' money, which is why refinancing usually only makes sense if you plan to stay in the home past the break-even point."
        }
    },
    {
        "@type": "Question",
        "name": "Should I refinance for a lower rate or a shorter term?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "It depends on your financial goals. Refinancing to a lower rate reduces your monthly payment. Refinancing to a shorter term (like from 30 to 15 years) usually increases your monthly payment but saves you tens of thousands of dollars in long-term interest."
        }
    },
    {
        "@type": "Question",
        "name": "Can I roll closing costs into the new loan?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, many lenders allow a 'no closing cost' refinance, where the costs are either rolled into your principal balance or offset by accepting a slightly higher interest rate. This prevents you from needing cash out of pocket."
        }
    }
]
    }
  ]
};
---

<BaseLayout
  keywords="refinance calculator, break even point calculator, mortgage refinance savings, refinance closing costs, should i refinance"
  canonicalUrl="/refinance-calculator/"
  title="Refinance Calculator"
  description="Calculate if it makes sense to refinance your mortgage. Find your break-even point and total savings."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="color: var(--text-primary);">
        Mortgage Refinance
        <span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] dark:from-cyan-300 dark:to-emerald-400 bg-clip-text text-transparent">Calculator</span>
      </h1>
      <p class="text-base sm:text-lg max-w-xl mx-auto" style="color: var(--text-muted);">
        See if refinancing makes sense for you by calculating your break-even point and lifetime savings.
      </p>
    </div>
  </section>

  <!-- Ad Slot: Leaderboard -->
  <AdSlot type="leaderboard" />


  <!-- Ad Slot -->
  <div class="ad-slot max-w-4xl mx-auto my-6">Advertisement Space Reserved</div>


  <!-- Calculator -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="card p-6 sm:p-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10">

        <!-- INPUTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#06b6d4] dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Current Loan
          </h2>

          <!-- Remaining Balance -->
          <div>
            <label class="label block mb-1.5">Remaining Balance</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input aria-label="Current Balance" type="text" id="current-balance" value="250,000" inputmode="numeric" class="calc-input pl-7 font-mono" data-step="1" data-tooltip="Step 1: Current Loan Balance" />
            </div>
          </div>

          <!-- Current Rate -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="label block mb-1.5">Current Rate (%)</label>
              <input aria-label="Current Rate" type="text" id="current-rate" value="7.5" inputmode="decimal" class="calc-input font-mono" data-step="2" data-tooltip="Step 2: Current Interest Rate" />
            </div>
            <div>
              <label class="label block mb-1.5">Years Left</label>
              <input aria-label="Current Years Left" type="text" id="current-years-left" value="25" inputmode="numeric" class="calc-input font-mono" data-step="3" data-tooltip="Step 3: Years Remaining" />
            </div>
          </div>

          <h2 class="text-base font-semibold flex items-center gap-2 mt-8" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#f59e0b] dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            New Loan Options
          </h2>

          <!-- New Rate & Term -->
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="label block mb-1.5">New Rate (%)</label>
              <input aria-label="New Rate" type="text" id="new-rate" value="6.0" inputmode="decimal" class="calc-input font-mono" data-step="4" data-tooltip="Step 4: Target New Rate" />
            </div>
            <div>
              <label class="label block mb-1.5">New Term</label>
              <select aria-label="New Term" id="new-term" class="calc-input font-mono w-full" data-step="5" data-tooltip="Step 5: Select New Loan Term">
                <option value="30">30 Years</option>
                <option value="15">15 Years</option>
              </select>
            </div>
          </div>

          <!-- Closing Costs -->
          <div>
            <label class="label block mb-1.5">Closing Costs (Est. $)</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input aria-label="Closing Costs" type="text" id="closing-costs" value="5,000" inputmode="numeric" class="calc-input pl-7 font-mono" data-step="6" data-tooltip="Step 6: Estimated Closing Costs" />
            </div>
          </div>
        </div>

        <!-- RESULTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#10b981] dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Refinance Breakdown
          </h2>

          <div class="text-center py-8 rounded-xl" style="background: var(--bg-surface-2); border: 1px solid var(--border-default);">
            <p class="label-faint text-sm mb-2">Monthly Savings</p>
            <div class="text-4xl sm:text-5xl font-bold font-mono tracking-tight" id="monthly-savings">
              <span class="text-[#10b981] dark:text-emerald-400">$0</span>
            </div>
          </div>

          <div>
            <div class="result-row">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[#f59e0b] dark:bg-amber-400"></span>
                <span class="label">Break-Even Point</span>
              </div>
              <span class="text-sm font-semibold font-mono text-[#f59e0b] dark:text-amber-400" id="break-even">0 months</span>
            </div>
            <div class="result-row">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full bg-[#06b6d4] dark:bg-cyan-400"></span>
                <span class="label">Total Lifetime Savings</span>
              </div>
              <span class="text-sm font-semibold font-mono text-[#06b6d4] dark:text-cyan-400" id="lifetime-savings">$0</span>
            </div>
          </div>

          <div class="mt-4 p-4 rounded-lg border" style="background: var(--bg-surface-2); border-color: var(--border-default);">
            <p class="text-sm font-medium" style="color: var(--text-primary);" id="refi-recommendation">
              Calculating...
            </p>
          </div>

        </div>
      </div>
    </div>
  
  <!-- Ad Slot -->
  <div class="ad-slot max-w-4xl mx-auto my-6">Advertisement Space Reserved</div>
</section>

  <!-- Ad Slot: Rectangle -->
  <AdSlot type="rectangle" />


  <!-- Related Links -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="card p-8">
      <h3 class="text-xl font-bold mb-6" style="color: var(--text-primary);">Related Tools & States</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div>
          <h4 class="font-semibold mb-4 text-[#06b6d4]">More Calculators</h4>
          <ul class="space-y-3">
            <li><a href="/amortization-schedule/" class="text-sm hover:text-[#10b981] transition-colors" style="color: var(--text-secondary);">→ Amortization Schedule</a></li>
            <li><a href="/extra-payment-calculator/" class="text-sm hover:text-[#10b981] transition-colors" style="color: var(--text-secondary);">→ Extra Payment Calculator</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-4 text-[#10b981]">State Spotlights</h4>
          <ul class="space-y-3">
            <li><a href="/states/california/" class="text-sm hover:text-[#06b6d4] transition-colors" style="color: var(--text-secondary);">→ California Mortgage Calculator</a></li>
            <li><a href="/states/florida/" class="text-sm hover:text-[#06b6d4] transition-colors" style="color: var(--text-secondary);">→ Florida Mortgage Calculator</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }
  function parse(s) { return parseFloat(String(s).replace(/[^0-9.-]/g, '')) || 0; }
  function fmtNum(n) { return Math.round(n).toLocaleString('en-US'); }

  function calcRefinance() {
    const balance = parse((document.getElementById('current-balance') as HTMLInputElement).value);
    const currRate = parseFloat((document.getElementById('current-rate') as HTMLInputElement).value);
    const currYearsLeft = parseFloat((document.getElementById('current-years-left') as HTMLInputElement).value);
    const newRate = parseFloat((document.getElementById('new-rate') as HTMLInputElement).value);
    const newTerm = parseInt((document.getElementById('new-term') as HTMLSelectElement).value);
    const costs = parse((document.getElementById('closing-costs') as HTMLInputElement).value);

    // Format
    if (document.activeElement?.id !== 'current-balance') (document.getElementById('current-balance') as HTMLInputElement).value = fmtNum(balance);
    if (document.activeElement?.id !== 'closing-costs') (document.getElementById('closing-costs') as HTMLInputElement).value = fmtNum(costs);

    // Current loan calculation
    const currMr = (currRate / 100) / 12;
    const currN = currYearsLeft * 12;
    const currPayment = currMr > 0 ? balance * (currMr * Math.pow(1 + currMr, currN)) / (Math.pow(1 + currMr, currN) - 1) : balance / currN;
    const currTotalCost = currPayment * currN;

    // New loan calculation
    const newMr = (newRate / 100) / 12;
    const newN = newTerm * 12;
    // Add closing costs to loan balance to see true cost if rolled in (or just add them at the end)
    const newPayment = newMr > 0 ? balance * (newMr * Math.pow(1 + newMr, newN)) / (Math.pow(1 + newMr, newN) - 1) : balance / newN;
    const newTotalCost = (newPayment * newN) + costs;

    const monthlySavings = currPayment - newPayment;
    const lifetimeSavings = currTotalCost - newTotalCost;
    
    let breakEvenMonths = 0;
    if (monthlySavings > 0) {
      breakEvenMonths = Math.ceil(costs / monthlySavings);
    }

    const savingsEl = document.getElementById('monthly-savings')!;
    if (monthlySavings > 0) {
      savingsEl.innerHTML = `<span class="text-[#10b981] dark:text-emerald-400">${fmt(monthlySavings)}</span>`;
    } else if (monthlySavings < 0) {
      savingsEl.innerHTML = `<span class="text-[#f43f5e] dark:text-rose-400">${fmt(monthlySavings)}</span>`;
    } else {
      savingsEl.innerHTML = `<span class="text-[#f59e0b] dark:text-amber-300">${fmt(monthlySavings)}</span>`;
    }

    const lifetimeEl = document.getElementById('lifetime-savings')!;
    if (lifetimeSavings > 0) {
      lifetimeEl.innerHTML = `<span class="text-[#10b981] dark:text-emerald-400">${fmt(lifetimeSavings)}</span>`;
    } else if (lifetimeSavings < 0) {
      lifetimeEl.innerHTML = `<span class="text-[#f43f5e] dark:text-rose-400">${fmt(lifetimeSavings)}</span>`;
    } else {
      lifetimeEl.innerHTML = `<span class="text-[#f59e0b] dark:text-amber-300">${fmt(lifetimeSavings)}</span>`;
    }

    document.getElementById('break-even')!.textContent = monthlySavings > 0 ? `${breakEvenMonths} months` : 'Never';

    const recEl = document.getElementById('refi-recommendation')!;
    if (lifetimeSavings > 0 && monthlySavings > 0) {
      recEl.innerHTML = `<strong>Good idea!</strong> You will save money every month, and you will recoup your closing costs in about <strong>${Math.round(breakEvenMonths / 12 * 10) / 10} years</strong>.`;
    } else if (monthlySavings < 0) {
      recEl.innerHTML = `<strong>Not recommended.</strong> Your monthly payment will actually go up by ${fmt(Math.abs(monthlySavings))}.`;
    } else {
      recEl.innerHTML = `<strong>Think twice.</strong> While your monthly payment might go down, you will actually lose money over the life of the loan due to resetting the clock on your mortgage.`;
    }
  }

  document.addEventListener('DOMContentLoaded', async () => {
    ['current-balance', 'current-rate', 'current-years-left', 'new-rate', 'new-term', 'closing-costs'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', calcRefinance);
      document.getElementById(id)?.addEventListener('change', calcRefinance);
    });
    calcRefinance();

    const { OnboardingTour } = await import('../scripts/onboarding.ts');
    new OnboardingTour().init();
  });
</script>
