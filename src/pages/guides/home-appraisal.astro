const description = "A home appraisal is an unbiased professional opinion of a home's fair market value. If you are using a mortgage to buy a home or refinance your curren...";
const keywords = "home appraisal, how appraisal works, appraisal cost, low appraisal, appraisal vs inspection, what is a home appraisal, who pays for appraisal, appraisal gap, challenge home appraisal";
const canonicalUrl = "/guides/home-appraisal/";

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Organization",
    "name": "MortgageDash Team"
  },
  "datePublished": "2025-07-04"
