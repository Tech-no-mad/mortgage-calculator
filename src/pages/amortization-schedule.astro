---
import BaseLayout from '../layouts/BaseLayout.astro';
import ratesData from '../data/rates.json';
import AdSlot from '../components/AdSlot.astro';
---

<BaseLayout
  canonicalUrl="https://mortgagedash.app/amortization-schedule/"
  title="Amortization Schedule Calculator"
  description="Generate a complete amortization schedule. See exactly how much of your monthly mortgage payment goes to principal versus interest."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="color: var(--text-primary);">
        Amortization
        <span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">Schedule</span>
      </h1>
      <p class="text-base sm:text-lg max-w-xl mx-auto" style="color: var(--text-muted);">
        See month-by-month how your mortgage payment breaks down into principal and interest over the life of your loan.
      </p>
    </div>
  </section>

  <!-- Ad Slot: Leaderboard -->
  <AdSlot type="leaderboard" />


  <!-- Ad Slot -->
  <div class="ad-slot max-w-4xl mx-auto my-6">Advertisement Space Reserved</div>


  <!-- Calculator -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="card p-6 sm:p-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Loan Amount -->
        <div>
          <label class="label block mb-1.5">Loan Amount</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
            <input aria-label="Loan Amount" type="text" id="loan-amount" value="300,000" inputmode="numeric" class="calc-input pl-7 font-mono" data-step="1" data-tooltip="Step 1: Enter Loan Amount" />
          </div>
        </div>

        <!-- Interest Rate -->
        <div>
          <label class="label block mb-1.5">Interest Rate (%)</label>
          <input aria-label="Interest Rate" type="text" id="interest-rate" value="6.52" inputmode="decimal" class="calc-input font-mono" data-step="2" data-tooltip="Step 2: Enter Interest Rate" />
        </div>

        <!-- Loan Term -->
        <div>
          <label class="label block mb-1.5">Loan Term</label>
          <select aria-label="Loan Term" id="loan-term" class="calc-input font-mono w-full" data-step="3" data-tooltip="Step 3: Select Loan Term">
            <option value="30">30 Years</option>
            <option value="20">20 Years</option>
            <option value="15">15 Years</option>
            <option value="10">10 Years</option>
          </select>
        </div>

      </div>
      
      <div class="mt-8 pt-6 flex flex-col sm:flex-row gap-6 justify-between items-center" style="border-top: 1px solid var(--border-default);">
        <div class="flex gap-8">
           <div>
             <p class="label-faint text-xs mb-1">Monthly (P&I) Payment</p>
             <p class="text-2xl font-bold font-mono text-[#06b6d4] dark:text-cyan-300" id="monthly-pi">$0</p>
           </div>
           <div>
             <p class="label-faint text-xs mb-1">Total Interest Paid</p>
             <p class="text-2xl font-bold font-mono text-[#f59e0b] dark:text-amber-300" id="total-interest">$0</p>
           </div>
        </div>
        
        <!-- View Toggle -->
        <div class="flex items-center bg-slate-100 dark:bg-slate-800 p-1 rounded-lg border" style="border-color: var(--border-default);">
          <button id="view-monthly" class="px-4 py-1.5 text-sm font-semibold rounded-md bg-white dark:bg-slate-700 shadow-sm transition-all" style="color: var(--text-primary);">Monthly</button>
          <button id="view-yearly" class="px-4 py-1.5 text-sm font-medium rounded-md text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-all">Yearly</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Schedule Table -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <div class="card overflow-hidden">
      <!-- Table Header -->
      <div class="px-6 py-4" style="background: var(--bg-surface-2); border-bottom: 1px solid var(--border-default);">
        <h2 class="text-lg font-bold" style="color: var(--text-primary);">Payment Schedule</h2>
      </div>
      
      <!-- Table Container (Scrollable) -->
      <div class="overflow-x-auto max-h-[600px] overflow-y-auto">
        <table class="w-full text-sm text-left">
          <thead class="text-xs uppercase sticky top-0 z-10" style="background: var(--bg-surface-3); color: var(--text-muted); box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
            <tr>
              <th scope="col" class="px-6 py-3 font-semibold" id="col-payment">Payment #</th>
              <th scope="col" class="px-6 py-3 font-semibold text-right">Principal Paid</th>
              <th scope="col" class="px-6 py-3 font-semibold text-right">Interest Paid</th>
              <th scope="col" class="px-6 py-3 font-semibold text-right">Total Interest</th>
              <th scope="col" class="px-6 py-3 font-semibold text-right">Remaining Balance</th>
            </tr>
          </thead>
          <tbody id="schedule-body" class="divide-y font-mono" style="divide-color: var(--border-default); color: var(--text-secondary);">
            <!-- Rows generated by JS -->
          </tbody>
        </table>
      </div>
      
    </div>
  
  <!-- Ad Slot -->
  <div class="ad-slot max-w-4xl mx-auto my-6">Advertisement Space Reserved</div>
</section>

  <!-- Ad Slot: Rectangle -->
  <AdSlot type="rectangle" />

</BaseLayout>

<script>
  function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }
  function parse(s) { return parseFloat(String(s).replace(/[^0-9.-]/g, '')) || 0; }
  function fmtNum(n) { return Math.round(n).toLocaleString('en-US'); }

  let currentView: 'monthly' | 'yearly' = 'monthly';

  function generateSchedule() {
    const loan = parse((document.getElementById('loan-amount') as HTMLInputElement).value);
    const r = parseFloat((document.getElementById('interest-rate') as HTMLInputElement).value);
    const t = parseInt((document.getElementById('loan-term') as HTMLSelectElement).value);

    // Format input
    if (document.activeElement?.id !== 'loan-amount') {
      (document.getElementById('loan-amount') as HTMLInputElement).value = fmtNum(loan);
    }

    const mr = (r / 100) / 12;
    const n = t * 12;

    let pi = 0;
    if (mr > 0) {
      pi = loan * (mr * Math.pow(1 + mr, n)) / (Math.pow(1 + mr, n) - 1);
    } else {
      pi = loan / n;
    }

    let balance = loan;
    let totalInterest = 0;
    let html = '';

    if (currentView === 'monthly') {
      // Generate monthly rows
      for (let i = 1; i <= n; i++) {
        const interestPayment = balance * mr;
        const principalPayment = pi - interestPayment;
        
        totalInterest += interestPayment;
        balance -= principalPayment;

        if (balance < 0) balance = 0;

        const isYearEnd = i % 12 === 0;
        const rowClass = isYearEnd ? 'bg-slate-50 dark:bg-slate-800/30 font-bold' : 'font-medium';

        html += `<tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors ${rowClass}">
          <td class="px-6 py-3 whitespace-nowrap" style="color: var(--text-primary);">
            ${i} ${isYearEnd ? `<span class="text-xs ml-2 text-[#06b6d4] dark:text-cyan-300">(Year ${i/12})</span>` : ''}
          </td>
          <td class="px-6 py-3 text-right text-[#10b981] dark:text-emerald-400">${fmt(principalPayment)}</td>
          <td class="px-6 py-3 text-right text-[#f59e0b] dark:text-amber-300">${fmt(interestPayment)}</td>
          <td class="px-6 py-3 text-right" style="color: var(--text-primary);">${fmt(totalInterest)}</td>
          <td class="px-6 py-3 text-right" style="color: var(--text-primary);">${fmt(balance)}</td>
        </tr>`;
      }
    } else {
      // Generate yearly aggregated rows
      let yearlyPrincipal = 0;
      let yearlyInterest = 0;
      let yearCount = 1;
      
      for (let i = 1; i <= n; i++) {
        const interestPayment = balance * mr;
        const principalPayment = pi - interestPayment;
        
        yearlyPrincipal += principalPayment;
        yearlyInterest += interestPayment;
        
        totalInterest += interestPayment;
        balance -= principalPayment;
        if (balance < 0) balance = 0;

        if (i % 12 === 0 || i === n) {
          html += `<tr class="hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors font-semibold">
            <td class="px-6 py-4 whitespace-nowrap" style="color: var(--text-primary);">
              Year ${yearCount}
            </td>
            <td class="px-6 py-4 text-right text-[#10b981] dark:text-emerald-400">${fmt(yearlyPrincipal)}</td>
            <td class="px-6 py-4 text-right text-[#f59e0b] dark:text-amber-300">${fmt(yearlyInterest)}</td>
            <td class="px-6 py-4 text-right" style="color: var(--text-primary);">${fmt(totalInterest)}</td>
            <td class="px-6 py-4 text-right" style="color: var(--text-primary);">${fmt(balance)}</td>
          </tr>`;
          
          yearlyPrincipal = 0;
          yearlyInterest = 0;
          yearCount++;
        }
      }
    }

    document.getElementById('monthly-pi')!.textContent = fmt(pi);
    document.getElementById('total-interest')!.textContent = fmt(totalInterest);
    document.getElementById('schedule-body')!.innerHTML = html;
    document.getElementById('col-payment')!.textContent = currentView === 'monthly' ? 'Payment #' : 'Year';
  }

  document.addEventListener('DOMContentLoaded', async () => {
    ['loan-amount', 'interest-rate', 'loan-term'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', generateSchedule);
      document.getElementById(id)?.addEventListener('change', generateSchedule);
    });
    
    const btnMonthly = document.getElementById('view-monthly')!;
    const btnYearly = document.getElementById('view-yearly')!;
    
    function updateTabs() {
      if (currentView === 'monthly') {
        btnMonthly.className = 'px-4 py-1.5 text-sm font-semibold rounded-md bg-white dark:bg-slate-700 shadow-sm transition-all';
        btnMonthly.style.color = 'var(--text-primary)';
        btnYearly.className = 'px-4 py-1.5 text-sm font-medium rounded-md text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-all';
        btnYearly.style.color = '';
      } else {
        btnYearly.className = 'px-4 py-1.5 text-sm font-semibold rounded-md bg-white dark:bg-slate-700 shadow-sm transition-all';
        btnYearly.style.color = 'var(--text-primary)';
        btnMonthly.className = 'px-4 py-1.5 text-sm font-medium rounded-md text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-all';
        btnMonthly.style.color = '';
      }
      generateSchedule();
    }
    
    btnMonthly.addEventListener('click', () => { currentView = 'monthly'; updateTabs(); });
    btnYearly.addEventListener('click', () => { currentView = 'yearly'; updateTabs(); });

    // Initial generation
    generateSchedule();

    const { OnboardingTour } = await import('../scripts/onboarding.ts');
    new OnboardingTour().init();
  });
</script>
