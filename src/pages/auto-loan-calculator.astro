---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLiveRates } from '../utils/rates';
const ratesData = await getLiveRates(Astro);
import AdSlot from '../components/AdSlot.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Auto Loan Calculator",
      "description": "Calculate your monthly car payment, total interest paid, and true cost of financing. Supports trade-in value and down payment inputs.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
    {
        "@type": "Question",
        "name": "Should I finance a car for 60 or 72 months?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "A shorter 60-month term will have a higher monthly payment but a lower interest rate, saving you money overall. A 72-month term lowers the monthly burden but significantly increases total interest paid and puts you at a higher risk of being 'underwater' (owing more than the car is worth)."
        }
    },
    {
        "@type": "Question",
        "name": "Does my credit score affect my auto loan rate?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "Significantly. Auto loan rates are highly tiered based on FICO scores. Borrowers with excellent credit (720+) secure the lowest advertised rates, while those with subprime credit can see rates well into double digits."
        }
    },
    {
        "@type": "Question",
        "name": "What is gap insurance?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "Cars depreciate rapidly. If your car is totaled, standard insurance only pays its current market value. If you owe more on the loan than the car is worth, GAP (Guaranteed Asset Protection) insurance covers the difference so you aren't stuck paying for a car you no longer have."
        }
    },
    {
        "@type": "Question",
        "name": "Is it better to put more money down on a car?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. A larger down payment reduces your loan amount, lowers your monthly payment, decreases the total interest you'll pay, and protects you against rapid vehicle depreciation early in the loan term."
        }
    }
]
    }
  ]
};
---

<BaseLayout
  keywords="auto loan calculator, car payment calculator, vehicle financing, monthly car payment, auto loan payoff, mortgage calculator, home loan calculator, current mortgage rates, monthly mortgage payment, free mortgage calculator, mortgage payment calculator, house payment calculator, home mortgage calculator, calculate mortgage, mortgage estimator, monthly house payment, mortgage interest calculator, loan payment calculator, how much is my mortgage, mortgage calculator with taxes, mortgage calculator with PMI, mortgage calculator with insurance, PITI calculator, home buying calculator, home affordability calculator, mortgage amortization, what will my mortgage payment be, mortgage calculator 2025, best mortgage calculator, accurate mortgage calculator, simple mortgage calculator, mortgage calculator USA, home loan payment estimator, mortgage rate calculator, mortgage cost calculator"
  canonicalUrl="/auto-loan-calculator/"
  title="Auto Loan Calculator"
  description="Calculate your monthly car payment, total interest paid, and true cost of financing. Supports trade-in value and down payment inputs."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="color: var(--text-primary);">
        Auto Loan
        <span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">Calculator</span>
      </h1>
      <p class="text-base sm:text-lg max-w-xl mx-auto" style="color: var(--text-muted);">
        Calculate your monthly car payment and total cost of financing.
      </p>
    </div>

            <button type="button" id="email-cta" class="inline-flex items-center gap-1.5 px-4 py-2 bg-[var(--color-usa-blue)] text-white text-sm font-medium rounded-lg hover:bg-opacity-90 transition shadow-sm mb-6 mt-4 cursor-pointer mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              Email me this breakdown
            </button>

  </section>

  <!-- Ad Slot: Leaderboard -->
  <AdSlot type="leaderboard" />


  <!-- Ad Slot -->
  <div class="ad-slot max-w-4xl mx-auto mb-6">Advertisement Space Reserved</div>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="card p-6 sm:p-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10">
        <!-- INPUTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#06b6d4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Vehicle Details
          </h2>
          <div>
            <label class="label block mb-1.5">Vehicle Price</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input aria-label="Auto Price" type="text" id="auto-price" value="35,000" inputmode="numeric" class="calc-input pl-7 font-mono"  data-step="1" data-tooltip="Step 1: Enter Auto Price"/>
            </div>
          </div>
          <div>
            <label class="label block mb-1.5">Trade-in Value</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input aria-label="Auto Tradein" type="text" id="auto-tradein" value="0" inputmode="numeric" class="calc-input pl-7 font-mono"  data-step="2" data-tooltip="Step 2: Enter Auto Tradein"/>
            </div>
          </div>
          <div>
            <label class="label block mb-1.5">Down Payment</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input aria-label="Auto Down" type="text" id="auto-down" value="3,000" inputmode="numeric" class="calc-input pl-7 font-mono"  data-step="3" data-tooltip="Step 3: Enter Auto Down"/>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="label block mb-1.5">Interest Rate (%)</label>
              <input aria-label="Auto Rate" type="number" id="auto-rate" value="7.5" step="0.01" inputmode="numeric" class="calc-input font-mono"  data-step="4" data-tooltip="Step 4: Enter Auto Rate"/>
            </div>
            <div>
              <label class="label block mb-1.5">Loan Term</label>
              <select aria-label="Auto Term" id="auto-term" class="calc-input font-mono w-full" data-step="5" data-tooltip="Step 5: Enter Auto Term">
                <option value="24">24 months</option>
                <option value="36">36 months</option>
                <option value="48">48 months</option>
                <option value="60" selected>60 months</option>
                <option value="72">72 months</option>
                <option value="84">84 months</option>
              </select>
            </div>
          </div>
        </div>

        <!-- RESULTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#10b981]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Payment Projection
          </h2>
          <div class="text-center py-6 rounded-xl" style="background: var(--bg-surface-2); border: 1px solid var(--border-default);">
            <p class="label-faint text-sm mb-2">Monthly Payment</p>
            <div class="text-4xl font-bold font-mono tracking-tight" id="auto-payment">
              <span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">$0</span>
            </div>
          </div>
          <div class="result-row">
            <span class="label">Net Loan Amount</span>
            <span class="text-sm font-semibold font-mono text-[#06b6d4]" id="auto-net">$0</span>
          </div>
          <div class="result-row">
            <span class="label">Total Amount Paid</span>
            <span class="text-sm font-semibold font-mono text-[#10b981]" id="auto-total">$0</span>
          </div>
          <div class="result-row">
            <span class="label">Total Interest Paid</span>
            <span class="text-sm font-semibold font-mono text-[#ef4444]" id="auto-interest">$0</span>
          </div>
          <p class="text-sm text-center font-medium mt-4" style="color: var(--text-primary);" id="auto-summary">
            You'll pay off this loan in 60 months
          </p>
        </div>
      </div>
    </div>

    <!-- Ad Slot -->
    <div class="ad-slot max-w-4xl mx-auto my-6">Advertisement Space Reserved</div>

    <p class="text-xs mt-8 max-w-2xl mx-auto text-center" style="color: var(--text-muted); line-height: 1.6;">
      This calculator provides estimates for informational purposes only and does not constitute financial advice. 
      Consult a licensed financial advisor or lender before making any financial decisions.
    </p>
  </section>

  <!-- Ad Slot: Rectangle -->
  <AdSlot type="rectangle" />


  <!-- Related Links -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="card p-8">
      <h3 class="text-xl font-bold mb-6" style="color: var(--text-primary);">Related Tools & States</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div>
          <h4 class="font-semibold mb-4 text-[#06b6d4]">More Calculators</h4>
          <ul class="space-y-3">
            <li><a href="/loan-payment-calculator/" class="text-sm hover:text-[#10b981] transition-colors" style="color: var(--text-secondary);">→ Loan Payment Calculator</a></li>
            <li><a href="/how-much-can-i-afford/" class="text-sm hover:text-[#10b981] transition-colors" style="color: var(--text-secondary);">→ Affordability Calculator</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-4 text-[#10b981]">State Spotlights</h4>
          <ul class="space-y-3">
            <li><a href="/states/california/" class="text-sm hover:text-[#06b6d4] transition-colors" style="color: var(--text-secondary);">→ California Mortgage Calculator</a></li>
            <li><a href="/states/washington/" class="text-sm hover:text-[#06b6d4] transition-colors" style="color: var(--text-secondary);">→ Washington Mortgage Calculator</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { OnboardingTour } from '../scripts/onboarding.ts';
  new OnboardingTour().init();

  function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }
  function parse(s) { return parseFloat(String(s).replace(/[^0-9.-]/g, '')) || 0; }
  function fmtNum(n) { return Math.round(n).toLocaleString('en-US'); }

  function calculate() {
    const vehiclePrice = parse((document.getElementById('auto-price')).value);
    const tradeIn = parse((document.getElementById('auto-tradein')).value);
    const downPayment = parse((document.getElementById('auto-down')).value);
    
    if (document.activeElement?.id !== 'auto-price') document.getElementById('auto-price').value = fmtNum(vehiclePrice);
    if (document.activeElement?.id !== 'auto-tradein') document.getElementById('auto-tradein').value = fmtNum(tradeIn);
    if (document.activeElement?.id !== 'auto-down') document.getElementById('auto-down').value = fmtNum(downPayment);

    const rate = parseFloat((document.getElementById('auto-rate')).value) || 0;
    const termMonths = parseInt((document.getElementById('auto-term')).value) || 60;

    const netLoan = vehiclePrice - tradeIn - downPayment;
    const r = rate / 100 / 12;
    const n = termMonths;
    const payment = r === 0 ? netLoan / n : netLoan * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
    const totalPaid = payment * n;
    const totalInterest = totalPaid - netLoan;

    document.getElementById('auto-payment').innerHTML = `<span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">${fmt(payment)}</span>`;
    document.getElementById('auto-net').innerText = fmt(netLoan);
    document.getElementById('auto-total').innerText = fmt(totalPaid);
    document.getElementById('auto-interest').innerText = fmt(totalInterest);
    document.getElementById('auto-summary').innerText = `You'll pay off this loan in ${termMonths} months`;
  }

  ['auto-price', 'auto-tradein', 'auto-down', 'auto-rate', 'auto-term'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', calculate);
  });
  
  calculate();

  document.getElementById('email-cta')?.addEventListener('click', () => {
    if (typeof (window as any).__openEmailModal === 'function') {
      (window as any).__openEmailModal({
        title: "Your Auto Loan Breakdown",
        fields: [
          { label: 'Monthly Payment', value: document.getElementById('monthly-payment')?.textContent?.trim() || '$0', highlight: true },
          { label: 'Total Interest', value: document.getElementById('total-interest')?.textContent?.trim() || '$0' },
          { label: 'Total Cost', value: document.getElementById('total-cost')?.textContent?.trim() || '$0' }
        ]
      });
    }
  });
</script>
