---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLiveRates } from '../utils/rates';
const ratesData = await getLiveRates(Astro);
import AdSlot from '../components/AdSlot.astro';
---

<BaseLayout
  keywords="va loans, va loans calculator, va loans rates, how to calculate va loans"
  canonicalUrl="/va-loans/"
  title="VA Loans Guide & Calculator"
  description="Learn about VA loans, eligibility, 0% down payment requirements, and VA funding fees."
>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-24">
    <div class="text-center mb-12">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4" style="color: var(--text-primary);">
        VA Loans:
        <span class="bg-gradient-to-r from-[var(--color-usa-blue)] to-[var(--color-usa-red)] bg-clip-text text-transparent">Complete Guide</span>
      </h1>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-muted);">
        Everything veterans and active-duty service members need to know about VA home loans.
      </p>
    </div>

    <!-- Ad Slot -->
    <div class="ad-slot max-w-4xl mx-auto mb-6">Advertisement Space Reserved</div>

    <div class="card p-8 sm:p-10 space-y-8">
      <div>
        <h2 class="text-2xl font-bold mb-4" style="color: var(--text-primary);">What is a VA Loan?</h2>
        <p style="color: var(--text-secondary); line-height: 1.7;">
          A VA loan is a $0-down mortgage option issued by private lenders and partially backed by the Department of Veterans Affairs (VA). It is exclusively available to veterans, active-duty service members, and select military spouses.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="p-5 rounded-xl border" style="background: var(--bg-surface-2); border-color: var(--border-subtle);">
          <h3 class="font-bold mb-2 text-[var(--color-usa-blue)]">0% Down Payment</h3>
          <p class="text-sm" style="color: var(--text-secondary);">One of the only loan types available today that allows you to buy a home with absolutely no money down.</p>
        </div>
        <div class="p-5 rounded-xl border" style="background: var(--bg-surface-2); border-color: var(--border-subtle);">
          <h3 class="font-bold mb-2 text-[var(--color-usa-red)]">No PMI Required</h3>
          <p class="text-sm" style="color: var(--text-secondary);">Unlike FHA or conventional loans, VA loans do not require Private Mortgage Insurance, saving you hundreds monthly.</p>
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold mb-4" style="color: var(--text-primary);">The VA Funding Fee</h2>
        <p style="color: var(--text-secondary); line-height: 1.7;">
          While there is no PMI, VA loans do have a one-time "Funding Fee" (ranging from 1.25% to 3.3% of the loan amount). This fee can usually be rolled directly into the loan amount so you don't have to pay it out of pocket.
        </p>
      </div>

      <div class="mt-8 text-center">
        <a href="/?type=va" class="inline-block px-8 py-3 rounded-lg bg-[var(--color-usa-blue)] hover:bg-blue-900 text-white font-medium transition-colors shadow-sm">
          Calculate VA Payment Now
        </a>
      </div>
    </div>
  </section>

  <!-- Ad Slot: Leaderboard -->
  <AdSlot type="leaderboard" />


  <!-- Ad Slot -->
  <div class="ad-slot max-w-4xl mx-auto my-6">Advertisement Space Reserved</div>


  <!-- Ad Slot: Rectangle -->
  <AdSlot type="rectangle" />

</BaseLayout>
