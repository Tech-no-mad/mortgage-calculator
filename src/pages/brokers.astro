---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Top 10 Rated Mortgage Brokers"
  description="Compare the best mortgage brokers and lenders to get your home loan."
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-24">
    <div class="text-center mb-12">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4" style="color: var(--text-primary);">
        Top 10 Mortgage
        <span class="bg-gradient-to-r from-[var(--color-usa-blue)] to-[var(--color-usa-red)] bg-clip-text text-transparent">Brokers & Lenders</span>
      </h1>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-muted);">
        Ready to get a mortgage? We've aggregated the top 10 national lenders based on independent public reviews and Trustpilot scores.
      </p>
    </div>

    <!-- Top Ad Slot -->
    <div class="ad-slot">Advertisement Space Reserved</div>

    <!-- Affiliate/Broker List -->
    <div class="space-y-6 mt-8">
      
      <!-- Broker 1 -->
      <div class="card p-6 sm:p-8 flex flex-col md:flex-row items-center gap-6 group hover:border-[var(--color-usa-blue)] transition-all">
        <div class="w-28 h-28 px-2 text-center break-words text-lg leading-tight rounded-2xl bg-blue-600 flex items-center justify-center flex-shrink-0 text-white font-bold text-xl shadow-inner">
          Rocket
        </div>
        <div class="flex-1 text-center md:text-left">
          <h2 class="text-2xl font-bold mb-2" style="color: var(--text-primary);">1. Rocket Mortgage</h2>
          <div class="flex items-center justify-center md:justify-start gap-2 mb-3">
            <span class="text-sm font-semibold text-slate-500">4.1 TrustScore</span>
          </div>
          <p class="text-sm md:text-base mb-4" style="color: var(--text-secondary);">
            Known for its fully digital, fast application process and highly rated mobile app. Great for first-time buyers looking for convenience.
          </p>
          <ul class="flex flex-wrap items-center justify-center md:justify-start gap-2 text-xs font-medium">
            <li class="bg-slate-100 dark:bg-slate-800 px-3 py-1 rounded-full text-slate-700 dark:text-slate-300">Fast Approvals</li>
            <li class="bg-slate-100 dark:bg-slate-800 px-3 py-1 rounded-full text-slate-700 dark:text-slate-300">100% Online</li>
          </ul>
        </div>
        <div class="flex-shrink-0 w-full md:w-auto">
          <a href="#" class="block w-full text-center px-6 py-3 rounded-lg bg-[var(--color-usa-blue)] hover:bg-blue-900 text-white font-semibold transition-colors shadow-sm">
            Check Rates
          </a>
        </div>
      </div>

      <!-- Broker 2 -->
      <div class="card p-6 sm:p-8 flex flex-col md:flex-row items-center gap-6 group hover:border-[var(--color-usa-red)] transition-all">
        <div class="w-28 h-28 px-2 text-center break-words text-lg leading-tight rounded-2xl bg-green-600 flex items-center justify-center flex-shrink-0 text-white font-bold text-xl shadow-inner">
          Better
        </div>
        <div class="flex-1 text-center md:text-left">
          <h2 class="text-2xl font-bold mb-2" style="color: var(--text-primary);">2. Better.com</h2>
          <div class="flex items-center justify-center md:justify-start gap-2 mb-3">
            <span class="text-sm font-semibold text-slate-500">4.8 TrustScore</span>
          </div>
          <p class="text-sm md:text-base mb-4" style="color: var(--text-secondary);">
            No commission fees or lender fees. Offers transparent rates and an excellent fully-digital closing experience.
          </p>
          <ul class="flex flex-wrap items-center justify-center md:justify-start gap-2 text-xs font-medium">
            <li class="bg-slate-100 dark:bg-slate-800 px-3 py-1 rounded-full text-slate-700 dark:text-slate-300">No Lender Fees</li>
            <li class="bg-slate-100 dark:bg-slate-800 px-3 py-1 rounded-full text-slate-700 dark:text-slate-300">Price Match Guarantee</li>
          </ul>
        </div>
        <div class="flex-shrink-0 w-full md:w-auto">
          <a href="#" class="block w-full text-center px-6 py-3 rounded-lg bg-[var(--color-usa-red)] hover:bg-red-800 text-white font-semibold transition-colors shadow-sm">
            Check Rates
          </a>
        </div>
      </div>

      <!-- Broker 3 -->
      <div class="card p-6 sm:p-8 flex flex-col md:flex-row items-center gap-6 group transition-all">
        <div class="w-28 h-28 px-2 text-center break-words text-lg leading-tight rounded-2xl bg-slate-800 flex items-center justify-center flex-shrink-0 text-white font-bold text-xl shadow-inner">
          Chase
        </div>
        <div class="flex-1 text-center md:text-left">
          <h2 class="text-2xl font-bold mb-2" style="color: var(--text-primary);">3. Chase Bank</h2>
          <div class="flex items-center justify-center md:justify-start gap-2 mb-3">
            <span class="text-sm font-semibold text-slate-500">4.0 TrustScore</span>
          </div>
          <p class="text-sm md:text-base mb-4" style="color: var(--text-secondary);">
            Excellent physical branch access and great discounts for existing bank customers.
          </p>
        </div>
        <div class="flex-shrink-0 w-full md:w-auto">
          <a href="#" class="block w-full text-center px-6 py-3 rounded-lg bg-[var(--color-usa-blue)] hover:bg-blue-900 text-white font-semibold transition-colors shadow-sm">Check Rates</a>
        </div>
      </div>

      <!-- Mid Ad Slot -->
      <div class="ad-slot">Advertisement Space Reserved</div>

      <!-- Broker 4 -->
      <div class="card p-6 sm:p-8 flex flex-col md:flex-row items-center gap-6 group transition-all">
        <div class="w-28 h-28 px-2 text-center break-words text-lg leading-tight rounded-2xl bg-red-600 flex items-center justify-center flex-shrink-0 text-white font-bold text-xl shadow-inner text-center leading-tight">
          Bank of<br/>America
        </div>
        <div class="flex-1 text-center md:text-left">
          <h2 class="text-2xl font-bold mb-2" style="color: var(--text-primary);">4. Bank of America</h2>
          <div class="flex items-center justify-center md:justify-start gap-2 mb-3">
            <span class="text-sm font-semibold text-slate-500">3.9 TrustScore</span>
          </div>
          <p class="text-sm md:text-base mb-4" style="color: var(--text-secondary);">
            Offers significant lender credit programs and low down payment options for first-time buyers.
          </p>
        </div>
        <div class="flex-shrink-0 w-full md:w-auto">
          <a href="#" class="block w-full text-center px-6 py-3 rounded-lg bg-[var(--color-usa-red)] hover:bg-red-800 text-white font-semibold transition-colors shadow-sm">Check Rates</a>
        </div>
      </div>

      <!-- Broker 5 -->
      <div class="card p-6 sm:p-8 flex flex-col md:flex-row items-center gap-6 group transition-all">
        <div class="w-28 h-28 px-2 text-center break-words text-lg leading-tight rounded-2xl bg-green-500 flex items-center justify-center flex-shrink-0 text-white font-bold text-xl shadow-inner">
          Fairway
        </div>
        <div class="flex-1 text-center md:text-left">
          <h2 class="text-2xl font-bold mb-2" style="color: var(--text-primary);">5. Fairway Independent</h2>
          <div class="flex items-center justify-center md:justify-start gap-2 mb-3">
            <span class="text-sm font-semibold text-slate-500">4.9 TrustScore</span>
          </div>
          <p class="text-sm md:text-base mb-4" style="color: var(--text-secondary);">
            Top-rated customer service with highly localized loan officers.
          </p>
        </div>
        <div class="flex-shrink-0 w-full md:w-auto">
          <a href="#" class="block w-full text-center px-6 py-3 rounded-lg bg-[var(--color-usa-blue)] hover:bg-blue-900 text-white font-semibold transition-colors shadow-sm">Check Rates</a>
        </div>
      </div>

      <!-- Broker 6 -->
      <div class="card p-6 sm:p-8 flex flex-col md:flex-row items-center gap-6 group transition-all">
        <div class="w-28 h-28 px-2 text-center break-words text-lg leading-tight rounded-2xl bg-indigo-600 flex items-center justify-center flex-shrink-0 text-white font-bold text-xl shadow-inner">
          Guild
        </div>
        <div class="flex-1 text-center md:text-left">
          <h2 class="text-2xl font-bold mb-2" style="color: var(--text-primary);">6. Guild Mortgage</h2>
          <div class="flex items-center justify-center md:justify-start gap-2 mb-3">
            <span class="text-sm font-semibold text-slate-500">4.7 TrustScore</span>
          </div>
          <p class="text-sm md:text-base mb-4" style="color: var(--text-secondary);">
            Specializes in first-time homebuyers and down payment assistance programs.
          </p>
        </div>
        <div class="flex-shrink-0 w-full md:w-auto">
          <a href="#" class="block w-full text-center px-6 py-3 rounded-lg bg-[var(--color-usa-red)] hover:bg-red-800 text-white font-semibold transition-colors shadow-sm">Check Rates</a>
        </div>
      </div>

      <!-- Broker 7 -->
      <div class="card p-6 sm:p-8 flex flex-col md:flex-row items-center gap-6 group transition-all">
        <div class="w-28 h-28 px-2 text-center break-words text-lg leading-tight rounded-2xl bg-teal-600 flex items-center justify-center flex-shrink-0 text-white font-bold text-xl shadow-inner">
          PennyMac
        </div>
        <div class="flex-1 text-center md:text-left">
          <h2 class="text-2xl font-bold mb-2" style="color: var(--text-primary);">7. PennyMac</h2>
          <div class="flex items-center justify-center md:justify-start gap-2 mb-3">
            <span class="text-sm font-semibold text-slate-500">4.5 TrustScore</span>
          </div>
          <p class="text-sm md:text-base mb-4" style="color: var(--text-secondary);">
            One of the top nationwide lenders for FHA and VA loans.
          </p>
        </div>
        <div class="flex-shrink-0 w-full md:w-auto">
          <a href="#" class="block w-full text-center px-6 py-3 rounded-lg bg-[var(--color-usa-blue)] hover:bg-blue-900 text-white font-semibold transition-colors shadow-sm">Check Rates</a>
        </div>
      </div>

      <!-- Broker 8 -->
      <div class="card p-6 sm:p-8 flex flex-col md:flex-row items-center gap-6 group transition-all">
        <div class="w-28 h-28 px-2 text-center break-words text-lg leading-tight rounded-2xl bg-blue-800 flex items-center justify-center flex-shrink-0 text-white font-bold text-xl shadow-inner">
          U.S. Bank
        </div>
        <div class="flex-1 text-center md:text-left">
          <h2 class="text-2xl font-bold mb-2" style="color: var(--text-primary);">8. U.S. Bank</h2>
          <div class="flex items-center justify-center md:justify-start gap-2 mb-3">
            <span class="text-sm font-semibold text-slate-500">4.2 TrustScore</span>
          </div>
          <p class="text-sm md:text-base mb-4" style="color: var(--text-secondary);">
            Competitive rates and great portfolio loans for unique situations.
          </p>
        </div>
        <div class="flex-shrink-0 w-full md:w-auto">
          <a href="#" class="block w-full text-center px-6 py-3 rounded-lg bg-[var(--color-usa-red)] hover:bg-red-800 text-white font-semibold transition-colors shadow-sm">Check Rates</a>
        </div>
      </div>

      <!-- Broker 9 -->
      <div class="card p-6 sm:p-8 flex flex-col md:flex-row items-center gap-6 group transition-all">
        <div class="w-28 h-28 px-2 text-center break-words text-lg leading-tight rounded-2xl bg-cyan-800 flex items-center justify-center flex-shrink-0 text-white font-bold text-center leading-tight text-lg shadow-inner">
          Navy Federal
        </div>
        <div class="flex-1 text-center md:text-left">
          <h2 class="text-2xl font-bold mb-2" style="color: var(--text-primary);">9. Navy Federal</h2>
          <div class="flex items-center justify-center md:justify-start gap-2 mb-3">
            <span class="text-sm font-semibold text-slate-500">4.8 TrustScore</span>
          </div>
          <p class="text-sm md:text-base mb-4" style="color: var(--text-secondary);">
            The best option for VA loans and military members with 0% down options.
          </p>
        </div>
        <div class="flex-shrink-0 w-full md:w-auto">
          <a href="#" class="block w-full text-center px-6 py-3 rounded-lg bg-[var(--color-usa-blue)] hover:bg-blue-900 text-white font-semibold transition-colors shadow-sm">Check Rates</a>
        </div>
      </div>

      <!-- Broker 10 -->
      <div class="card p-6 sm:p-8 flex flex-col md:flex-row items-center gap-6 group transition-all">
        <div class="w-28 h-28 px-2 text-center break-words text-lg leading-tight rounded-2xl bg-orange-600 flex items-center justify-center flex-shrink-0 text-white font-bold text-xl shadow-inner">
          LoanDepot
        </div>
        <div class="flex-1 text-center md:text-left">
          <h2 class="text-2xl font-bold mb-2" style="color: var(--text-primary);">10. LoanDepot</h2>
          <div class="flex items-center justify-center md:justify-start gap-2 mb-3">
            <span class="text-sm font-semibold text-slate-500">4.3 TrustScore</span>
          </div>
          <p class="text-sm md:text-base mb-4" style="color: var(--text-secondary);">
            Great online platform combined with local loan officers for guidance.
          </p>
        </div>
        <div class="flex-shrink-0 w-full md:w-auto">
          <a href="#" class="block w-full text-center px-6 py-3 rounded-lg bg-[var(--color-usa-red)] hover:bg-red-800 text-white font-semibold transition-colors shadow-sm">Check Rates</a>
        </div>
      </div>

    </div>
    
    <!-- Bottom Ad Slot -->
    <div class="ad-slot mt-8">Advertisement Space Reserved</div>

    <div class="mt-12 p-6 rounded-xl border" style="border-color: var(--border-subtle); background: var(--bg-surface-2);">
      <h3 class="font-bold text-sm uppercase tracking-wider mb-2" style="color: var(--text-muted);">Disclaimer</h3>
      <p class="text-xs" style="color: var(--text-secondary); line-height: 1.6;">
        The brokers and lenders listed on this page are ranked solely based on third-party public review platforms such as Trustpilot and their respective TrustScores as of the last update. MortgageDash is not affiliated with these lenders, does not specifically endorse or encourage their use, and does not guarantee loan approval or specific interest rates. Always perform your own due diligence and compare offers from multiple lenders to find the best rate for your specific financial situation.
      </p>
    </div>
  </section>
</BaseLayout>
