---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  canonicalUrl="https://mortgagedash.app/loan-payment-calculator/"
  title="Loan Payment Calculator"
  description="Calculate monthly payments for any loan — personal loans, second mortgages, HELOCs, or student loans. Simple and fast loan payment estimator."
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="color: var(--text-primary);">
        Loan Payment
        <span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">Calculator</span>
      </h1>
      <p class="text-base sm:text-lg max-w-xl mx-auto" style="color: var(--text-muted);">
        Fast and simple estimator for personal loans and second mortgages.
      </p>
    </div>
  </section>

  <!-- Ad Slot -->
  <div class="ad-slot max-w-4xl mx-auto mb-6">Advertisement Space Reserved</div>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="card p-6 sm:p-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10">
        <!-- INPUTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#06b6d4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Loan Details
          </h2>
          <div>
            <label class="label block mb-1.5">Loan Amount</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input aria-label="Lp Amount" type="text" id="lp-amount" value="25,000" inputmode="numeric" class="calc-input pl-7 font-mono"  data-step="1" data-tooltip="Step 1: Enter Lp Amount"/>
            </div>
          </div>
          <div>
            <label class="label block mb-1.5">Annual Interest Rate (%)</label>
            <input aria-label="Lp Rate" type="number" id="lp-rate" value="8.5" step="0.01" inputmode="numeric" class="calc-input font-mono"  data-step="2" data-tooltip="Step 2: Enter Lp Rate"/>
          </div>
          <div>
            <label class="label block mb-1.5">Loan Term (months)</label>
            <input aria-label="Lp Term" type="number" id="lp-term" value="60" inputmode="numeric" class="calc-input font-mono"  data-step="3" data-tooltip="Step 3: Enter Lp Term"/>
          </div>
        </div>

        <!-- RESULTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#10b981]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Payment Projection
          </h2>
          <div class="text-center py-6 rounded-xl" style="background: var(--bg-surface-2); border: 1px solid var(--border-default);">
            <p class="label-faint text-sm mb-2">Monthly Payment</p>
            <div class="text-4xl font-bold font-mono tracking-tight" id="lp-payment">
              <span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">$0</span>
            </div>
          </div>
          <div class="result-row">
            <span class="label">Total Repaid</span>
            <span class="text-sm font-semibold font-mono text-[#06b6d4]" id="lp-repaid">$0</span>
          </div>
          <div class="result-row">
            <span class="label">Total Interest Paid</span>
            <span class="text-sm font-semibold font-mono text-[#f59e0b]" id="lp-interest">$0</span>
          </div>
          <div class="result-row">
            <span class="label">Interest as % of loan</span>
            <span class="text-sm font-semibold font-mono text-[#ef4444]" id="lp-interest-pct">0%</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Ad Slot -->
    <div class="ad-slot max-w-4xl mx-auto my-6">Advertisement Space Reserved</div>

    <p class="text-xs mt-8 max-w-2xl mx-auto text-center" style="color: var(--text-muted); line-height: 1.6;">
      This calculator provides estimates for informational purposes only and does not constitute financial advice. 
      Consult a licensed financial advisor or lender before making any financial decisions.
    </p>
  </section>
</BaseLayout>

<script>
  function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }
  function parse(s) { return parseFloat(String(s).replace(/[^0-9.-]/g, '')) || 0; }
  function fmtNum(n) { return Math.round(n).toLocaleString('en-US'); }

  function calculate() {
    const amount = parse((document.getElementById('lp-amount')).value);
    if (document.activeElement?.id !== 'lp-amount') document.getElementById('lp-amount').value = fmtNum(amount);

    const rate = parseFloat((document.getElementById('lp-rate')).value) || 0;
    const n = parseInt((document.getElementById('lp-term')).value) || 0;

    const r = rate / 100 / 12;
    const payment = r === 0 ? (n > 0 ? amount / n : 0) : amount * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
    
    const totalRepaid = payment * n;
    const totalInterest = totalRepaid - amount;
    const intPct = amount > 0 ? (totalInterest / amount) * 100 : 0;

    document.getElementById('lp-payment').innerHTML = `<span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">${fmt(payment)}</span>`;
    document.getElementById('lp-repaid').innerText = fmt(totalRepaid);
    document.getElementById('lp-interest').innerText = fmt(totalInterest);
    document.getElementById('lp-interest-pct').innerText = intPct.toFixed(2) + '%';
  }

  ['lp-amount', 'lp-rate', 'lp-term'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', calculate);
  });
  
  calculate();
</script>
