---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLiveRates } from '../utils/rates';
const ratesData = await getLiveRates(Astro);
import AdSlot from '../components/AdSlot.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Loan Payment Calculator",
      "description": "Calculate monthly payments for any loan — personal loans, second mortgages, HELOCs, or student loans. Simple and fast loan payment estimator.",
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "All",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
    {
        "@type": "Question",
        "name": "How do I calculate a monthly loan payment?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "A monthly loan payment is calculated using the loan principal, the interest rate, and the term length using a standard amortization formula. Our calculator does the heavy lifting instantly so you don't have to crunch the mathematical formula by hand."
        }
    },
    {
        "@type": "Question",
        "name": "Does this calculator include taxes and insurance?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our standard loan payment calculator computes strictly Principal and Interest (P&I). For a complete housing calculation including taxes, insurance, and PMI, we recommend using our comprehensive Mortgage Calculator tool on the homepage."
        }
    },
    {
        "@type": "Question",
        "name": "How does the loan term affect the payment?",
        "acceptedAnswer": {
            "@type": "Answer",
            "text": "A longer term (like 30 years) stretches the payments out, resulting in a lower monthly cost but much higher total interest over time. A shorter term (like 15 years) requires a higher monthly payment but drastically reduces the total interest paid to the bank."
        }
    }
]
    }
  ]
};
---

<BaseLayout
  keywords="loan payment calculator, simple mortgage calculator, monthly payment calculator, interest rate calculator, loan calculator, mortgage calculator, home loan calculator, current mortgage rates, monthly mortgage payment, free mortgage calculator, mortgage payment calculator, house payment calculator, home mortgage calculator, calculate mortgage, mortgage estimator, monthly house payment, mortgage interest calculator, how much is my mortgage, mortgage calculator with taxes, mortgage calculator with PMI, mortgage calculator with insurance, PITI calculator, home buying calculator, home affordability calculator, mortgage amortization, what will my mortgage payment be, mortgage calculator 2025, best mortgage calculator, accurate mortgage calculator, mortgage calculator USA, home loan payment estimator, mortgage rate calculator, mortgage cost calculator"
  canonicalUrl="/loan-payment-calculator/"
  title="Loan Payment Calculator"
  description="Calculate monthly payments for any loan — personal loans, second mortgages, HELOCs, or student loans. Simple and fast loan payment estimator."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-6">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="color: var(--text-primary);">
        Loan Payment
        <span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">Calculator</span>
      </h1>
      <p class="text-base sm:text-lg max-w-xl mx-auto" style="color: var(--text-muted);">
        Fast and simple estimator for personal loans and second mortgages.
      </p>
    </div>

            <button type="button" id="email-cta" class="inline-flex items-center gap-1.5 px-4 py-2 bg-[var(--color-usa-blue)] text-white text-sm font-medium rounded-lg hover:bg-opacity-90 transition shadow-sm mb-6 mt-4 cursor-pointer mx-auto">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              Email me this breakdown
            </button>

  </section>

  <!-- Ad Slot: Leaderboard -->
  <AdSlot type="leaderboard" />
<section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="card p-6 sm:p-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10">
        <!-- INPUTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#06b6d4]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Loan Details
          </h2>
          <div>
            <label class="label block mb-1.5">Loan Amount</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 label-faint">$</span>
              <input aria-label="Lp Amount" type="text" id="lp-amount" value="25,000" inputmode="numeric" class="calc-input pl-7 font-mono"  data-step="1" data-tooltip="Step 1: Enter Lp Amount"/>
            </div>
          </div>
          <div>
            <label class="label block mb-1.5">Annual Interest Rate (%)</label>
            <input aria-label="Lp Rate" type="number" id="lp-rate" value="8.5" step="0.01" inputmode="numeric" class="calc-input font-mono"  data-step="2" data-tooltip="Step 2: Enter Lp Rate"/>
          </div>
          <div>
            <label class="label block mb-1.5">Loan Term (months)</label>
            <input aria-label="Lp Term" type="number" id="lp-term" value="60" inputmode="numeric" class="calc-input font-mono"  data-step="3" data-tooltip="Step 3: Enter Lp Term"/>
          </div>
        </div>

        <!-- RESULTS -->
        <div class="space-y-5">
          <h2 class="text-base font-semibold flex items-center gap-2" style="color: var(--text-primary);">
            <svg class="w-4 h-4 text-[#10b981]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
            Payment Projection
          </h2>
          <div class="text-center py-6 rounded-xl" style="background: var(--bg-surface-2); border: 1px solid var(--border-default);">
            <p class="label-faint text-sm mb-2">Monthly Payment</p>
            <div class="text-4xl font-bold font-mono tracking-tight" id="lp-payment">
              <span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">$0</span>
            </div>
          </div>
          <div class="result-row">
            <span class="label">Total Repaid</span>
            <span class="text-sm font-semibold font-mono text-[#06b6d4]" id="lp-repaid">$0</span>
          </div>
          <div class="result-row">
            <span class="label">Total Interest Paid</span>
            <span class="text-sm font-semibold font-mono text-[#f59e0b]" id="lp-interest">$0</span>
          </div>
          <div class="result-row">
            <span class="label">Interest as % of loan</span>
            <span class="text-sm font-semibold font-mono text-[#ef4444]" id="lp-interest-pct">0%</span>
          </div>
        </div>
      </div>
    </div>
<p class="text-xs mt-8 max-w-2xl mx-auto text-center" style="color: var(--text-muted); line-height: 1.6;">
      This calculator provides estimates for informational purposes only and does not constitute financial advice. 
      Consult a licensed financial advisor or lender before making any financial decisions.
    </p>
  </section>

  <!-- Ad Slot: Rectangle -->
  <AdSlot type="rectangle" />

  <!-- Related Links -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="card p-8">
      <h3 class="text-xl font-bold mb-6" style="color: var(--text-primary);">Related Tools & States</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div>
          <h4 class="font-semibold mb-4 text-[#06b6d4]">More Calculators</h4>
          <ul class="space-y-3">
            <li><a href="/" class="text-sm hover:text-[#10b981] transition-colors" style="color: var(--text-secondary);">→ Mortgage Calculator</a></li>
            <li><a href="/amortization-schedule/" class="text-sm hover:text-[#10b981] transition-colors" style="color: var(--text-secondary);">→ Amortization Schedule</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-4 text-[#10b981]">State Spotlights</h4>
          <ul class="space-y-3">
            <li><a href="/states/massachusetts/" class="text-sm hover:text-[#06b6d4] transition-colors" style="color: var(--text-secondary);">→ Massachusetts Mortgage Calculator</a></li>
            <li><a href="/states/indiana/" class="text-sm hover:text-[#06b6d4] transition-colors" style="color: var(--text-secondary);">→ Indiana Mortgage Calculator</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { OnboardingTour } from '../scripts/onboarding.ts';
  new OnboardingTour().init();

  function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }
  function parse(s) { return parseFloat(String(s).replace(/[^0-9.-]/g, '')) || 0; }
  function fmtNum(n) { return Math.round(n).toLocaleString('en-US'); }

  function calculate() {
    const amount = parse((document.getElementById('lp-amount')).value);
    if (document.activeElement?.id !== 'lp-amount') document.getElementById('lp-amount').value = fmtNum(amount);

    const rate = parseFloat((document.getElementById('lp-rate')).value) || 0;
    const n = parseInt((document.getElementById('lp-term')).value) || 0;

    const r = rate / 100 / 12;
    const payment = r === 0 ? (n > 0 ? amount / n : 0) : amount * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
    
    const totalRepaid = payment * n;
    const totalInterest = totalRepaid - amount;
    const intPct = amount > 0 ? (totalInterest / amount) * 100 : 0;

    document.getElementById('lp-payment').innerHTML = `<span class="bg-gradient-to-r from-[#06b6d4] to-[#10b981] bg-clip-text text-transparent">${fmt(payment)}</span>`;
    document.getElementById('lp-repaid').innerText = fmt(totalRepaid);
    document.getElementById('lp-interest').innerText = fmt(totalInterest);
    document.getElementById('lp-interest-pct').innerText = intPct.toFixed(2) + '%';
  }

  ['lp-amount', 'lp-rate', 'lp-term'].forEach(id => {
    document.getElementById(id)?.addEventListener('input', calculate);
  });
  
  calculate();

  document.getElementById('email-cta')?.addEventListener('click', () => {
    if (typeof (window as any).__openEmailModal === 'function') {
      (window as any).__openEmailModal({
        title: "Your Loan Breakdown",
        fields: [
          { label: 'Monthly Payment', value: document.getElementById('monthly-payment')?.textContent?.trim() || '$0', highlight: true },
          { label: 'Total Interest', value: document.getElementById('total-interest')?.textContent?.trim() || '$0' },
          { label: 'Total Cost', value: document.getElementById('total-cost')?.textContent?.trim() || '$0' }
        ]
      });
    }
  });
</script>
