---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Server Error" description="Something went wrong. Please try again.">
  <section class="min-h-[65vh] flex items-center justify-center px-4">
    <div class="card p-10 sm:p-16 text-center max-w-lg">
      <div class="text-8xl sm:text-9xl font-bold font-mono tracking-tighter mb-4">
        <span class="bg-gradient-to-r from-[#f43f5e] to-[#f59e0b] bg-clip-text text-transparent">500</span>
      </div>
      <h1 class="text-2xl font-bold mb-3" style="color: var(--text-primary);">Something Went Wrong</h1>
      <p class="mb-8" style="color: var(--text-muted);">We're working on fixing this. Please try again later.</p>
      <a href="/" class="inline-block px-6 py-3 rounded-lg bg-[#06b6d4] hover:bg-[#0891b2] text-white font-medium transition-colors">Go Home</a>
    </div>
  </section>
</BaseLayout>
