---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  keywords?: string;
}

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Chatbot from '../components/Chatbot.astro';
import AdSlot from '../components/AdSlot.astro';
import EmailModal from '../components/EmailModal.astro';

// Fallback to workers.dev if PUBLIC_SITE_URL is not yet set for the custom domain
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://mortgage-calculator.karteek-tadimalla.workers.dev';

// Default keywords (ideally overridden by every page)
const defaultKeywords = "mortgage calculator, home loan calculator, current mortgage rates, monthly mortgage payment";

const { 
  title, 
  description, 
  canonicalUrl = Astro.url.pathname, 
  ogImage = '/og-default.png', 
  keywords = defaultKeywords 
} = Astro.props;

const fullTitle = `${title} | MortgageDash`;

// Ensure canonicalUrl is absolute
const absoluteCanonicalUrl = canonicalUrl.startsWith('http') 
  ? canonicalUrl 
  : new URL(canonicalUrl, siteUrl).toString();

// Ensure ogImage is absolute
const absoluteOgImage = ogImage.startsWith('http') 
  ? ogImage 
  : new URL(ogImage, siteUrl).toString();
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    {absoluteCanonicalUrl && <link rel="canonical" href={absoluteCanonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MortgageDash" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    {absoluteCanonicalUrl && <meta property="og:url" content={absoluteCanonicalUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Google Consent Mode & Dynamic Script Loading -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      
      const hasConsent = localStorage.getItem('mortgagedash_cookie_consent') === 'granted';
      
      gtag('consent', 'default', {
        'ad_storage': hasConsent ? 'granted' : 'denied',
        'analytics_storage': hasConsent ? 'granted' : 'denied'
      });
      
      if (hasConsent) {
        const adsenseScript = document.createElement('script');
        adsenseScript.async = true;
        adsenseScript.src = "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX";
        adsenseScript.crossOrigin = "anonymous";
        document.head.appendChild(adsenseScript);
      }
    </script>

    <!-- Prevent FOUC: set theme before paint -->
    <script is:inline>
      (function () {
        const s = localStorage.getItem('theme');
        if (s === 'light') document.documentElement.classList.remove('dark');
        else if (s === 'dark') document.documentElement.classList.add('dark');
        else if (window.matchMedia && !window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>

  <body class="min-h-screen font-sans antialiased transition-colors duration-300 flex flex-col">
    <div class="aurora-bg"></div>
    <Header />
    
    <!-- 🛡️ BOT LAYOUT SHIELDING -->
    <div class="relative flex-grow flex flex-col pb-24 sm:pb-16">
      <main class="flex-grow">
        <slot />
      </main>
    </div>

    <Footer />
    <Chatbot />
    <EmailModal />

    <!-- Sticky Anchor Ad (Slot 4) - fixed to bottom, hidden when cookie banner is visible -->
    <AdSlot type="sticky" />

    <!-- Mobile Sticky Payment Bar -->
    <div
      id="mobile-sticky-payment"
      class="fixed bottom-0 left-0 right-0 z-[9985] md:hidden transform translate-y-full transition-transform duration-300"
      style="background: var(--bg-surface); border-top: 1px solid var(--border-default); box-shadow: 0 -4px 20px rgba(0,0,0,0.15);"
    >
      <div class="flex items-center justify-between px-4 py-3">
        <div>
          <p class="text-xs font-medium" style="color: var(--text-muted);">Monthly Payment</p>
          <p class="text-xl font-bold font-mono bg-gradient-to-r from-[var(--color-usa-blue)] to-[var(--color-usa-red)] bg-clip-text text-transparent" id="sticky-payment-amount">$1,837</p>
        </div>
        <a href="#monthly-payment" class="px-4 py-2 rounded-lg text-xs font-semibold text-white" style="background: var(--color-usa-blue);">
          View Details ↓
        </a>
      </div>
    </div>


    <!-- 🍪 COMPLIANT COOKIE CONSENT BANNER INTERFACE -->
    <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 bg-[var(--bg-surface)] border-t border-[var(--border-default)] shadow-2xl p-4 z-[9999] hidden transform transition-all duration-300">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <span class="text-xl">🍪</span>
          <div>
            <h4 class="text-sm font-bold text-[var(--text-primary)]">Cookie & Privacy Preferences</h4>
            <p class="text-xs text-[var(--text-secondary)] leading-relaxed max-w-2xl mt-0.5">
              MortgageDash and our partner Google use cookies to analyze web traffic and deliver personalized, relevant advertisements. You can modify your choices at any time.
            </p>
          </div>
        </div>
        <div class="flex items-center gap-3 shrink-0 w-full md:w-auto justify-end">
          <button id="decline-cookies" class="px-4 py-2 text-sm font-semibold rounded-lg border border-[var(--border-default)] text-[var(--text-secondary)] hover:bg-[var(--bg-hover)] transition-colors w-full md:w-auto">
            Decline
          </button>
          <button id="accept-cookies" class="px-5 py-2 text-sm font-semibold rounded-lg bg-gradient-to-r from-[#06b6d4] to-[#10b981] text-white shadow-md hover:opacity-90 transition-opacity w-full md:w-auto">
            Accept All
          </button>
        </div>
      </div>
    </div>

    <script>
      // Global Range Slider Logic for styling
      function updateSliderProgress(slider: HTMLInputElement) {
        const min = parseFloat(slider.min) || 0;
        const max = parseFloat(slider.max) || 100;
        const val = parseFloat(slider.value) || 0;
        const percent = ((val - min) / (max - min)) * 100;
        slider.style.setProperty('--progress', `${percent}%`);
      }

      document.addEventListener('input', (e) => {
        if (e.target && (e.target as HTMLElement).matches('input[type="range"]')) {
          updateSliderProgress(e.target as HTMLInputElement);
        }
      });

      // Also run on Astro page load if using ViewTransitions, or standard load
      function initSliders() {
        document.querySelectorAll('input[type="range"]').forEach((el) => {
          updateSliderProgress(el as HTMLInputElement);
        });
      }
      
      const checkConsent = () => {
        const consentState = localStorage.getItem('mortgagedash_cookie_consent');
        const banner = document.getElementById('cookie-banner');
        
        if (!consentState && banner) {
          banner.classList.remove('hidden');
        }
      };

      document.addEventListener('DOMContentLoaded', () => {
        initSliders();
        checkConsent();

        document.getElementById('accept-cookies')?.addEventListener('click', () => {
          localStorage.setItem('mortgagedash_cookie_consent', 'granted');
          document.getElementById('cookie-banner')?.classList.add('hidden');
          
          if (typeof window.gtag === 'function') {
            window.gtag('consent', 'update', {
              'ad_storage': 'granted',
              'analytics_storage': 'granted'
            });
          }
          
          if (!document.querySelector('script[src*="adsbygoogle.js"]')) {
             const adsenseScript = document.createElement('script');
             adsenseScript.async = true;
             adsenseScript.src = "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX";
             adsenseScript.crossOrigin = "anonymous";
             document.head.appendChild(adsenseScript);
          }
        });

        document.getElementById('decline-cookies')?.addEventListener('click', () => {
          localStorage.setItem('mortgagedash_cookie_consent', 'denied');
          document.getElementById('cookie-banner')?.classList.add('hidden');
        });
      });
    </script>
  </body>
</html>
