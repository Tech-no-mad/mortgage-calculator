---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  keywords?: string;
}

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Chatbot from '../components/Chatbot.astro';

const defaultKeywords = "mortgage calculator, monthly mortgage payment, mortgage payment calculator, home loan calculator, mortgage rates today, current mortgage rates, 30 year mortgage rates, 15 year mortgage rates, best mortgage rates, mortgage rate comparison, refinance calculator, mortgage refinance rates, cash out refinance, refinance my mortgage, should i refinance, break even refinance, home affordability calculator, how much house can i afford, debt to income ratio calculator, mortgage pre approval, mortgage pre qualification, fha loan calculator, fha loan requirements, fha loan limits 2025, fha vs conventional loan, va loan calculator, va loan eligibility, va loan rates, va loan no down payment, jumbo loan calculator, jumbo loan limits 2025, jumbo mortgage rates, non conforming loan, reverse mortgage calculator, reverse mortgage pros and cons, hecm calculator, how does reverse mortgage work, reverse mortgage age requirement, arm mortgage calculator, adjustable rate mortgage, 5 1 arm calculator, arm vs fixed rate mortgage, when to choose arm mortgage, commercial mortgage calculator, commercial real estate loan, commercial loan rates, dscr loan calculator, commercial property financing, balloon payment calculator, auto loan calculator, car loan calculator, monthly car payment, auto loan rates, vehicle financing calculator, investment property mortgage, investment property calculator, rental property calculator, real estate roi calculator, compound interest calculator, amortization schedule, mortgage amortization calculator, amortization table, loan payment calculator, personal loan calculator, heloc calculator, home equity line of credit rates, heloc vs home equity loan, home equity calculator, pmi calculator, private mortgage insurance, how to remove pmi, mortgage recast calculator, extra payment calculator, biweekly mortgage calculator, pay off mortgage early, mortgage payoff calculator, property tax calculator, states mortgage calculator, texas mortgage calculator, florida mortgage calculator, california mortgage calculator, new york mortgage calculator, north carolina mortgage calculator, closing costs calculator, mortgage points calculator, buy down rate calculator, mortgage broker, mortgage lender near me, online mortgage lender, rocket mortgage, pennymac, uwm mortgage, freedom mortgage, loan estimate, truth in lending, piti calculator, principal interest taxes insurance, conventional loan, conforming loan limit 2025, family opportunity mortgage, assumable mortgage, seller financing, bridge loan, construction loan, usda loan calculator, usda loan eligibility, first time home buyer programs, down payment assistance, dave ramsey mortgage, zero down mortgage";
const { title, description, canonicalUrl, ogImage = '/og-default.png', keywords = defaultKeywords } = Astro.props;
const fullTitle = `${title} | MortgageDash`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MortgageDash" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Google Consent Mode & Dynamic Script Loading -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      
      const hasConsent = localStorage.getItem('mortgagedash_cookie_consent') === 'granted';
      
      gtag('consent', 'default', {
        'ad_storage': hasConsent ? 'granted' : 'denied',
        'analytics_storage': hasConsent ? 'granted' : 'denied'
      });
      
      if (hasConsent) {
        const adsenseScript = document.createElement('script');
        adsenseScript.async = true;
        adsenseScript.src = "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX";
        adsenseScript.crossOrigin = "anonymous";
        document.head.appendChild(adsenseScript);
      }
    </script>

    <!-- Prevent FOUC: set theme before paint -->
    <script is:inline>
      (function () {
        const s = localStorage.getItem('theme');
        if (s === 'light') document.documentElement.classList.remove('dark');
        else if (s === 'dark') document.documentElement.classList.add('dark');
        else if (window.matchMedia && !window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>

  <body class="min-h-screen font-sans antialiased transition-colors duration-300 flex flex-col">
    <div class="aurora-bg"></div>
    <Header />
    
    <!-- 🛡️ BOT LAYOUT SHIELDING -->
    <div class="relative flex-grow flex flex-col pb-24 sm:pb-16">
      <main class="flex-grow">
        <slot />
      </main>
    </div>

    <Footer />
    <Chatbot />

    <!-- 🍪 COMPLIANT COOKIE CONSENT BANNER INTERFACE -->
    <div id="cookie-banner" class="fixed bottom-4 left-4 right-4 md:left-auto md:max-w-md bg-[var(--bg-surface)] border border-[var(--border-default)] shadow-2xl rounded-2xl p-5 z-[9999] hidden transform transition-all duration-300">
      <div class="flex flex-col gap-3">
        <div class="flex items-center gap-2">
          <span class="text-xl">🍪</span>
          <h4 class="text-sm font-bold text-[var(--text-primary)]">Cookie & Privacy Preferences</h4>
        </div>
        <p class="text-xs text-[var(--text-secondary)] leading-relaxed">
          MortgageDash and our partner Google use cookies to analyze web traffic and deliver personalized, relevant advertisements. You can modify your choices at any time.
        </p>
        <div class="flex items-center justify-end gap-2 mt-2">
          <button id="decline-cookies" class="px-3 py-1.5 text-xs font-semibold rounded-lg border border-[var(--border-default)] text-[var(--text-secondary)] hover:bg-[var(--bg-hover)] transition-colors">
            Decline
          </button>
          <button id="accept-cookies" class="px-4 py-1.5 text-xs font-semibold rounded-lg bg-gradient-to-r from-[#06b6d4] to-[#10b981] text-white shadow-md hover:opacity-90 transition-opacity">
            Accept All
          </button>
        </div>
      </div>
    </div>

    <script>
      // Global Range Slider Logic for styling
      function updateSliderProgress(slider: HTMLInputElement) {
        const min = parseFloat(slider.min) || 0;
        const max = parseFloat(slider.max) || 100;
        const val = parseFloat(slider.value) || 0;
        const percent = ((val - min) / (max - min)) * 100;
        slider.style.setProperty('--progress', `${percent}%`);
      }

      document.addEventListener('input', (e) => {
        if (e.target && (e.target as HTMLElement).matches('input[type="range"]')) {
          updateSliderProgress(e.target as HTMLInputElement);
        }
      });

      // Also run on Astro page load if using ViewTransitions, or standard load
      function initSliders() {
        document.querySelectorAll('input[type="range"]').forEach((el) => {
          updateSliderProgress(el as HTMLInputElement);
        });
      }
      
      const checkConsent = () => {
        const consentState = localStorage.getItem('mortgagedash_cookie_consent');
        const banner = document.getElementById('cookie-banner');
        
        if (!consentState && banner) {
          banner.classList.remove('hidden');
        }
      };

      document.addEventListener('DOMContentLoaded', () => {
        initSliders();
        checkConsent();

        document.getElementById('accept-cookies')?.addEventListener('click', () => {
          localStorage.setItem('mortgagedash_cookie_consent', 'granted');
          document.getElementById('cookie-banner')?.classList.add('hidden');
          
          if (typeof window.gtag === 'function') {
            window.gtag('consent', 'update', {
              'ad_storage': 'granted',
              'analytics_storage': 'granted'
            });
          }
          
          if (!document.querySelector('script[src*="adsbygoogle.js"]')) {
             const adsenseScript = document.createElement('script');
             adsenseScript.async = true;
             adsenseScript.src = "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX";
             adsenseScript.crossOrigin = "anonymous";
             document.head.appendChild(adsenseScript);
          }
        });

        document.getElementById('decline-cookies')?.addEventListener('click', () => {
          localStorage.setItem('mortgagedash_cookie_consent', 'denied');
          document.getElementById('cookie-banner')?.classList.add('hidden');
        });
      });
    </script>
  </body>
</html>
