---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  keywords?: string;
}

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Chatbot from '../components/Chatbot.astro';

const defaultKeywords = "mortgage calculator, states mortgage calculator, home loan, home loan calculator, mortgage rates, mortgage broker, mortgage recast, fixed-rate mortgage, mortgage recast calculator, reverse mortgage, assumable mortgage, simple mortgage calculator, mortgage affordability calculator, mortgage estimator, mortgage lender near me, mortgage refinance calculator, home mortgage, mortgage calc, mortgage lenders, family opportunity mortgage, ralo ai mortgage broker funding, rocket mortgage, pennymac, phh mortgage, onity mortgage, rosegate mortgage, shellpoint mortgage, chase mortgage, bank of america mortgage, uwm mortgage, freedom mortgage, champion mortgage, guild mortgage, dhi mortgage, essex mortgage, roundpoint mortgage, united wholesale mortgage, bankrate mortgage, midland mortgage, cmg mortgage, lennar mortgage, dave ramsey mortgage, union home mortgage, interest rate, amortization, PITI, principal, property tax, home insurance, PMI, conventional loan, FHA loan, VA loan, jumbo loan, down payment, closing costs, APR, HELOC";
const { title, description, canonicalUrl, ogImage = '/og-default.png', keywords = defaultKeywords } = Astro.props;
const fullTitle = `${title} | MortgageDash`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MortgageDash" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Prevent FOUC: set theme before paint -->
    <script is:inline>
      (function () {
        const s = localStorage.getItem('theme');
        if (s === 'light') document.documentElement.classList.remove('dark');
        else if (s === 'dark') document.documentElement.classList.add('dark');
        else if (window.matchMedia && !window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>

  <body class="min-h-screen font-sans antialiased transition-colors duration-300">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <Chatbot />
  </body>
</html>
