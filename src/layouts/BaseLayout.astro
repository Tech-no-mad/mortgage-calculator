---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  keywords?: string;
}

import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Chatbot from '../components/Chatbot.astro';

const defaultKeywords = "mortgage calculator, states mortgage calculator, home loan, home loan calculator, mortgage rates, mortgage broker, mortgage recast, fixed-rate mortgage, mortgage recast calculator, reverse mortgage, assumable mortgage, simple mortgage calculator, mortgage affordability calculator, mortgage estimator, mortgage lender near me, mortgage refinance calculator, home mortgage, mortgage calc, mortgage lenders, family opportunity mortgage, ralo ai mortgage broker funding, rocket mortgage, pennymac, phh mortgage, onity mortgage, rosegate mortgage, shellpoint mortgage, chase mortgage, bank of america mortgage, uwm mortgage, freedom mortgage, champion mortgage, guild mortgage, dhi mortgage, essex mortgage, roundpoint mortgage, united wholesale mortgage, bankrate mortgage, midland mortgage, cmg mortgage, lennar mortgage, dave ramsey mortgage, union home mortgage, interest rate, amortization, PITI, principal, property tax, home insurance, PMI, conventional loan, FHA loan, VA loan, jumbo loan, down payment, closing costs, APR, HELOC";
const { title, description, canonicalUrl, ogImage = '/og-default.png', keywords = defaultKeywords } = Astro.props;
const fullTitle = `${title} | MortgageDash`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MortgageDash" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Prevent FOUC: set theme before paint -->
    <script is:inline>
      (function () {
        const s = localStorage.getItem('theme');
        if (s === 'light') document.documentElement.classList.remove('dark');
        else if (s === 'dark') document.documentElement.classList.add('dark');
        else if (window.matchMedia && !window.matchMedia('(prefers-color-scheme: dark)').matches) {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>

  <body class="min-h-screen font-sans antialiased transition-colors duration-300 flex flex-col">
    <div class="aurora-bg"></div>
    <Header />
    
    <!-- 🛡️ BOT LAYOUT SHIELDING -->
    <div class="relative flex-grow flex flex-col pb-24 sm:pb-16">
      <main class="flex-grow">
        <slot />
      </main>
    </div>

    <Footer />
    <Chatbot />

    <!-- 🍪 COMPLIANT COOKIE CONSENT BANNER INTERFACE -->
    <div id="cookie-banner" class="fixed bottom-4 left-4 right-4 md:left-auto md:max-w-md bg-[var(--bg-surface)] border border-[var(--border-default)] shadow-2xl rounded-2xl p-5 z-[9999] hidden transform transition-all duration-300">
      <div class="flex flex-col gap-3">
        <div class="flex items-center gap-2">
          <span class="text-xl">🍪</span>
          <h4 class="text-sm font-bold text-[var(--text-primary)]">Cookie & Privacy Preferences</h4>
        </div>
        <p class="text-xs text-[var(--text-secondary)] leading-relaxed">
          MortgageDash and our partner Google use cookies to analyze web traffic and deliver personalized, relevant advertisements. You can modify your choices at any time.
        </p>
        <div class="flex items-center justify-end gap-2 mt-2">
          <button id="decline-cookies" class="px-3 py-1.5 text-xs font-semibold rounded-lg border border-[var(--border-default)] text-[var(--text-secondary)] hover:bg-[var(--bg-hover)] transition-colors">
            Decline
          </button>
          <button id="accept-cookies" class="px-4 py-1.5 text-xs font-semibold rounded-lg bg-gradient-to-r from-[#06b6d4] to-[#10b981] text-white shadow-md hover:opacity-90 transition-opacity">
            Accept All
          </button>
        </div>
      </div>
    </div>

    <script>
      // Global Range Slider Logic for styling
      function updateSliderProgress(slider: HTMLInputElement) {
        const min = parseFloat(slider.min) || 0;
        const max = parseFloat(slider.max) || 100;
        const val = parseFloat(slider.value) || 0;
        const percent = ((val - min) / (max - min)) * 100;
        slider.style.setProperty('--progress', `${percent}%`);
      }

      document.addEventListener('input', (e) => {
        if (e.target && (e.target as HTMLElement).matches('input[type="range"]')) {
          updateSliderProgress(e.target as HTMLInputElement);
        }
      });

      // Also run on Astro page load if using ViewTransitions, or standard load
      function initSliders() {
        document.querySelectorAll('input[type="range"]').forEach((el) => {
          updateSliderProgress(el as HTMLInputElement);
        });
      }
      
      const checkConsent = () => {
        const consentState = localStorage.getItem('mortgagedash_cookie_consent');
        const banner = document.getElementById('cookie-banner');
        
        if (!consentState && banner) {
          banner.classList.remove('hidden');
        }
      };

      document.addEventListener('DOMContentLoaded', () => {
        initSliders();
        checkConsent();

        document.getElementById('accept-cookies')?.addEventListener('click', () => {
          localStorage.setItem('mortgagedash_cookie_consent', 'granted');
          document.getElementById('cookie-banner')?.classList.add('hidden');
        });

        document.getElementById('decline-cookies')?.addEventListener('click', () => {
          localStorage.setItem('mortgagedash_cookie_consent', 'denied');
          document.getElementById('cookie-banner')?.classList.add('hidden');
        });
      });
    </script>
  </body>
</html>
