---
const currentYear = new Date().getFullYear();

const calculatorLinks = [
  { label: 'Mortgage Calculator', href: '/' },
  { label: 'Refinance Calculator', href: '/refinance-calculator' },
  { label: 'Affordability Calculator', href: '/how-much-can-i-afford' },
  { label: 'Extra Payments', href: '/extra-payment-calculator' },
  { label: 'Amortization Schedule', href: '/amortization-schedule' },
];

const stateLinks = [
  { label: 'Texas', href: '/states/texas' },
  { label: 'Florida', href: '/states/florida' },
  { label: 'California', href: '/states/california' },
  { label: 'New York', href: '/states/new-york' },
  { label: 'North Carolina', href: '/states/north-carolina' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Terms of Service', href: '/terms' },
  { label: 'About Us', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<footer style="background: var(--bg-footer); border-top: 1px solid var(--border-default);">
  <div class="mx-auto max-w-7xl px-6 pt-14 pb-32 lg:px-8">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4 lg:gap-16">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2 group" aria-label="MortgageDash home">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#06b6d4] transition-transform duration-200 group-hover:scale-105">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 10.5L12 3l9 7.5" />
              <path d="M5 9.5V19a1 1 0 001 1h12a1 1 0 001-1V9.5" />
              <polyline points="8,16 11,13 13.5,15 17,11" stroke-width="1.8" />
            </svg>
          </div>
          <span class="text-lg font-bold tracking-tight text-white">
            Mortgage<span class="text-[#06b6d4]">Dash</span>
          </span>
        </a>
        <p class="mt-4 text-sm leading-relaxed text-slate-400 max-w-xs">
          Smart mortgage calculations for every US state. Make confident home-buying decisions.
        </p>
        <p class="mt-6 text-xs text-slate-500">
          &copy; {currentYear} MortgageDash. All rights reserved.
        </p>
      </div>

      <!-- Calculators -->
      <nav aria-label="Calculator pages">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-400">Calculators</h3>
        <ul class="mt-4 space-y-3" role="list">
          {calculatorLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 transition-colors duration-200 hover:text-[#06b6d4]">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- States -->
      <nav aria-label="State resources">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-400">Top States</h3>
        <ul class="mt-4 space-y-3" role="list">
          {stateLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 transition-colors duration-200 hover:text-[#06b6d4]">
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/states" class="inline-flex items-center gap-1 text-sm font-medium text-[#06b6d4] hover:text-[#22d3ee] transition-colors">
              All 50 States →
            </a>
          </li>
        </ul>
      </nav>

      <!-- Legal -->
      <nav aria-label="Legal pages">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-400">Legal</h3>
        <ul class="mt-4 space-y-3" role="list">
          {legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 transition-colors duration-200 hover:text-[#06b6d4]">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

    </div>

    <!-- ⚠️ CRITICAL YMYL DISCLAIMER BOX -->
    <div class="mt-12 pt-8 border-t border-[var(--border-default)] text-xs text-slate-400 space-y-3 max-w-4xl mx-auto lg:mx-0">
      <p class="font-semibold text-slate-300 uppercase tracking-wider">Financial Disclaimer & Advertising Disclosure</p>
      <p style="line-height: 1.6;">
        MortgageDash is an independent, static educational resource and tool developer. The calculated configurations, projections, amortization schedules, and multi-state data vectors (including local property taxes, average home insurance metrics, and median market pricing arrays) provided across this domain are intended exclusively for informational, simulation, and illustrative purposes. 
      </p>
      <p style="line-height: 1.6;">
        Calculations are executed entirely via client-side financial formulas. They do not constitute official financing calculations, contractual offers, formal rate locks, real estate tracking indices, or definitive legal or investment advice. Always consult a certified, licensed financial planner, mortgage broker, or banking representative prior to committing to a home loan obligation.
      </p>
      <p style="line-height: 1.6;">
        <strong>Advertising Disclosure:</strong> This website serves programmatic advertisements managed via Google AdSense. Third-party vendors, including Google, utilize tracking cookies to optimize and serve targeted marketing assets based on an individual user's browsing profile across this and other platforms.
      </p>
    </div>
  </div>

  <!-- Bottom bar -->
  <div style="border-top: 1px solid rgba(148, 163, 184, 0.1);">
    <div class="mx-auto max-w-7xl px-6 py-5 lg:px-8 flex flex-col items-center justify-between gap-3 sm:flex-row">
      <p class="text-xs text-slate-500">
        Built with <span class="text-[#f43f5e]">&hearts;</span> for US homebuyers
      </p>
      <p class="text-xs text-slate-500">
        mortgagedash.app &middot; {currentYear}
      </p>
    </div>
  </div>
</footer>
