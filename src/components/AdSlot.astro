---
interface Props {
  type: 'leaderboard' | 'rectangle' | 'rectangle-lg' | 'sticky';
  class?: string;
}

const { type, class: className = '' } = Astro.props;

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID || 'ca-pub-XXXXXXXXXXXXXXXX';
const isRealAdEnabled = adsenseClient && adsenseClient !== 'ca-pub-XXXXXXXXXXXXXXXX';

const typeConfig = {
  leaderboard: {
    wrapper: 'w-full max-w-4xl mx-auto my-4',
    format: 'auto',
    style: 'display:block; min-height:90px;',
    slot: 'SLOT_LEADERBOARD',
    label: 'Leaderboard Ad (728x90 / Auto)'
  },
  rectangle: {
    wrapper: 'w-full max-w-4xl mx-auto my-6',
    format: 'auto',
    style: 'display:block; min-height:250px;',
    slot: 'SLOT_RECTANGLE',
    label: 'Medium Rectangle Ad (300x250 / Auto)'
  },
  'rectangle-lg': {
    wrapper: 'w-full max-w-4xl mx-auto my-6',
    format: 'auto',
    style: 'display:block; min-height:280px;',
    slot: 'SLOT_RECTANGLE_LG',
    label: 'Large Rectangle Ad (336x280 / Auto)'
  },
  sticky: {
    wrapper: '',
    format: 'auto',
    style: 'display:block; min-height:50px;',
    slot: 'SLOT_STICKY',
    label: 'Sticky Anchor Ad'
  },
};

const config = typeConfig[type];
---

{isRealAdEnabled ? (
  type === 'sticky' ? (
    <div
      id="sticky-ad-anchor"
      class={`fixed bottom-0 left-0 right-0 z-[9990] bg-[var(--bg-surface)] border-t border-[var(--border-default)] shadow-lg transition-transform duration-300 ${className}`}
      data-ad-type="sticky"
    >
      <div class="max-w-4xl mx-auto px-2 py-1 text-center">
        <ins
          class="adsbygoogle"
          style={config.style}
          data-ad-client={adsenseClient}
          data-ad-slot={config.slot}
          data-ad-format={config.format}
          data-full-width-responsive="true"
        ></ins>
      </div>
    </div>
  ) : (
    <div class={`${config.wrapper} ${className}`} data-ad-type={type}>
      <ins
        class="adsbygoogle"
        style={config.style}
        data-ad-client={adsenseClient}
        data-ad-slot={config.slot}
        data-ad-format={config.format}
        data-full-width-responsive="true"
      ></ins>
    </div>
  )
) : (
  type !== 'sticky' && (
    <div class={`${config.wrapper} ${className} flex items-center justify-center border border-dashed border-[var(--border-default)] bg-[var(--bg-surface-2)]/50 rounded-2xl p-6 text-xs text-[var(--text-muted)] transition-all`} style={config.style}>
      <div class="text-center">
        <p class="font-bold uppercase tracking-wider opacity-60">Sponsored Advertisement</p>
        <p class="mt-1 text-[var(--text-faint)]">{config.label}</p>
        <p class="mt-0.5 text-[var(--text-faint)] text-[10px]">Placeholder will activate once PUBLIC_ADSENSE_CLIENT_ID is set</p>
      </div>
    </div>
  )
)}
