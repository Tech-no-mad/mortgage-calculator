---
/**
 * EmailModal.astro - Glassmorphism email capture modal
 * Replaces the raw mailto: CTA with a proper lead capture form.
 * Stores emails in localStorage for now; ready for Mailchimp integration.
 */
---

<!-- Email Capture Modal Overlay -->
<div
  id="email-modal-overlay"
  class="fixed inset-0 z-[10000] hidden items-center justify-center p-4"
  style="background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);"
>
  <div
    id="email-modal"
    class="relative w-full max-w-md rounded-2xl p-8 shadow-2xl border transform transition-all duration-300 scale-95 opacity-0"
    style="background: var(--bg-surface); border-color: var(--border-default);"
  >
    <!-- Close button -->
    <button
      id="email-modal-close"
      class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full hover:bg-[var(--bg-hover)] transition-colors"
      style="color: var(--text-muted);"
      aria-label="Close modal"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Form State -->
    <div id="email-form-state">
      <!-- Icon -->
      <div class="flex justify-center mb-5">
        <div class="w-14 h-14 rounded-full flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-usa-blue), var(--color-usa-red));">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
      </div>

      <h3 id="email-modal-title" class="text-xl font-bold text-center mb-2" style="color: var(--text-primary);">
        Get Your Personalized Report
      </h3>
      <p class="text-sm text-center mb-6" style="color: var(--text-muted);">
        We'll email your full breakdown directly to your inbox.
      </p>

      <!-- Dynamic fields populated by JS -->
      <div id="email-modal-summary" class="rounded-xl p-4 mb-6 space-y-2 text-sm font-mono" style="background: var(--bg-surface-2); color: var(--text-secondary);">
        <!-- Populated dynamically -->
      </div>

      <form id="email-capture-form" class="space-y-4">
        <div class="relative">
          <input
            type="email"
            id="email-capture-input"
            required
            placeholder="you@example.com"
            class="calc-input w-full pl-10 font-mono"
            autocomplete="email"
          />
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4" style="color: var(--text-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207" />
          </svg>
        </div>
        <button
          id="email-submit-btn"
          type="submit"
          class="w-full py-3 rounded-xl text-white font-bold text-sm shadow-lg hover:opacity-90 transition-opacity flex justify-center items-center"
          style="background: linear-gradient(135deg, var(--color-usa-blue), var(--color-usa-red));"
        >
          <span id="email-submit-text">Send My Report →</span>
          <svg id="email-submit-spinner" class="hidden animate-spin ml-2 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>
        <p class="text-xs text-center" style="color: var(--text-muted);">No spam. Unsubscribe anytime.</p>
        <p id="email-error-message" class="hidden text-xs text-center text-red-500 font-medium"></p>
      </form>
    </div>

    <!-- Success State -->
    <div id="email-success-state" class="hidden text-center py-4">
      <div class="flex justify-center mb-4">
        <div class="w-16 h-16 rounded-full flex items-center justify-center bg-emerald-500/10">
          <svg class="w-8 h-8 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        </div>
      </div>
      <h3 class="text-xl font-bold mb-2" style="color: var(--text-primary);">Report Sent! 🎉</h3>
      <p class="text-sm mb-6" style="color: var(--text-muted);">Check your inbox for your personalized mortgage breakdown.</p>
      <button
        id="email-success-close"
        class="px-6 py-2 rounded-lg text-sm font-semibold border transition-colors hover:bg-[var(--bg-hover)]"
        style="border-color: var(--border-default); color: var(--text-secondary);"
      >
        Done
      </button>
    </div>
  </div>
</div>

<script>
  let currentEmailPayload: any = null;

  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.getElementById('email-modal-overlay');
    const modal = document.getElementById('email-modal');
    const closeBtn = document.getElementById('email-modal-close');
    const form = document.getElementById('email-capture-form') as HTMLFormElement;
    const formState = document.getElementById('email-form-state');
    const successState = document.getElementById('email-success-state');
    const successClose = document.getElementById('email-success-close');
    const emailInput = document.getElementById('email-capture-input') as HTMLInputElement;

    // Expose open function globally
    (window as any).__openEmailModal = function(options: any) {
      if (!overlay || !modal) return;
      
      currentEmailPayload = options || {};
      
      // Update Title
      const titleEl = document.getElementById('email-modal-title');
      if (titleEl && options.title) {
        titleEl.textContent = options.title;
      }

      // Update Summary Fields
      const summaryContainer = document.getElementById('email-modal-summary');
      if (summaryContainer) {
        summaryContainer.innerHTML = '';
        if (options.fields && Array.isArray(options.fields)) {
          options.fields.forEach((f: any) => {
            const row = document.createElement('div');
            row.className = 'flex justify-between';
            const labelSpan = document.createElement('span');
            labelSpan.textContent = f.label;
            const valueSpan = document.createElement('span');
            valueSpan.textContent = f.value;
            if (f.highlight) {
              valueSpan.className = 'font-semibold';
              valueSpan.style.color = 'var(--text-primary)';
            }
            row.appendChild(labelSpan);
            row.appendChild(valueSpan);
            summaryContainer.appendChild(row);
          });
        }
      }

      overlay.classList.remove('hidden');
      overlay.classList.add('flex');
      
      requestAnimationFrame(() => {
        modal.classList.remove('scale-95', 'opacity-0');
        modal.classList.add('scale-100', 'opacity-100');
        emailInput?.focus();
      });
    };

    function closeModal() {
      if (!overlay || !modal) return;
      modal.classList.remove('scale-100', 'opacity-100');
      modal.classList.add('scale-95', 'opacity-0');
      setTimeout(() => {
        overlay.classList.add('hidden');
        overlay.classList.remove('flex');
        // Reset to form state
        if (formState) formState.classList.remove('hidden');
        if (successState) successState.classList.add('hidden');
      }, 200);
    }



    closeBtn?.addEventListener('click', closeModal);
    successClose?.addEventListener('click', closeModal);
    overlay?.addEventListener('click', (e) => {
      if (e.target === overlay) closeModal();
    });

    // Handle ESC key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay && !overlay.classList.contains('hidden')) {
        closeModal();
      }
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('email-capture-input') as HTMLInputElement;
      const email = emailInput?.value?.trim();
      if (!email) return;

      const submitBtn = document.getElementById('email-submit-btn') as HTMLButtonElement;
      const submitText = document.getElementById('email-submit-text');
      const submitSpinner = document.getElementById('email-submit-spinner');
      const errorMessage = document.getElementById('email-error-message');

      // Set loading state
      if (submitBtn) submitBtn.disabled = true;
      if (submitText) submitText.textContent = "Sending...";
      if (submitSpinner) submitSpinner.classList.remove('hidden');
      if (errorMessage) errorMessage.classList.add('hidden');

      try {
        const payload = {
          email,
          title: currentEmailPayload?.title || "Your Breakdown",
          fields: currentEmailPayload?.fields || []
        };

        const res = await fetch('/api/send-breakdown', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        const data = await res.json();
        
        if (!res.ok) {
          throw new Error(data.error || "Failed to send email");
        }

        // Store in localStorage as backup
        const stored = JSON.parse(localStorage.getItem('mortgagedash_emails') || '[]');
        stored.push({ email, timestamp: new Date().toISOString() });
        localStorage.setItem('mortgagedash_emails', JSON.stringify(stored));

        // Show success state
        if (formState) formState.classList.add('hidden');
        if (successState) successState.classList.remove('hidden');

        // Clear the input
        emailInput.value = '';

      } catch (err: any) {
        if (errorMessage) {
          errorMessage.textContent = err.message || "An error occurred while sending the email.";
          errorMessage.classList.remove('hidden');
        }
      } finally {
        // Reset loading state
        if (submitBtn) submitBtn.disabled = false;
        if (submitText) submitText.textContent = "Send My Report →";
        if (submitSpinner) submitSpinner.classList.add('hidden');
      }
    });
  });
</script>
