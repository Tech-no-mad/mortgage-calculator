---
const currentPath = Astro.url.pathname;
const navLinks = [
  { label: "Calculator", href: "/" },
  { label: "Affordability", href: "/how-much-can-i-afford" },
  { label: "Extra Payments", href: "/extra-payment-calculator" },
  { label: "States", href: "/states" },
  { label: "Brokers", href: "/brokers" },
  { label: "FAQ", href: "/faq" },
];
const moreTools = [
  { label: "Refinance", href: "/refinance-calculator" },
  { label: "Amortization", href: "/amortization-schedule" },
  { label: "Recast Calculator", href: "/recast-calculator" },
  { label: "HELOC Calculator", href: "/heloc-calculator" },
  { label: "FHA Loans", href: "/fha-loans" },
  { label: "VA Loans", href: "/va-loans" },
  { label: "Jumbo Loans", href: "/jumbo-loans" },
];
function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/" || currentPath === "";
  return currentPath.startsWith(href);
}
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl transition-all duration-300"
  style="background: var(--bg-header); border-bottom: 1px solid var(--border-default);"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group" aria-label="MortgageDash Home">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-[#06b6d4] transition-transform duration-200 group-hover:scale-105">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 10.5L12 3l9 7.5" />
          <path d="M5 9.5V19a1 1 0 001 1h12a1 1 0 001-1V9.5" />
          <polyline points="8,16 11,13 13.5,15 17,11" stroke-width="1.8" />
        </svg>
      </div>
      <span class="text-lg font-bold tracking-tight" style="color: var(--text-primary);">
        Mortgage<span class="text-[#06b6d4]">Dash</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center gap-1 lg:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "rounded-lg px-3 py-2 text-sm font-medium transition-colors duration-200",
            isActive(link.href) ? "text-[#06b6d4]" : "",
          ]}
          style={!isActive(link.href) ? "color: var(--text-muted);" : ""}
        >
          {link.label}
        </a>
      ))}
      
      <!-- Dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium transition-colors duration-200" style="color: var(--text-muted);">
          More Tools
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        <div class="absolute left-0 top-full pt-2 w-48 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
          <div class="py-2 flex flex-col rounded-xl shadow-xl border" style="background: var(--bg-surface-2); border-color: var(--border-default);">
            {moreTools.map((tool) => (
              <a href={tool.href} class="px-4 py-2 text-sm transition-colors hover:bg-black/5 dark:hover:bg-white/5" style="color: var(--text-primary);">
                {tool.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Right: theme toggle + mobile menu -->
    <div class="flex items-center gap-2">
      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        type="button"
        class="flex h-9 w-9 items-center justify-center rounded-lg transition-colors duration-200"
        style="color: var(--text-muted);"
        aria-label="Toggle dark mode"
      >
        <svg id="theme-icon-sun" class="h-5 w-5 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5" />
          <line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" />
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
          <line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" />
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
        </svg>
        <svg id="theme-icon-moon" class="absolute h-5 w-5 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
        </svg>
      </button>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="flex h-9 w-9 items-center justify-center rounded-lg lg:hidden transition-colors"
        style="color: var(--text-muted);"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="menu-icon-open" class="h-5 w-5 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg id="menu-icon-close" class="absolute h-5 w-5 scale-0 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 lg:hidden">
    <div class="overflow-hidden">
      <div class="px-4 py-3 sm:px-6" style="border-top: 1px solid var(--border-default);">
        <div class="flex flex-col gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                "rounded-lg px-3 py-2.5 text-sm font-medium transition-colors",
                isActive(link.href) ? "text-[#06b6d4]" : "",
              ]}
              style={!isActive(link.href) ? "color: var(--text-muted);" : ""}
            >
              {link.label}
            </a>
          ))}
          <div class="pt-2 mt-2" style="border-top: 1px solid var(--border-subtle);">
            <span class="px-3 py-1 text-xs font-semibold uppercase tracking-wider text-slate-400">More Tools</span>
            {moreTools.map((tool) => (
              <a href={tool.href} class="block rounded-lg px-3 py-2 text-sm font-medium transition-colors" style="color: var(--text-muted);">
                {tool.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- Spacer -->
<div class="h-[57px]"></div>

<script>
  function initHeader() {
    const toggle = document.getElementById("theme-toggle");
    const sunIcon = document.getElementById("theme-icon-sun") as HTMLElement;
    const moonIcon = document.getElementById("theme-icon-moon") as HTMLElement;
    const menuBtn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const iconOpen = document.getElementById("menu-icon-open") as HTMLElement;
    const iconClose = document.getElementById("menu-icon-close") as HTMLElement;

    // Theme toggle
    function applyIcons(isDark: boolean) {
      if (!sunIcon || !moonIcon) return;
      sunIcon.style.transform = isDark ? "rotate(0deg) scale(1)" : "rotate(-90deg) scale(0)";
      sunIcon.style.opacity = isDark ? "1" : "0";
      moonIcon.style.transform = isDark ? "rotate(90deg) scale(0)" : "rotate(0deg) scale(1)";
      moonIcon.style.opacity = isDark ? "0" : "1";
    }

    applyIcons(document.documentElement.classList.contains("dark"));

    toggle?.addEventListener("click", () => {
      const isDark = document.documentElement.classList.contains("dark");
      document.documentElement.classList.toggle("dark", !isDark);
      localStorage.setItem("theme", !isDark ? "dark" : "light");
      applyIcons(!isDark);
    });

    // Mobile menu
    let isOpen = false;
    menuBtn?.addEventListener("click", () => {
      isOpen = !isOpen;
      menuBtn.setAttribute("aria-expanded", String(isOpen));
      if (menu) menu.style.gridTemplateRows = isOpen ? "1fr" : "0fr";
      if (iconOpen) iconOpen.style.transform = isOpen ? "rotate(90deg) scale(0)" : "rotate(0deg) scale(1)";
      if (iconClose) iconClose.style.transform = isOpen ? "rotate(0deg) scale(1)" : "rotate(-90deg) scale(0)";
    });

    menu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        isOpen = false;
        menuBtn?.setAttribute("aria-expanded", "false");
        if (menu) menu.style.gridTemplateRows = "0fr";
        if (iconOpen) iconOpen.style.transform = "rotate(0deg) scale(1)";
        if (iconClose) iconClose.style.transform = "rotate(-90deg) scale(0)";
      });
    });

    // Scroll shadow
    const header = document.getElementById("site-header");
    window.addEventListener("scroll", () => {
      header?.classList.toggle("shadow-lg", window.scrollY > 10);
    }, { passive: true });
  }

  initHeader();
  document.addEventListener("astro:page-load", initHeader);
</script>
