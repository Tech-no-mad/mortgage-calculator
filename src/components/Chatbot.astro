---
---

<!-- Chatbot Toggle Button -->
<button 
  id="chatbot-toggle" 
  class="fixed bottom-6 right-6 w-14 h-14 rounded-full bg-gradient-to-r from-[var(--color-usa-blue)] to-[var(--color-usa-red)] text-white shadow-lg flex items-center justify-center hover:shadow-xl transition-all z-50 focus:outline-none focus:ring-4 focus:ring-[var(--color-usa-blue)]/30 transform hover:scale-105"
  aria-label="Open Mortgage Assistant"
  data-step="99"
  data-tooltip="Chatbot: Try 'Calculate $500k home in Texas' or 'Show commercial loans'"
>
  <!-- Ripple Animation Background -->
  <span class="absolute inset-0 rounded-full bg-[var(--color-usa-blue)] opacity-75 animate-ping" style="animation-duration: 2s;"></span>
  
  <!-- Robot/AI Icon -->
  <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    <path stroke-linecap="round" stroke-linejoin="round" d="M9 9h.01M15 9h.01" />
  </svg>
</button>

<!-- Chatbot Window -->
<div 
  id="chatbot-window" 
  class="fixed bottom-24 right-6 w-[calc(100vw-2rem)] sm:w-96 rounded-2xl shadow-2xl flex flex-col overflow-hidden z-50 transition-all duration-300 opacity-0 pointer-events-none translate-y-4 border border-slate-200 dark:border-slate-700"
  style="background: var(--bg-surface); min-height: 250px; max-height: 75vh; height: auto;"
>
  <!-- Header -->
  <div class="px-5 py-4 flex justify-between items-center bg-gradient-to-r from-[var(--color-usa-blue)] to-[var(--color-usa-red)] text-white">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center shadow-inner">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 9h.01M15 9h.01" />
        </svg>
      </div>
      <div>
        <h3 class="font-bold text-sm">Mortgage AI Assistant</h3>
        <p class="text-xs text-white/90">Assistant</p>
      </div>
    </div>
    <div class="flex gap-1">
      <button id="chatbot-maximize" class="p-1 text-white/80 hover:text-white transition-colors focus:outline-none hidden sm:block" aria-label="Toggle Fullscreen">
        <svg id="icon-expand" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
        </svg>
        <svg id="icon-shrink" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V5m0 4H5m4 0L4 4M15 9V5m0 4h4m-4 0l5-5M9 15v4m0-4H5m4 0l-5 5M15 15v4m0-4h4m-4 0l5 5" />
        </svg>
      </button>
      <button id="chatbot-close" class="p-1 text-white/80 hover:text-white transition-colors focus:outline-none" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Chat History -->
  <div id="chatbot-messages" class="flex-1 p-5 overflow-y-auto space-y-5" style="background: var(--bg-surface-2);">
    <!-- Initial Greeting -->
    <div class="flex items-end gap-2.5">
      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[var(--color-usa-blue)] to-[var(--color-usa-red)] flex-shrink-0 flex items-center justify-center text-white shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 9h.01M15 9h.01" />
        </svg>
      </div>
      <div class="p-3.5 rounded-2xl rounded-bl-none shadow-sm text-sm leading-relaxed" style="background: var(--bg-surface-2); color: var(--text-primary); border: 1px solid var(--border-default);">
        Hi! I can help you calculate mortgage payments, navigate our tools, and answer home-buying questions. Try: "Take me to the reverse mortgage calculator", "Set home price to 500k in Texas", or "What is the property tax in Florida?"
      </div>
    </div>
  </div>

  <!-- Input Area -->
  <div class="p-4" style="background: var(--bg-surface); border-top: 1px solid var(--border-default);">
    <form id="chatbot-form" class="flex gap-2 relative">
      <textarea 
        id="chatbot-input" 
        rows="1"
        class="flex-1 pl-4 pr-12 py-3 text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-[var(--color-usa-blue)] resize-none" 
        style="background: var(--bg-surface-2); border: 1px solid var(--border-default); color: var(--text-primary); max-height: 120px; overflow-y: auto;"
        placeholder="Ask me anything..." 
        aria-label="Chatbot input message"
      ></textarea>
      <button 
        type="submit" 
        class="absolute right-1.5 top-1.5 bottom-1.5 w-9 rounded-lg bg-[var(--color-usa-blue)] text-white flex items-center justify-center transition-colors focus:outline-none"
        aria-label="Send message"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </button>
    </form>
  </div>
</div>

<script>
  const toggleBtn = document.getElementById('chatbot-toggle');
  const closeBtn = document.getElementById('chatbot-close');
  const windowEl = document.getElementById('chatbot-window');
  const form = document.getElementById('chatbot-form');
  const input = document.getElementById('chatbot-input') as HTMLTextAreaElement;
  const messagesContainer = document.getElementById('chatbot-messages');

  const maximizeBtn = document.getElementById('chatbot-maximize');
  const iconExpand = document.getElementById('icon-expand');
  const iconShrink = document.getElementById('icon-shrink');

  if (input) {
    input.addEventListener('input', function() {
      this.style.height = 'auto';
      this.style.height = (this.scrollHeight) + 'px';
    });
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form?.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
      }
    });
  }

  let isOpen = sessionStorage.getItem('chatbotOpen') === 'true';
  let chatHistory: Array<{text: string, isUser: boolean}> = [];
  let chatContext: any = null; // Lightweight conversational memory state
  let sessionMap: Record<string, string> = {}; // Edge-ready stateless learning memory

  maximizeBtn?.addEventListener('click', () => {
    windowEl?.classList.toggle('maximized-view');
    
    if (windowEl?.classList.contains('maximized-view')) {
       iconExpand?.classList.add('hidden');
       iconShrink?.classList.remove('hidden');
    } else {
       iconExpand?.classList.remove('hidden');
       iconShrink?.classList.add('hidden');
    }
  });

  function toggleChat(forceState?: boolean) {
    isOpen = forceState !== undefined ? forceState : !isOpen;
    sessionStorage.setItem('chatbotOpen', isOpen.toString());
    if (isOpen) {
      windowEl?.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
      document.body.classList.add('chatbot-open');
      input?.focus();
    } else {
      windowEl?.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
      document.body.classList.remove('chatbot-open');
    }
  }

  // Set initial state
  if (isOpen) {
    document.body.classList.add('chatbot-open');
  }

  toggleBtn?.addEventListener('click', () => toggleChat());
  closeBtn?.addEventListener('click', () => toggleChat(false));

  function saveHistory() {
    sessionStorage.setItem('chatbotHistory', JSON.stringify(chatHistory));
    if (chatContext) sessionStorage.setItem('chatbotContext', JSON.stringify(chatContext));
    else sessionStorage.removeItem('chatbotContext');
    sessionStorage.setItem('chatbotSessionMap', JSON.stringify(sessionMap));
  }

  function renderMessage(text: string, isUser: boolean, animate = true) {
    if (!messagesContainer) return;
    
    const div = document.createElement('div');
    div.className = `flex items-end gap-2.5 ${isUser ? 'flex-row-reverse' : ''} ${animate ? 'animate-fade-in' : ''}`;
    
    let avatar = isUser ? `
        <div class="w-8 h-8 rounded-full bg-slate-200 dark:bg-slate-700 flex-shrink-0 flex items-center justify-center text-slate-500 dark:text-slate-400 pb-[1px]">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
        </div>
      ` : `
        <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[var(--color-usa-blue)] to-[var(--color-usa-red)] flex-shrink-0 flex items-center justify-center text-white shadow-sm">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9h.01M15 9h.01" />
          </svg>
        </div>
      `;

    let formattedText = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    formattedText = formattedText.replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" class="underline text-current font-semibold hover:opacity-80 transition-opacity">$1</a>');
    formattedText = formattedText.replace(/\n/g, '<br/>');

    const bubbleClass = isUser 
      ? `bg-gradient-to-r from-[var(--color-usa-blue)] to-[var(--color-usa-red)] text-white p-3.5 rounded-2xl rounded-br-none shadow-sm text-sm leading-relaxed`
      : `p-3.5 rounded-2xl rounded-bl-none shadow-sm text-sm leading-relaxed`;
      
    const botStyle = isUser ? '' : 'background: var(--bg-surface-2); color: var(--text-primary); border: 1px solid var(--border-default);';

    div.innerHTML = `
      ${avatar}
      <div class="${bubbleClass}" style="max-width: 80%; ${botStyle}">
        ${formattedText}
      </div>
    `;

    messagesContainer.appendChild(div);
    messagesContainer.scrollTop = messagesContainer.scrollHeight;
  }

  function addMessage(text: string, isUser: boolean) {
    chatHistory.push({ text, isUser });
    saveHistory();
    renderMessage(text, isUser, true);
  }

  document.addEventListener('DOMContentLoaded', () => {
    const storedHistory = sessionStorage.getItem('chatbotHistory');
    if (storedHistory && messagesContainer) {
      try {
        const parsed = JSON.parse(storedHistory);
        if (parsed.length > 0) {
          chatHistory = parsed;
          messagesContainer.innerHTML = '';
          chatHistory.forEach(msg => renderMessage(msg.text, msg.isUser, false));
        }
      } catch(e) {}
    }
    const storedCtx = sessionStorage.getItem('chatbotContext');
    if (storedCtx) {
      try { chatContext = JSON.parse(storedCtx); } catch(e) {}
    }
    const storedMap = sessionStorage.getItem('chatbotSessionMap');
    if (storedMap) {
      try { sessionMap = JSON.parse(storedMap); } catch(e) {}
    }

    // Always inject the current page path as the Active Scope
    if (!chatContext) chatContext = {};
    chatContext.activeScope = window.location.pathname;

    if (isOpen) toggleChat(true);

    const pendingFill = sessionStorage.getItem('pendingAutofill');
    if (pendingFill) {
      // Delay to ensure the calculator's DOMContentLoaded runs first
      setTimeout(() => {
        try {
          const payload = JSON.parse(pendingFill);
          let updated = false;
          payload.forEach((fill: any) => {
            for (const id of fill.id) {
              if (id === 'term') {
                const btn = document.querySelector(`.term-btn[data-term="${fill.value}"]`) as HTMLElement;
                if (btn) { btn.click(); updated = true; }
                const sel = document.getElementById('loan-term') as HTMLSelectElement;
                if (sel) { sel.value = fill.value; sel.dispatchEvent(new Event('change', { bubbles: true })); updated = true; }
              } else if (id === 'down-payment') {
                let v = parseFloat(fill.value);
                if (v > 100) {
                   const dEl = document.getElementById('down-payment-dollar-input') as HTMLInputElement;
                   if (dEl) { dEl.value = v.toString(); dEl.dispatchEvent(new Event('change', { bubbles: true })); updated = true; }
                } else {
                   const pEl = document.getElementById('down-payment-input') as HTMLInputElement;
                   if (pEl) { pEl.value = v.toString(); pEl.dispatchEvent(new Event('change', { bubbles: true })); updated = true; }
                   const el = document.getElementById(id) as HTMLInputElement;
                   if (el) { el.value = v.toString(); el.dispatchEvent(new Event('input', {bubbles: true})); }
                }
              } else {
                const el = document.getElementById(id);
                if (el) {
                  (el as HTMLInputElement).value = fill.value;
                  updated = true;
                }
              }
            }
          });
          if (updated) {
            const ev = new Event('change', { bubbles: true });
            const inputEv = new Event('input', { bubbles: true });
            ['home-price', 'loan-amount', 'down-payment', 'interest-rate', 'state-selector'].forEach(id => {
              document.getElementById(id)?.dispatchEvent(inputEv);
              document.getElementById(id)?.dispatchEvent(ev);
            });
            sessionStorage.removeItem('pendingAutofill');
            toggleChat(true); 
          }
        } catch(e) {
          console.error('Failed to parse pending autofill', e);
        }
      }, 50);
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!input) return;
    const text = input.value.trim();
    if (!text) return;

    addMessage(text, true);
    input.value = '';
    input.style.height = 'auto'; 

    const typingId = 'typing-' + Date.now();
    const typingDiv = document.createElement('div');
    typingDiv.id = typingId;
    typingDiv.className = `flex items-end gap-2.5`;
    typingDiv.innerHTML = `
      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[var(--color-usa-blue)] to-[var(--color-usa-red)] flex-shrink-0 flex items-center justify-center text-white shadow-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 9h.01M15 9h.01" />
        </svg>
      </div>
      <div class="p-3.5 rounded-2xl rounded-bl-none shadow-sm text-sm flex gap-1 items-center h-10" style="background: var(--bg-surface-2); color: var(--text-primary); border: 1px solid var(--border-default);">
        <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 0ms;"></div>
        <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 150ms;"></div>
        <div class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 300ms;"></div>
      </div>
    `;
    messagesContainer?.appendChild(typingDiv);
    messagesContainer!.scrollTop = messagesContainer!.scrollHeight;

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ query: text, history: chatContext, sessionMap: sessionMap })
      });
      const data = await res.json();
      
      document.getElementById(typingId)?.remove();
      addMessage(data.response, false);
      
      let shouldSave = false;

      // Update compressed context memory
      if (data.context !== undefined) {
        chatContext = data.context;
        shouldSave = true;
      }

      // Update stateless memory (RLHF Learning)
      if (data.updateSessionMap) {
        sessionMap[data.updateSessionMap.key] = data.updateSessionMap.value;
        shouldSave = true;
      }

      if (shouldSave) saveHistory();

      if (data.actions && Array.isArray(data.actions)) {
        let shouldNavigate = false;
        let navigateUrl = '';
        let hasFills = false;
        let fillsPayload = null;

        data.actions.forEach((action: any) => {
          if (action.type === 'navigate') {
            shouldNavigate = true;
            navigateUrl = action.payload;
          } else if (action.type === 'fill') {
            hasFills = true;
            fillsPayload = action.payload;
          }
        });

        if (shouldNavigate) {
          if (hasFills) {
            sessionStorage.setItem('pendingAutofill', JSON.stringify(fillsPayload));
          }
          setTimeout(() => { window.location.href = navigateUrl; }, 1500);
        } else if (hasFills) {
          let updated = false;
          fillsPayload.forEach((fill: any) => {
            for (const id of fill.id) {
              if (id === 'term') {
                const btn = document.querySelector(`.term-btn[data-term="${fill.value}"]`) as HTMLElement;
                if (btn) { btn.click(); updated = true; }
                const sel = document.getElementById('loan-term') as HTMLSelectElement;
                if (sel) { sel.value = fill.value; sel.dispatchEvent(new Event('change', { bubbles: true })); updated = true; }
              } else if (id === 'down-payment') {
                let v = parseFloat(fill.value);
                if (v > 100) {
                   const dEl = document.getElementById('down-payment-dollar-input') as HTMLInputElement;
                   if (dEl) { dEl.value = v.toString(); dEl.dispatchEvent(new Event('change', { bubbles: true })); updated = true; }
                } else {
                   const pEl = document.getElementById('down-payment-input') as HTMLInputElement;
                   if (pEl) { pEl.value = v.toString(); pEl.dispatchEvent(new Event('change', { bubbles: true })); updated = true; }
                   const el = document.getElementById(id) as HTMLInputElement;
                   if (el) { el.value = v.toString(); el.dispatchEvent(new Event('input', {bubbles: true})); }
                }
              } else {
                const el = document.getElementById(id);
                if (el) {
                  (el as HTMLInputElement).value = fill.value;
                  updated = true;
                }
              }
            }
          });
          
          if (updated) {
            const ev = new Event('change');
            const inputEv = new Event('input');
            ['home-price', 'loan-amount', 'down-payment', 'interest-rate', 'state-selector'].forEach(id => {
              document.getElementById(id)?.dispatchEvent(inputEv);
              document.getElementById(id)?.dispatchEvent(ev);
            });
          } else {
            sessionStorage.setItem('pendingAutofill', JSON.stringify(fillsPayload));
            setTimeout(() => { window.location.href = '/'; }, 1000);
          }
        }
      } else if (data.action) {
         // Legacy single action support just in case
         if (data.action.type === 'navigate') {
           setTimeout(() => { window.location.href = data.action.payload; }, 1500);
         }
      }
    } catch (e) {
      document.getElementById(typingId)?.remove();
      addMessage("Sorry, I'm having trouble connecting to the server.", false);
    }
  });
</script>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.2s ease-out forwards;
  }
  
  .maximized-view {
    width: calc(100vw - 2rem) !important;
    height: calc(100vh - 2rem) !important;
    max-height: calc(100vh - 2rem) !important;
    bottom: 1rem !important;
    right: 1rem !important;
    border-radius: 1rem !important;
    border: 1px solid var(--color-usa-blue) !important;
    z-index: 9999 !important;
  }
  
  /* Mobile Adjustments */
  @media (max-width: 640px) {
    #chatbot-window {
      width: calc(100vw - 2rem) !important;
      right: 1rem !important;
    }
  }
</style>
