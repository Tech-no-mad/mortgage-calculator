---
import states from '../data/states.json';
import counties from '../data/counties.json';

// Build a slim dictionary of states for the client side autocomplete
const searchDict = states.map(s => ({ name: s.name, slug: s.slug }));

// Build a slim dictionary of counties
const countiesDict = [];
const stateAbbrMap = {};
states.forEach(s => { stateAbbrMap[s.slug] = s.abbr; });

Object.keys(counties).forEach(stateSlug => {
  const stateCounties = counties[stateSlug];
  const abbr = stateAbbrMap[stateSlug] || stateSlug;
  stateCounties.forEach(c => {
    const countySlug = c.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
    countiesDict.push({
      name: `${c.name}, ${abbr}`,
      url: `/states/${stateSlug}/${countySlug}/`
    });
  });
});

// Region mapping for the specific user request ("western could mean connecticut etc thes=se are examples search for more")
const regions = [
  { name: 'Western', matches: ['california', 'oregon', 'washington', 'nevada', 'arizona', 'utah', 'idaho', 'montana', 'wyoming', 'colorado', 'new-mexico'] },
  { name: 'Northeast', matches: ['new-york', 'pennsylvania', 'new-jersey', 'massachusetts', 'connecticut', 'rhode-island', 'vermont', 'new-hampshire', 'maine'] },
  { name: 'Midwest', matches: ['illinois', 'ohio', 'michigan', 'indiana', 'wisconsin', 'iowa', 'minnesota', 'missouri', 'north-dakota', 'south-dakota', 'nebraska', 'kansas'] },
  { name: 'South', matches: ['texas', 'florida', 'georgia', 'north-carolina', 'virginia', 'tennessee', 'maryland', 'south-carolina', 'alabama', 'louisiana', 'kentucky', 'oklahoma', 'arkansas', 'mississippi', 'west-virginia'] }
];
---

<!-- Chatbot is strictly for navigation now, no Puter.js -->

<!-- Pass data to client -->
<script is:inline define:vars={{ searchDict, countiesDict, regions }}>
  window.chatbotData = { searchDict, countiesDict, regions };
</script>

<!-- Chatbot UI -->
<div id="chatbot-container" class="fixed bottom-6 right-6 z-50 flex flex-col items-end">
  
  <!-- Chat Window -->
  <div id="chat-window" class="hidden flex-col w-[350px] max-h-[500px] h-[70vh] sm:w-[400px] bg-[var(--bg-surface)] border border-[var(--border-default)] rounded-2xl shadow-2xl mb-4 overflow-hidden transition-all duration-300 transform origin-bottom-right scale-95 opacity-0">
    
    <!-- Header -->
    <div class="bg-[var(--color-usa-blue)] text-white p-4 flex justify-between items-center shrink-0">
      <div class="flex items-center gap-2">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        <h3 class="font-bold">Mortgage AI Expert</h3>
      </div>
      <button id="chat-close" class="hover:bg-white/20 p-1 rounded transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>

    <!-- Message History -->
    <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-4 bg-[var(--bg-primary)]">
      <!-- Welcome Message -->
      <div class="flex gap-2">
        <div class="w-8 h-8 rounded-full bg-[var(--color-usa-blue)] flex items-center justify-center text-white shrink-0">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <div class="bg-[var(--bg-surface)] border border-[var(--border-default)] p-3 rounded-2xl rounded-tl-none shadow-sm text-sm text-[var(--text-primary)]">
          Hi! I can answer mortgage questions or help you find local county data. Try asking a question or typing a region like "Western"!
        </div>
      </div>
    </div>

    <!-- Autocomplete Popup -->
    <div id="chat-autocomplete" class="hidden absolute bottom-16 left-0 w-full bg-[var(--bg-surface)] border-t border-[var(--border-default)] shadow-lg max-h-40 overflow-y-auto z-10 p-2">
      <!-- Options injected via JS -->
    </div>

    <!-- Input Area -->
    <div class="p-3 bg-[var(--bg-surface)] border-t border-[var(--border-default)] shrink-0 relative">
      <form id="chat-form" class="flex items-center gap-2">
        <input type="text" id="chat-input" placeholder="Ask a question or find a state..." class="flex-1 bg-[var(--bg-input)] border border-[var(--border-default)] rounded-xl px-4 py-2.5 text-sm text-[var(--text-primary)] focus:ring-2 focus:ring-[var(--color-usa-blue)] outline-none" autocomplete="off" />
        <button type="submit" class="bg-[var(--color-usa-blue)] text-white p-2.5 rounded-xl hover:bg-opacity-90 transition disabled:opacity-50">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
        </button>
      </form>
    </div>
  </div>

  <!-- Floating Toggle Button -->
  <button id="chat-toggle" class="bg-[var(--color-usa-blue)] hover:bg-[#1e4b87] text-white p-4 rounded-full shadow-xl transition-transform hover:scale-110 active:scale-95 flex items-center justify-center group">
    <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
  </button>

</div>

<script is:inline>
  (function initChatbot() {
    const container = document.getElementById('chatbot-container');
    const toggleBtn = document.getElementById('chat-toggle');
    const closeBtn = document.getElementById('chat-close');
    const windowEl = document.getElementById('chat-window');
    const messagesEl = document.getElementById('chat-messages');
    const form = document.getElementById('chat-form');
    const input = document.getElementById('chat-input');
    const autocomplete = document.getElementById('chat-autocomplete');
    
    let isOpen = false;
    let messageHistory = [
      { role: "system", content: "You are the MortgageDash AI expert. Answer mortgage questions clearly and concisely. If a user asks about local rates or areas, tell them they can navigate to our state and county pages for exact data. Use markdown for bolding and lists, but do NOT use html. If you mention a state, provide a markdown link to it like [California](/states/california/). Be extremely helpful." }
    ];

    function toggleChat() {
      isOpen = !isOpen;
      if (isOpen) {
        windowEl.classList.remove('hidden');
        // trigger reflow
        void windowEl.offsetWidth;
        windowEl.classList.remove('scale-95', 'opacity-0');
        windowEl.classList.add('scale-100', 'opacity-100', 'flex');
        toggleBtn.classList.add('hidden');
        input.focus();
      } else {
        windowEl.classList.remove('scale-100', 'opacity-100');
        windowEl.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
          windowEl.classList.add('hidden');
          windowEl.classList.remove('flex');
          toggleBtn.classList.remove('hidden');
        }, 300);
      }
    }

    toggleBtn.addEventListener('click', toggleChat);
    closeBtn.addEventListener('click', toggleChat);

    function addMessage(text, isUser = false) {
      const div = document.createElement('div');
      div.className = `flex gap-2 ${isUser ? 'flex-row-reverse' : ''}`;
      
      const avatar = document.createElement('div');
      avatar.className = `w-8 h-8 rounded-full flex items-center justify-center shrink-0 text-white ${isUser ? 'bg-[var(--color-emerald)]' : 'bg-[var(--color-usa-blue)]'}`;
      avatar.innerHTML = isUser 
        ? '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>'
        : '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>';
      
      const bubble = document.createElement('div');
      bubble.className = `bg-[var(--bg-surface)] border border-[var(--border-default)] p-3 rounded-2xl shadow-sm text-sm text-[var(--text-primary)] ${isUser ? 'rounded-tr-none bg-[var(--bg-input)]' : 'rounded-tl-none'}`;
      
      // Basic markdown link parsing for AI responses
      let parsedText = text.replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" class="text-blue-600 dark:text-blue-400 hover:underline">$1</a>');
      // Basic bold parsing
      parsedText = parsedText.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
      // Basic newlines
      parsedText = parsedText.replace(/\n/g, '<br/>');

      bubble.innerHTML = parsedText;
      
      div.appendChild(avatar);
      div.appendChild(bubble);
      messagesEl.appendChild(div);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      
      return bubble; // Return so we can update it during streaming
    }

    // Autocomplete Logic
    input.addEventListener('input', (e) => {
      const val = e.target.value.toLowerCase().trim();
      autocomplete.innerHTML = '';
      if (val.length < 2) {
        autocomplete.classList.add('hidden');
        return;
      }

      let matches = [];
      const { searchDict, countiesDict, regions } = window.chatbotData;

      // Check regions
      regions.forEach(r => {
        if (r.name.toLowerCase().includes(val)) {
          matches.push({ type: 'region', label: `${r.name} Region`, links: r.matches });
        }
      });

      // Check states
      searchDict.forEach(s => {
        if (s.name.toLowerCase().includes(val)) {
          matches.push({ type: 'state', label: s.name, slug: s.slug });
        }
      });

      // Check counties (limit to 10 to avoid DOM bloat)
      if (countiesDict) {
        let count = 0;
        for (let i = 0; i < countiesDict.length; i++) {
          if (countiesDict[i].name.toLowerCase().includes(val)) {
            matches.push({ type: 'county', label: countiesDict[i].name, url: countiesDict[i].url });
            count++;
            if (count >= 10) break;
          }
        }
      }

      if (matches.length > 0) {
        autocomplete.classList.remove('hidden');
        matches.forEach(m => {
          const item = document.createElement('div');
          item.className = 'p-2 hover:bg-[var(--bg-input)] cursor-pointer rounded-lg text-sm text-[var(--text-primary)] mb-1 transition-colors';
          
          if (m.type === 'region') {
            item.innerHTML = `<strong>${m.label}</strong><br/><span class="text-xs text-[var(--text-muted)]">Includes: ${m.links.slice(0,3).join(', ')}...</span>`;
            item.addEventListener('click', () => {
              autocomplete.classList.add('hidden');
              input.value = '';
              const prompt = `Can you list the states in the ${m.label} and provide links to them?`;
              addMessage(prompt, true);
              messageHistory.push({ role: 'user', content: prompt });
              fetchAIResponse();
            });
          } else if (m.type === 'county') {
            item.innerHTML = `<a href="${m.url}" class="block w-full">Go to <strong>${m.label}</strong> Calculator</a>`;
            item.addEventListener('click', () => {
              window.location.href = m.url;
            });
          } else {
            item.innerHTML = `<a href="/states/${m.slug}/" class="block w-full">Go to <strong>${m.label}</strong> Calculator</a>`;
            item.addEventListener('click', () => {
              window.location.href = `/states/${m.slug}/`;
            });
          }
          autocomplete.appendChild(item);
        });
      } else {
        autocomplete.classList.add('hidden');
      }
    });

    // Close autocomplete on click outside
    document.addEventListener('click', (e) => {
      if (!autocomplete.contains(e.target) && e.target !== input) {
        autocomplete.classList.add('hidden');
      }
    });

    // Handle Form Submit
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const val = input.value.trim();
      if (!val) return;
      
      autocomplete.classList.add('hidden');
      input.value = '';
      
      addMessage(val, true);
      messageHistory.push({ role: 'user', content: val });
      fetchAIResponse();
    });

    async function fetchAIResponse() {
      const bubble = addMessage('<span class="animate-pulse">Thinking...</span>', false);
      const submitBtn = form.querySelector('button');
      submitBtn.disabled = true;

      // Simulate a small delay for natural feel
      setTimeout(() => {
        bubble.innerHTML = "I am a simple navigation assistant! Please start typing the name of a state (like 'Texas') or a region (like 'Western') and select an option from the dropdown menu above to navigate there.";
        messagesEl.scrollTop = messagesEl.scrollHeight;
        submitBtn.disabled = false;
        input.focus();
      }, 500);
    }
  })();
</script>
