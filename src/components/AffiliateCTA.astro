---
/**
 * AffiliateCTA.astro - "Compare Lenders" affiliate conversion card
 * Styled with a green gradient to stand out as a revenue element.
 * Link defaults to LendingTree; replace with your affiliate link.
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div
  class={`relative overflow-hidden rounded-2xl p-6 sm:p-8 my-6 border ${className}`}
  style="background: linear-gradient(135deg, rgba(16,185,129,0.08), rgba(5,150,105,0.15)); border-color: rgba(16,185,129,0.25);"
  id="affiliate-cta-card"
>
  <!-- Decorative glow -->
  <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full opacity-20" style="background: radial-gradient(circle, #10b981, transparent);"></div>

  <div class="relative z-10">
    <div class="flex items-center gap-2 mb-2">
      <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="text-lg font-bold" style="color: var(--text-primary);">
        You could save on your monthly payment
      </h3>
    </div>

    <p class="text-sm mb-5" style="color: var(--text-secondary);">
      Based on your loan, lenders in your area may offer lower rates. Compare offers in seconds — no impact on your credit score.
    </p>

    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
      <div class="relative flex-1">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4" style="color: var(--text-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <input
          type="text"
          id="affiliate-zip-input"
          placeholder="Enter ZIP Code"
          inputmode="numeric"
          maxlength="5"
          class="calc-input w-full pl-10 font-mono"
          aria-label="ZIP Code for rate comparison"
        />
      </div>
      <a
        href="https://www.lendingtree.com"
        target="_blank"
        rel="noopener noreferrer nofollow"
        id="affiliate-cta-button"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-white font-bold text-sm shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-0.5 whitespace-nowrap"
        style="background: linear-gradient(135deg, #10b981, #059669);"
      >
        Compare Lenders Now
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>

    <p class="text-xs mt-4 flex items-center gap-1" style="color: var(--text-muted);">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
      </svg>
      Powered by LendingTree · Free, no obligation
    </p>
  </div>
</div>

<script>
  // Append ZIP code to the affiliate link when user types
  document.addEventListener('DOMContentLoaded', () => {
    const zipInput = document.getElementById('affiliate-zip-input') as HTMLInputElement;
    const ctaBtn = document.getElementById('affiliate-cta-button') as HTMLAnchorElement;

    zipInput?.addEventListener('input', () => {
      const zip = zipInput.value.replace(/\D/g, '').slice(0, 5);
      zipInput.value = zip;
      if (zip.length === 5) {
        ctaBtn.href = `https://www.lendingtree.com/?zipcode=${zip}`; // TODO: replace with real LendingTree affiliate ID once approved
      } else {
        ctaBtn.href = 'https://www.lendingtree.com'; // TODO: replace with real LendingTree affiliate ID once approved
      }
    });
  });
</script>
