  </div>

  <!-- Tooltip -->
  <div id="map-tooltip" class="absolute pointer-events-none opacity-0 transition-opacity duration-200 z-10 bg-[var(--bg-card)] backdrop-blur-md border border-[var(--border-default)] rounded-xl shadow-xl p-4 min-w-[200px]">
    <div class="flex items-center gap-2 mb-2 border-b border-[var(--border-default)] pb-2">
      <span class="text-xl">🏠</span>
      <h3 id="tt-name" class="font-bold text-[var(--text-primary)] text-lg">State</h3>
    </div>
    <div class="text-sm space-y-1">
      <div class="flex justify-between gap-4"><span class="text-[var(--text-muted)]">Median Price:</span> <strong id="tt-price" class="text-[var(--text-primary)]"></strong></div>
      <div class="flex justify-between gap-4"><span class="text-[var(--text-muted)]">Property Tax:</span> <strong id="tt-tax" class="text-[var(--text-primary)]"></strong></div>
      <div class="flex justify-between gap-4"><span class="text-[var(--text-muted)]">Avg 30-yr:</span> <strong id="tt-rate" class="text-[var(--text-primary)]"></strong></div>
    </div>
    <div class="mt-3 text-xs text-[var(--color-usa-blue)] font-semibold text-right">Click to explore &rarr;</div>
  </div>

  <!-- State Detail Panel -->
  <div id="state-panel" class="absolute inset-0 bg-[var(--bg-surface)] backdrop-blur-xl z-20 translate-x-full transition-transform duration-500 flex flex-col">
    <!-- Header -->
    <div class="p-6 border-b border-[var(--border-default)] flex flex-col md:flex-row items-start md:items-center justify-between sticky top-0 bg-[var(--bg-surface)] z-30 gap-4">
      <div>
        <button id="btn-back-map" class="text-sm text-[var(--text-muted)] hover:text-[var(--color-usa-blue)] flex items-center gap-2 mb-2 transition-colors">
          &larr; Back to Map
        </button>
        <h2 id="panel-state-name" class="text-3xl font-extrabold text-[var(--text-primary)]">State Name</h2>
      </div>
      <a id="btn-state-calc" href="#" class="px-6 py-3 rounded-xl bg-gradient-to-r from-[var(--color-usa-blue)] to-[#1e4b87] text-white font-bold shadow-lg hover:shadow-xl transition-all active:scale-95 flex items-center gap-2 shrink-0">
        Use State Calculator &rarr;
      </a>
    </div>

    <!-- Content -->
    <div class="p-6 overflow-y-auto flex-grow bg-[var(--bg-card)]">
      <p id="panel-state-note" class="text-[var(--text-muted)] italic max-w-3xl mb-8 leading-relaxed text-lg border-l-4 border-[var(--color-usa-red)] pl-4"></p>
      
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-6 gap-4">
        <h3 class="text-xl font-bold text-[var(--text-primary)] flex items-center gap-2">
          <span class="text-2xl">📍</span> Browse <span id="county-count" class="text-[var(--color-usa-blue)] mx-1">0</span> Counties
        </h3>
        <div class="relative max-w-xs w-full">
          <input type="text" id="county-search" placeholder="Search counties..." class="w-full bg-[var(--bg-surface)] border border-[var(--border-default)] rounded-lg py-2 px-4 pl-10 text-[var(--text-primary)] focus:outline-none focus:border-[var(--color-usa-blue)] transition-colors shadow-inner">
          <span class="absolute left-3 top-2.5 opacity-50">🔍</span>
        </div>
      </div>

      <div id="county-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 pb-12">
        <!-- County cards rendered via JS -->
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ states, counties }}>
  window.interactiveMapData = { states, counties };
</script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const { states, counties } = window.interactiveMapData;
    
    // Create fast lookup maps
    const stateMap = new Map(states.map(s => [s.slug, s]));
    
    // DOM Elements
    const container = document.getElementById('interactive-us-map-container');
    const mapView = document.getElementById('map-view');
    const tooltip = document.getElementById('map-tooltip');
    const statePanel = document.getElementById('state-panel');
    const btnBackMap = document.getElementById('btn-back-map');
    const btnStateCalc = document.getElementById('btn-state-calc');
    const countySearch = document.getElementById('county-search');
    const countyGrid = document.getElementById('county-grid');
    
    const currencyFmt = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
    const pctFmt = new Intl.NumberFormat('en-US', { style: 'percent', minimumFractionDigits: 2, maximumFractionDigits: 2 });

    let currentStateSlug = null;
    let currentCounties = [];

    // Hover logic for map
    document.querySelectorAll('.state-path').forEach(path => {
      path.addEventListener('mouseenter', (e) => {
        const slug = e.target.getAttribute('data-state');
        const state = stateMap.get(slug);
        if (!state) return;

        // Populate tooltip
        document.getElementById('tt-name').textContent = `${state.name} (${state.abbr})`;
        document.getElementById('tt-price').textContent = currencyFmt.format(state.medianPrice);
        document.getElementById('tt-tax').textContent = pctFmt.format(state.taxRate / 100);
        document.getElementById('tt-rate').textContent = `${state.avgRate30}%`;

        tooltip.classList.remove('opacity-0');
        
        // Minor visual bump
        e.target.style.transform = 'translateY(-2px) scale(1.01)';
        e.target.style.transformOrigin = 'center';
        
        // Bring path to front by re-appending it so border stroke isn't clipped
        e.target.parentNode.appendChild(e.target);
      });

      path.addEventListener('mousemove', (e) => {
        const containerRect = container.getBoundingClientRect();
        let x = e.clientX - containerRect.left + 20;
        let y = e.clientY - containerRect.top + 20;
        
        // Keep in bounds
        if (x + tooltip.offsetWidth > containerRect.width) x = containerRect.width - tooltip.offsetWidth - 10;
        if (y + tooltip.offsetHeight > containerRect.height) y = containerRect.height - tooltip.offsetHeight - 10;

        tooltip.style.left = `${x}px`;
        tooltip.style.top = `${y}px`;
      });

      path.addEventListener('mouseleave', (e) => {
        tooltip.classList.add('opacity-0');
        e.target.style.transform = '';
      });

      path.addEventListener('click', (e) => {
        const slug = e.target.getAttribute('data-state');
        openStatePanel(slug);
      });

      // Keyboard support
      path.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          const slug = e.target.getAttribute('data-state');
          openStatePanel(slug);
        }
      });
    });

    function openStatePanel(slug) {
      const state = stateMap.get(slug);
      if (!state) return;
      
      currentStateSlug = slug;
      tooltip.classList.add('opacity-0');

      document.getElementById('panel-state-name').textContent = state.name;
      document.getElementById('panel-state-note').textContent = state.localNote || `Explore mortgage rates and property taxes across ${state.name}.`;
      btnStateCalc.href = `/states/${slug}/`;

      // Load counties
      currentCounties = counties[slug] || [];
      // Sort alphabetically
      currentCounties.sort((a,b) => a.name.localeCompare(b.name));
      
      document.getElementById('county-count').textContent = currentCounties.length;
      countySearch.value = '';
      renderCounties(currentCounties);

      statePanel.classList.remove('translate-x-full');
      mapView.classList.add('opacity-0');
    }

    function closeStatePanel() {
      statePanel.classList.add('translate-x-full');
      mapView.classList.remove('opacity-0');
      currentStateSlug = null;
    }

    btnBackMap.addEventListener('click', closeStatePanel);

    function renderCounties(list) {
      countyGrid.innerHTML = '';
      const fragment = document.createDocumentFragment();
      list.forEach(c => {
        const countySlug = c.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
        const taxVal = c.effectiveTaxRate ? pctFmt.format(c.effectiveTaxRate / 100) : 'N/A';
        
        const card = document.createElement('a');
        card.href = `/states/${currentStateSlug}/${countySlug}/`;
        card.className = 'group block p-4 rounded-xl bg-[var(--bg-surface)] border border-[var(--border-default)] hover:border-[var(--color-usa-blue)] hover:shadow-lg transition-all duration-300';
        card.innerHTML = `
          <h4 class="font-bold text-[var(--text-primary)] mb-2 group-hover:text-[var(--color-usa-blue)] transition-colors">${c.name}</h4>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-[var(--text-muted)]">Home Value</span>
            <span class="font-semibold text-[var(--text-primary)]">${currencyFmt.format(c.medianHomeValue)}</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-[var(--text-muted)]">Tax Rate</span>
            <span class="font-semibold text-[var(--color-usa-red)]">${taxVal}</span>
          </div>
        `;
        fragment.appendChild(card);
      });
      countyGrid.appendChild(fragment);
    }

    countySearch.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      const filtered = currentCounties.filter(c => c.name.toLowerCase().includes(query));
      renderCounties(filtered);
    });
  });
</script>
